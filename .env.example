# L'Espoir asbl — Astro SSR runtime config (server-only; never commit real .env)
NODE_ENV=production
HOST=127.0.0.1
PORT=4325

# ContentCore origin (WITHOUT the /api/v1 suffix). Defaults to the tenant domain;
# only set to override (e.g. staging).
# CMS_ORIGIN=https://lespoir.contentcore.app

# Optional server-only bearer token — the public delivery API needs none; set only
# for auth/preview server-to-server calls.
# CMS_TOKEN=
