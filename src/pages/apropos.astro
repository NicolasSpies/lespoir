<Fragment slot="scripts">
<script>
(function() {
  'use strict';
      /* ── SCROLL REVEAL ── */
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    var revealItems = [];

    document.querySelectorAll('.section-text, .section-img').forEach(function(el, i) {
      revealItems.push({ el: el, delay: (i % 2) * 120 });
    });

    document.querySelectorAll('.value-col').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 80 });
    });

    document.querySelectorAll('.team-col').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 100 });
    });

    var donText = document.querySelector('.don-text');
    var donCards = document.querySelector('.don-cards');
    if (donText) revealItems.push({ el: donText, delay: 0 });
    if (donCards) revealItems.push({ el: donCards, delay: 150 });

    revealItems.forEach(function(item) { item.el.classList.add('scroll-reveal'); });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var item = revealItems.find(function(g) { return g.el === el; });
        setTimeout(function() { el.classList.add('revealed'); }, item ? item.delay : 0);
        observer.unobserve(el);
      });
    }, { threshold: 0.1 });

    revealItems.forEach(function(item) { observer.observe(item.el); });

    // Safeguard: reveal anything still hidden after 1.5s
    setTimeout(function() { revealItems.forEach(function(item) { if (!item.el.classList.contains("revealed")) { item.el.classList.add("revealed"); observer.unobserve(item.el); } }); }, 1500);
  }

  /* ── NAV DROPDOWNS ── */
  

  if (window.matchMedia('(hover: none)').matches && 'IntersectionObserver' in window) {
    var touchTargets = document.querySelectorAll('.don-card, .value-card, .person-card, .partner-pill');
    var touchObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        entry.target.classList.toggle('is-active', entry.isIntersecting);
      });
    }, { threshold: [0.5], rootMargin: '-20% 0px -20% 0px' });
    touchTargets.forEach(function(el) { touchObs.observe(el); });
  }

  /* ── NOTRE HISTOIRE · scroll-following timeline line ── */
  (function () {
    var tl = document.getElementById('histoireTimeline');
    var fill = document.getElementById('histoireTimelineFill');
    if (!tl || !fill) return;
    var items = Array.prototype.slice.call(tl.querySelectorAll('.tl-item'));
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      fill.style.height = 'calc(100% - 20px)';
      items.forEach(function (it) { it.classList.add('is-active'); });
      return;
    }
    var ticking = false;
    function update() {
      ticking = false;
      var rect = tl.getBoundingClientRect();
      var trigger = window.innerHeight * 0.5;
      fill.style.height = Math.max(0, Math.min(rect.height - 20, trigger - rect.top - 10)) + 'px';
      items.forEach(function (it) {
        var dot = it.querySelector('.tl-dot');
        var dr = (dot || it).getBoundingClientRect();
        it.classList.toggle('is-active', (dr.top + dr.height / 2) <= trigger);
      });
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();

})();
</script>


