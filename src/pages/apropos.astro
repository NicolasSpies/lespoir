---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import WaveDivider from '../components/WaveDivider.astro';
import { getPage, getList, getTaxonomyTerms, serviceColor, sectionData, str, asImage, imageUrl, imageSrcSet, focusPosition, extractVisitorHeaders } from '../lib/cms';
import type { CmsEntry } from '../lib/cms';
import DOMPurify from 'isomorphic-dompurify';

const vis = extractVisitorHeaders(Astro.request);
const page = await getPage('a-propos', vis);
const d = sectionData(page, 'a_propos');

// Team: grouped by the `service` taxonomy (SRG/SASE/SAPA) — headers always shown,
// even when a category has no members yet. Members come from the `equipe` entries.
const team = await getList('equipe', vis);
const serviceTerms = await getTaxonomyTerms('service', vis);
const termSlugs = (e: CmsEntry): string[] =>
  ((e as unknown as { taxonomy_terms?: Array<{ slug?: string }> }).taxonomy_terms ?? []).map(t => t.slug ?? '');
const DIR = 'direction';
const hasTerm = (e: CmsEntry, slug: string): boolean => termSlugs(e).includes(slug);
// A member with `direction` shows ONLY in the Direction group; their service term(s)
// (SRG/SASE/SAPA) surface as coloured bubbles on the photo instead.
const teamSections: Array<{ slug: string; label: string; color: string; members: CmsEntry[] }> =
  serviceTerms.map(t => ({
    slug: t.slug,
    label: t.label,
    color: serviceColor(t.slug),
    members: team.filter(e => hasTerm(e, t.slug) && (t.slug === DIR || !hasTerm(e, DIR))),
  }));
const teamUngrouped = team.filter(e => !serviceTerms.some(t => hasTerm(e, t.slug)));
if (teamUngrouped.length) teamSections.push({ slug: '', label: 'Équipe', color: '#002626', members: teamUngrouped });
// Photo bubbles = the member's service terms other than the current group (and not `direction`).
const badgesFor = (e: CmsEntry, groupSlug: string): Array<{ label: string; color: string }> =>
  termSlugs(e)
    .filter(s => s && s !== groupSlug && s !== DIR)
    .map(s => ({ label: serviceTerms.find(t => t.slug === s)?.label ?? s, color: serviceColor(s) }));

// Timeline repeater (ligne_de_temps_a_propos): map to existing markup when present.
type TimelineItem = { annee_notre_histoire?: string; titre_ligne_de_temps?: string; description_ligne_de_temps?: string };
const timeline = Array.isArray((d as Record<string, unknown>).ligne_de_temps_a_propos)
  ? ((d as Record<string, unknown>).ligne_de_temps_a_propos as TimelineItem[])
  : [];

// Notre-histoire image: use the real dimensions from the API (no forced crop).
const histoImg = asImage(d.foto_notre_histoire_a_propos);
const histoAspect = histoImg && histoImg.width && histoImg.height ? `${histoImg.width} / ${histoImg.height}` : null;

const title = "À propos · L'Espoir asbl, aide à la jeunesse depuis 1985";
const description = "Découvrez l’histoire, l’équipe et nos valeurs de L'Espoir asbl, acteur de l'aide à la jeunesse à Huy depuis 1985, agréé par la Fédération Wallonie-Bruxelles.";
const keywords = "L'Espoir asbl histoire, aide à la jeunesse 1985, équipe éducative Huy, mission asbl, valeurs éducation spécialisée, asbl Amay Belgique";
const canonicalPath = "/apropos";
const ogImage = "https://images.unsplash.com/photo-1529390079861-591de354faf5?fm=webp&w=1200&q=80";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"foundingLocation\":{\"@type\":\"Place\",\"name\":\"Antheit, Belgique\"},\"award\":\"Agrément Fédération Wallonie-Bruxelles, secteur Aide à la Jeunesse\",\"slogan\":\"Aide à la jeunesse à Huy depuis 1985\",\"numberOfEmployees\":{\"@type\":\"QuantitativeValue\",\"value\":20,\"unitText\":\"personnes\"},\"knowsLanguage\":\"fr-BE\",\"memberOf\":{\"@type\":\"Organization\",\"name\":\"Aide à la Jeunesse, Fédération Wallonie-Bruxelles\"},\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://asbl-espoir.be/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"À propos\",\"item\":\"https://asbl-espoir.be/apropos\"}]},{\"@type\":\"AboutPage\",\"mainEntity\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/apropos#webpage\",\"url\":\"https://asbl-espoir.be/apropos\",\"name\":\"À propos · L'Espoir asbl, aide à la jeunesse depuis 1985\",\"description\":\"Découvrez l’histoire, l’équipe et nos valeurs de L'Espoir asbl, acteur de l'aide à la jeunesse à Huy depuis 1985, agréé par la Fédération Wallonie-Bruxelles.\",\"inLanguage\":\"fr-BE\",\"dateModified\":\"2026-05-12\",\"datePublished\":\"2024-01-15\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
];
const activeNav = "apropos";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
  trackEntryId={page?.id ?? page?.entry_id ?? null}
  trackSlug={page?.slug ?? null}
>

<style is:global>

  /* ── Don cards hover ── */
  .don-card { transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease; }
  .don-card:hover { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
  .btn-accent:hover { box-shadow: 0 10px 24px rgba(192,75,114,0.35); filter: brightness(1.05); }

  /* ── Image blur-up loading ── */
  .blur-up {
    filter: blur(14px); transform: scale(1.03);
    transition: filter 0.6s ease, transform 0.6s ease, opacity 0.6s ease;
    will-change: filter;
  }
  .blur-up.is-loaded { filter: blur(0); transform: scale(1); }

  /* ── Service image wrapper ── */
  .service-img-wrap {
    border-radius: 1rem; overflow: hidden; height: 400px;
    box-shadow: 0 20px 60px rgba(0,38,38,0.12);
    transform: rotate(-1.5deg);
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), box-shadow 0.5s ease;
  }
  .service-img-wrap.revealed { transform: rotate(-1.5deg); }
  .service-img-wrap.tilt-right.revealed { transform: rotate(1.5deg); }
  .service-img-wrap:hover, .service-img-wrap.revealed:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 0 28px 70px rgba(0,38,38,0.18);
  }
  .service-img-wrap.tilt-right { transform: rotate(1.5deg); }
  .service-img-wrap.tilt-right:hover { transform: rotate(0deg) translateY(-4px); }
  @media (min-width: 768px) { .service-img-wrap { height: 480px; } }
  .service-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Notre histoire · image + scroll-animated timeline ── */
  .histoire-media { position: relative; width: 100%; background: #EAE9E5; box-shadow: 0 20px 50px -22px rgba(0,38,38,0.28); }
  .histoire-media img { display: block; width: 100%; height: 100%; object-fit: cover; }

  .histoire-timeline { position: relative; padding-left: 2.75rem; }
  .tl-line-bg, .tl-line-fill { position: absolute; left: 7px; width: 3px; border-radius: 3px; }
  .tl-line-bg { top: 10px; bottom: 10px; background: rgba(0,38,38,0.12); }
  .tl-line-fill { top: 10px; height: 0; background: #C04B72; box-shadow: 0 0 10px rgba(192,75,114,0.45); transition: height 0.15s ease-out; }
  .tl-item { position: relative; padding-bottom: 2.25rem; }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-dot {
    position: absolute; left: -2.75rem; top: 4px;
    width: 17px; height: 17px; border-radius: 50%;
    background: #fbf9f8; border: 3px solid rgba(0,38,38,0.22); z-index: 2;
    transition: border-color 0.35s ease, background 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }
  .tl-item.is-active .tl-dot { border-color: #C04B72; background: #C04B72; transform: scale(1.15); box-shadow: 0 0 0 5px rgba(192,75,114,0.14); }
  .tl-body { opacity: 0.5; transform: translateY(2px); transition: opacity 0.4s ease, transform 0.4s ease; }
  .tl-item.is-active .tl-body { opacity: 1; transform: none; }
  .timeline-year { font-size: 0.72rem; font-weight: 900; color: #C04B72; letter-spacing: 0.06em; margin-bottom: 0.25rem; text-transform: uppercase; }
  @media (prefers-reduced-motion: reduce) {
    .tl-line-fill { transition: none; }
    .tl-body { opacity: 1; transform: none; }
  }

  /* ── Value cards ── */
  .value-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 1rem; padding: 2rem;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .value-card:hover { background: rgba(255,255,255,0.10); transform: translateY(-3px); }
  .value-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(192,75,114,0.15);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
  }

  /* ── Team blocks (legacy role overview) ── */
  .team-block {
    background: #fff; border-radius: 1rem; padding: 2rem;
    border: 1px solid rgba(0,38,38,0.08);
  }
  .team-role-row {
    display: flex; align-items: flex-start; gap: 0.75rem;
    padding: 0.7rem 0; border-bottom: 1px solid rgba(0,38,38,0.06);
  }
  .team-role-row:last-child { border-bottom: none; padding-bottom: 0; }

  /* ── Service group banner ── */
  .service-banner {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 1.5rem; border-radius: 1rem;
    margin-bottom: 1.5rem; color: #fff;
    box-shadow: 0 6px 20px rgba(0,0,0,0.05);
  }
  .service-banner .banner-icon-wrap {
    width: 3rem; height: 3rem; border-radius: 50%;
    background: rgba(255,255,255,0.18);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .service-banner .banner-abbr { font-size: 1.35rem; font-weight: 800; line-height: 1.1; letter-spacing: -0.01em; }
  .service-banner .banner-name { font-size: 0.78rem; font-weight: 500; opacity: 0.85; margin-top: 0.15rem; letter-spacing: 0.02em; }
  .service-banner .banner-count {
    margin-left: auto; padding: 0.35rem 0.8rem;
    border-radius: 999px; background: rgba(255,255,255,0.2);
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.04em; white-space: nowrap;
  }

  /* ── Person card ── */
  .person-card {
    position: relative; background: #fff; border-radius: 1rem;
    padding: 0; text-align: left;
    border: 1px solid rgba(0,38,38,0.06);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s ease;
    overflow: hidden;
    display: flex; flex-direction: column;
  }
  .person-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -10px rgba(0,38,38,0.18);
  }
  .person-photo {
    position: relative; aspect-ratio: 1/1; overflow: hidden;
    background: var(--svc-color, #C04B72);
  }
  .person-photo::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(180deg, transparent 55%, rgba(0,38,38,0.28));
  }
  .person-photo img {
    position: relative; z-index: 1;
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
  }
  .person-card:hover .person-photo img { transform: scale(1.06); }
  .person-initials {
    /* Uniform photo placeholder · service color bg + L'Espoir logo mark centered */
    position: absolute; inset: 0; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--svc-color, #C04B72), rgba(0,0,0,0.18));
  }
  .person-initials::after {
    content: ''; display: block;
    width: 70%; aspect-ratio: 901/338;       /* lespoir-logo wordmark aspect */
    background: #fff; opacity: 0.42;
    -webkit-mask: url('/lespoir-logo.svg') no-repeat center / contain;
            mask: url('/lespoir-logo.svg') no-repeat center / contain;
  }
  .person-badge {
    position: absolute; top: 0.75rem; left: 0.75rem; z-index: 2;
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.3rem 0.65rem; border-radius: 999px;
    background: rgba(255,255,255,0.92);
    color: var(--svc-color, #8b2a4e);
    font-size: 0.68rem; font-weight: 800;
    letter-spacing: 0.06em; text-transform: uppercase;
    backdrop-filter: blur(6px);
    box-shadow: 0 4px 10px rgba(0,38,38,0.08);
  }
  .person-badge .material-symbols-outlined {
    font-size: 14px; font-variation-settings: 'FILL' 1;
  }
  /* stack of service bubbles on a photo (e.g. a Direction member's SRG/SAPA) */
  .person-badges {
    position: absolute; top: 0.75rem; left: 0.75rem; z-index: 2;
    display: flex; flex-direction: column; gap: 0.35rem; align-items: flex-start;
  }
  .person-badges .person-badge { position: static; top: auto; left: auto; }
  .person-info {
    padding: 1.1rem 1.15rem 1.25rem;
    flex: 1; display: flex; flex-direction: column;
    background: #fff;
  }
  .person-name {
    font-weight: 800; font-size: 1.02rem; color: #002626;
    margin-bottom: 0.1rem; line-height: 1.2;
  }
  .person-role {
    font-size: 0.78rem; color: #002626; opacity: 0.58;
    line-height: 1.3; font-weight: 500;
  }
  .person-quote {
    position: relative;
    font-size: 0.83rem; color: rgba(0,38,38,0.78);
    font-style: italic; line-height: 1.55;
    padding: 0.85rem 0 0 1.5rem; margin-top: 0.9rem;
    border-top: 1px dashed rgba(0,38,38,0.1);
  }
  .person-quote::before {
    content: '"'; font-family: Georgia, 'Times New Roman', serif;
    position: absolute; top: 0.5rem; left: 0;
    font-size: 2.8rem; color: var(--svc-color, #C04B72);
    opacity: 0.35; line-height: 0.8; font-style: normal;
  }
  .person-phone {
    display: inline-flex; align-items: center; gap: 0.35rem;
    margin-top: 0.6rem; font-size: 0.78rem; font-weight: 600;
    color: var(--svc-color, #8b2a4e); text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .person-phone .material-symbols-outlined {
    font-size: 14px; font-variation-settings: 'FILL' 1;
  }
  .person-phone:hover { opacity: 0.75; }

  /* ── Service group wrapper ── */
  .service-group { margin-bottom: 3rem; }
  .service-group:last-child { margin-bottom: 0; }

  /* ── Partner pills ── */
  .partner-pill {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 1.1rem; border-radius: 999px;
    background: #fff; border: 1px solid rgba(0,38,38,0.1);
    font-size: 0.85rem; font-weight: 600; color: #002626;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .partner-pill:hover { border-color: #C04B72; box-shadow: 0 4px 12px rgba(192,75,114,0.15); }
  /* ── Scroll-reveal hover fix: specificity (0,3,0) beats .scroll-reveal.revealed (0,2,0) ── */
  .value-card.revealed:hover { transform: translateY(-3px); }
  .person-card.revealed:hover { transform: translateY(-4px); }

  /* ── Organic blobs ── */
  .blob { position:absolute; border-radius:60% 40% 70% 30% / 50% 60% 40% 50%; pointer-events:none; z-index:0; }
  .blob-parent > :not(.blob) { position:relative; z-index:1; }
  .blob-parent { position:relative; overflow:hidden; }

  /* ── Mobile: auto-activate hover state when element is centered in viewport ── */
  @media (hover: none) {
    .don-card.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
    .don-card.revealed.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); }
    .value-card.is-active { background: rgba(255,255,255,0.10); transform: translateY(-3px); }
    .value-card.revealed.is-active { transform: translateY(-3px); }
    .person-card.is-active { transform: translateY(-4px); box-shadow: 0 14px 28px rgba(0,38,38,0.10); }
    .person-card.revealed.is-active { transform: translateY(-4px); }
    .partner-pill.is-active { border-color: #C04B72; box-shadow: 0 4px 12px rgba(192,75,114,0.15); }
  }

</style>

<main id="main" class="flex-grow">

  <!-- ── HEADER ── -->
  <section class="relative bg-[#EFE7DA] pt-16 pb-16 md:pt-24 md:pb-24 px-6 md:px-8 overflow-hidden">
    <div aria-hidden="true" style="font-family:'Pally',sans-serif; position:absolute; right:-3vw; top:50%; transform:translateY(-46%); font-weight:700; font-size:clamp(13rem,22vw,26rem); line-height:0.85; color:#002626; opacity:0.07; letter-spacing:-0.05em; pointer-events:none; user-select:none; white-space:nowrap;">
      1985
    </div>

    <div class="relative max-w-4xl mx-auto">
      <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:rgba(0,38,38,0.5);display:block;margin-bottom:22px;">L'Espoir asbl · Huy, Belgique</span>

      <h1 style="font-family:'Pally',sans-serif; font-weight:700; font-size:clamp(2.6rem,5.2vw,4.4rem); line-height:1.02; margin-bottom:24px; max-width:780px;">
        <Fragment set:html={DOMPurify.sanitize(String(d.titre_a_propos))} />
      </h1>

      <p style="font-size:17px; color:rgba(0,38,38,0.62); line-height:1.7; max-width:520px; margin-bottom:28px;">
        {str(d.description_a_propos)}
      </p>

      <div style="display:flex; align-items:center; gap:24px; flex-wrap:wrap;">
        <a href="#histoire" class="btn btn-accent btn-lg">
          Notre histoire
          <span class="material-symbols-outlined" style="font-size:18px;">arrow_downward</span>
        </a>
        <span style="display:inline-flex; align-items:baseline; gap:6px;">
          <span style="font-family:'Pally',sans-serif; font-weight:500; color:rgba(0,38,38,0.45); font-size:13px; letter-spacing:0.08em; text-transform:uppercase;">Depuis</span>
          <span style="font-family:'Pally',sans-serif; font-weight:700; color:#C04B72; font-size:18px;">40 ans</span>
        </span>
      </div>
    </div>
  </section>

  <!-- ── NOTRE HISTOIRE ── -->
  <section id="histoire" class="py-16 md:py-24 px-6 md:px-8 bg-surface blob-parent">
    <div class="blob" aria-hidden="true" style="width:200px;height:200px;background:rgba(229,131,70,0.07);top:20px;left:-50px;border-radius:45% 55% 40% 60% / 60% 40% 60% 40%;"></div>
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left · intro text + image below it -->
      <div class="section-text">
        <span class="text-[#C04B72] font-black tracking-widest text-sm uppercase block mb-4">Notre histoire</span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#002626] mb-6 leading-tight">
          <Fragment set:html={DOMPurify.sanitize(String(d.titre_notre_histoire_a_propos))} />
        </h2>
        {String(d.description_notre_histoire_a_propos).split(/\n\s*\n/).filter(p => p.trim()).map((p, i, arr) => (
          <p class={`text-base md:text-lg text-[#002626]/75 leading-relaxed ${i === arr.length - 1 ? 'mb-8' : 'mb-4'}`}>{p.trim()}</p>
        ))}

        <!-- Image · under the text, real API dimensions (no forced crop) -->
        <div class="histoire-media rounded-3xl overflow-hidden" style={histoAspect ? `aspect-ratio:${histoAspect}` : ''}>
          {histoImg
            ? <img src={imageUrl(histoImg, 'lg')} srcset={imageSrcSet(histoImg)} sizes="(min-width: 1024px) 45vw, 100vw" alt={histoImg.alt ?? "L'équipe de L'Espoir asbl"} loading="lazy" decoding="async" />
            : (<Placeholder alt="L'équipe de L'Espoir asbl" aspectRatio='4/3' />)}
        </div>
      </div>

      <!-- Right · timeline with a scroll-following line -->
      <div class="histoire-timeline" id="histoireTimeline">
        <span class="tl-line-bg" aria-hidden="true"></span>
        <span class="tl-line-fill" id="histoireTimelineFill" aria-hidden="true"></span>
        {timeline.map((item) => (
          <div class="tl-item">
