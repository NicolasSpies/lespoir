---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Page introuvable · L'Espoir asbl";
const description = "La page que vous cherchez n'existe pas ou a été déplacée. Retrouvez rapidement les services, les actualités et le contact de L'Espoir asbl.";
const canonicalPath = "/404";
const robots = "noindex, follow";
const activeNav = null;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  robots={robots}
  activeNav={activeNav}
>

<style is:global>
html { scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background-color: #fbf9f8; }

  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    display: inline-block; line-height: 1;
    transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }

  *:focus { outline: none; }
  *:focus-visible { outline: 2px solid #C04B72; outline-offset: 3px; border-radius: 4px; }

  :root { --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1); }

  a:hover > .material-symbols-outlined,
  a:hover > span > .material-symbols-outlined { transform: translateX(4px); }

  nav a, footer a { transition: var(--transition); }

  .nav-link { position: relative; padding-bottom: 6px; color: #002626; }
  .nav-link::after { content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 2px; background: #002626; transform: scaleX(0); transform-origin: center; transition: transform 0.3s cubic-bezier(0.4,0,0.2,1); }
  .nav-link:hover::after, .nav-link.is-active::after { transform: scaleX(1); }

  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 1rem 2rem; border-radius: 999px; font-weight: 700; font-size: 1rem; font-family: inherit; cursor: pointer; border: 0; transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, color 0.25s ease, filter 0.25s ease; line-height: 1; text-decoration: none; white-space: nowrap; }
  .btn:hover { transform: translateY(-2px); }
  .btn-lg { padding: 1.1rem 2.2rem; font-size: 1.05rem; }
  .btn-sm { padding: 0.75rem 1.3rem; font-size: 0.85rem; min-height: 44px; }
  .btn-primary { background: #002626; color: #EFE7DA; }
  .btn-primary:hover { box-shadow: 0 10px 24px rgba(0,38,38,0.25); filter: brightness(1.08); }
  .btn-accent { background: #C04B72; color: #fff; }
  .btn-accent:hover { box-shadow: 0 10px 24px rgba(192,75,114,0.35); }
  .btn-accent .material-symbols-outlined { font-variation-settings: 'FILL' 0; transition: font-variation-settings 0.35s ease, transform 0.35s ease; }
  .btn-accent:hover .material-symbols-outlined { font-variation-settings: 'FILL' 1; transform: scale(1.08); }
  .btn-outline { background: transparent; color: #002626; box-shadow: inset 0 0 0 2px #002626; }
  .btn-outline:hover { background: #002626; color: #EFE7DA; }

  nav > div { transition: padding 0.3s ease; }
  .nav-logo { width: auto; transition: height 0.3s ease; }
  nav.scrolled > div { padding-top: 0.75rem; padding-bottom: 0.75rem; }
  nav.scrolled .nav-logo { height: 2.25rem; }

  .hamburger { width: 44px; height: 44px; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 5px; padding: 0; background: transparent; border: 0; cursor: pointer; color: #002626; flex-shrink: 0; }
  .hamburger span { display: block; width: 22px; height: 2px; background: currentColor; border-radius: 2px; transition: transform 0.28s ease, opacity 0.22s ease; transform-origin: center; }
  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-drawer { position: fixed; top: 0; right: 0; width: min(88vw, 360px); height: 100vh; height: 100dvh; background: #EFE7DA; transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); z-index: 60; overflow-y: auto; display: flex; flex-direction: column; }
  .mobile-drawer.is-open { transform: translateX(0); }
  .mobile-drawer-backdrop { position: fixed; inset: 0; background: rgba(0, 38, 38, 0.5); opacity: 0; pointer-events: none; transition: opacity 0.3s ease; z-index: 55; backdrop-filter: blur(2px); }
  .mobile-drawer-backdrop.is-open { opacity: 1; pointer-events: auto; }
  .m-drawer-header { display: flex; align-items: center; justify-content: flex-end; padding: 0.85rem 1.25rem; border-bottom: 1px solid rgba(0, 38, 38, 0.08); flex-shrink: 0; }
  .m-close-btn { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(0, 38, 38, 0.07); border: 0; cursor: pointer; color: #002626; }
  .m-nav { flex: 1; padding: 0 0 0.5rem; overflow-y: auto; }
  .m-link { display: flex; align-items: center; justify-content: space-between; padding: 0.9rem 1.25rem; color: #002626; font-weight: 600; text-decoration: none; border-bottom: 1px solid rgba(0, 38, 38, 0.07); }
  .m-link:hover { background: rgba(0, 38, 38, 0.04); }
  .m-chevron { font-size: 20px; opacity: 0.45; transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1); }
  .m-accordion.is-open .m-chevron { transform: rotate(180deg); opacity: 0.7; }
  .m-accordion-body { max-height: 0; overflow: hidden; transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1); background: rgba(0, 38, 38, 0.025); }
  .m-accordion.is-open .m-accordion-body { max-height: 480px; }
  .m-sublink { display: flex; flex-direction: column; padding: 0.65rem 1.25rem 0.65rem 1.75rem; border-bottom: 1px solid rgba(0, 38, 38, 0.05); text-decoration: none; }
  .m-sublink .abbr { font-weight: 700; font-size: 0.9rem; color: #002626; }
  .m-sublink .name { font-size: 0.73rem; color: rgba(0, 38, 38, 0.55); margin-top: 1px; }
  .m-drawer-footer { padding: 1.25rem; border-top: 1px solid rgba(0, 38, 38, 0.08); }
  .m-drawer-footer .btn { width: 100%; }
  body.drawer-open { overflow: hidden; }
  .m-link-row { display: flex; align-items: stretch; border-bottom: 1px solid rgba(0,38,38,0.07); }
  .m-link-row .m-link-main { flex: 1; border-bottom: none; justify-content: flex-start; }
  .m-chevron-btn { padding: 0 1rem; background: transparent; border: none; border-left: 1px solid rgba(0,38,38,0.07); cursor: pointer; color: #002626; display: flex; align-items: center; }

  .nav-item { position: relative; display: flex; align-items: center; }
  .nav-dropdown { position: absolute; top: calc(100% + 8px); left: 0; min-width: 240px; background: #fff; border-radius: 12px; padding: 8px; box-shadow: 0 8px 32px rgba(0,0,0,0.10); opacity: 0; transform: translateY(-6px); pointer-events: none; transition: opacity 0.18s ease, transform 0.18s ease; z-index: 100; }
  .nav-item.dropdown-open .nav-dropdown { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .nav-dropdown a { display: block; padding: 8px 14px; border-radius: 8px; color: #002626; border-left: 3px solid transparent; text-decoration: none; }
  .nav-dropdown a:hover { background: #f5f5f3; }
  .nav-dropdown .dd-abbr { display: block; font-size: 15px; font-weight: 700; }
  .nav-dropdown .dd-name { display: block; font-size: 11.5px; line-height: 1.2; margin-top: 1px; opacity: 0.55; font-weight: 500; }

  /* ── 404 ── */
  .err-wrap { max-width: 960px; margin: 0 auto; padding: 4rem 1.5rem 5rem; text-align: center; }
  .err-big {
    font-size: clamp(8rem, 22vw, 15rem); line-height: 0.9;
    font-weight: 900; letter-spacing: -0.05em; color: #E58346;
    background: linear-gradient(135deg, #E58346 0%, #C04B72 50%, #119DA4 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
  }
  .err-lead { font-size: clamp(1.15rem, 2vw, 1.35rem); color: rgba(0,38,38,0.72); line-height: 1.65; max-width: 560px; margin: 0 auto 2.5rem; }
  .err-ctas { display: flex; flex-wrap: wrap; gap: 0.9rem; justify-content: center; margin-bottom: 3.5rem; }

  .quick-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; max-width: 880px; margin: 0 auto; }
  .quick-card {
    display: flex; flex-direction: column; align-items: flex-start; gap: 0.65rem;
    padding: 1.5rem 1.3rem; background: #fff;
    border: 1px solid rgba(0,38,38,0.08); border-radius: 1rem;
    text-decoration: none; text-align: left;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .quick-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,38,38,0.08); border-color: var(--accent, #C04B72); }
  .quick-card .q-icon {
    width: 40px; height: 40px; border-radius: 0.6rem;
    display: flex; align-items: center; justify-content: center;
    color: #fff; background: var(--accent, #C04B72);
  }
  .quick-card .q-title { font-weight: 800; color: #002626; font-size: 0.95rem; }
  .quick-card .q-desc { font-size: 0.8rem; color: rgba(0,38,38,0.6); line-height: 1.5; }
  .quick-card .q-arrow { margin-top: auto; padding-top: 0.4rem; display: flex; align-items: center; gap: 0.3rem; color: var(--accent, #C04B72); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; }

.skip-link{position:absolute;top:-48px;left:0;background:#002626;color:#fff;padding:10px 16px;font-weight:600;z-index:9999;text-decoration:none;border-radius:0 0 8px 0;transition:top .2s ease}.skip-link:focus{top:0;outline:2px solid #C04B72;outline-offset:2px}  /* ── Heartbeat animation for don/favorite icons ── */
  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    18% { transform: scale(1.22); }
    36% { transform: scale(1); }
    54% { transform: scale(1.18); }
    72% { transform: scale(1); }
  }
  .btn:hover .icon-heart, a:hover .icon-heart, button:hover .icon-heart {
    animation: heartbeat 1.2s ease-in-out infinite;
    font-variation-settings: 'FILL' 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .btn:hover .icon-heart, a:hover .icon-heart, button:hover .icon-heart { animation: none; }
  }

</style>

<main id="main" class="flex-grow">

  <!-- ── ERREUR 404 ── -->
  <section class="bg-[#EFE7DA]">
    <div class="err-wrap">
      <div class="err-big icon-wackel" aria-hidden="true">404</div>
      <h1 class="text-2xl md:text-3xl font-black text-[#002626] mb-4">Oups… cette page a pris la poudre d'escampette.</h1>
      <p class="err-lead">
        La page que vous cherchez n'existe pas, a été déplacée ou renommée. Pas de panique, on vous remet sur le bon chemin en un clic.
      </p>
      <div class="err-ctas">
        <a href="/" class="btn btn-primary btn-lg">
          <span class="material-symbols-outlined" style="font-size:18px;">home</span>
          Retour à l'accueil
        </a>
        <a href="/contact" class="btn btn-outline btn-lg">
          <span class="material-symbols-outlined" style="font-size:18px;">mail</span>
          Nous contacter
        </a>
      </div>

      <div class="quick-grid">
        <a href="/srg" class="quick-card" style="--accent:#C04B72;">
          <div class="q-icon"><span class="material-symbols-outlined" style="font-size:22px;">home</span></div>
          <div class="q-title">SRG</div>
          <div class="q-desc">Service Résidentiel Général, hébergement et accompagnement des jeunes.</div>
          <span class="q-arrow">Découvrir <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span></span>
        </a>
        <a href="/apropos" class="quick-card" style="--accent:#002626;">
          <div class="q-icon"><span class="material-symbols-outlined" style="font-size:22px;">groups</span></div>
          <div class="q-title">À propos</div>
          <div class="q-desc">Notre histoire, notre équipe et nos valeurs.</div>
          <span class="q-arrow">En savoir plus <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span></span>
        </a>
        <a href="/emploi" class="quick-card" style="--accent:#E58346;">
          <div class="q-icon"><span class="material-symbols-outlined" style="font-size:22px;">work</span></div>
          <div class="q-title">Offres d'emploi</div>
          <div class="q-desc">Rejoignez une équipe engagée dans l'aide à la jeunesse.</div>
          <span class="q-arrow">Voir les postes <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span></span>
        </a>
        <a href="/don" class="quick-card" style="--accent:#119DA4;">
          <div class="q-icon"><span class="material-symbols-outlined icon-heart" style="font-size:22px;">favorite</span></div>
          <div class="q-title">Faire un don</div>
          <div class="q-desc">Soutenez nos projets, déductible fiscalement dès 40€.</div>
          <span class="q-arrow">Je soutiens <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span></span>
        </a>
      </div>
    </div>
  </section>

</main>

<Fragment slot="scripts">
<script>
(function() {
  'use strict';


  /* ── NAV SHRINK ── */
  var nav = document.querySelector('nav');
  if (nav) window.addEventListener('scroll', function(){ nav.classList.toggle('scrolled', window.scrollY > 40); }, { passive:true });

  /* ── NAV DROPDOWNS ── */
  document.querySelectorAll('.nav-item').forEach(function(item) {
    var t;
    item.addEventListener('mouseenter', function(){ if(t){clearTimeout(t);t=null;} document.querySelectorAll('.nav-item.dropdown-open').forEach(function(o){ if(o!==item) o.classList.remove('dropdown-open'); }); item.classList.add('dropdown-open'); });
    item.addEventListener('mouseleave', function(){ t=setTimeout(function(){ item.classList.remove('dropdown-open'); },120); });
  });
})();
</script>


</Fragment>

</BaseLayout>
