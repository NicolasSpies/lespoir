          <p class="text-[#002626]/65 text-sm leading-relaxed">Chez les gens, dans leur quartier, à leur rythme.</p>
        </div>
        <div class="bg-white/60 backdrop-blur-sm rounded-2xl p-5 md:p-6 border border-[#002626]/8" style="transition: transform 0.25s ease, box-shadow 0.25s ease;" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 10px 30px rgba(0,38,38,0.08)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div class="text-[#C04B72] font-black text-xs tracking-widest uppercase mb-3">Co-construction</div>
          <h3 class="font-bold text-[#002626] text-lg md:text-xl leading-snug mb-2">Décider ensemble.</h3>
          <p class="text-[#002626]/65 text-sm leading-relaxed">Les projets se construisent avec les familles, pas pour elles.</p>
        </div>
        <div class="bg-white/60 backdrop-blur-sm rounded-2xl p-5 md:p-6 border border-[#002626]/8" style="transition: transform 0.25s ease, box-shadow 0.25s ease;" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 10px 30px rgba(0,38,38,0.08)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div class="text-[#C04B72] font-black text-xs tracking-widest uppercase mb-3">Singularité</div>
          <h3 class="font-bold text-[#002626] text-lg md:text-xl leading-snug mb-2">Voir la personne.</h3>
          <p class="text-[#002626]/65 text-sm leading-relaxed">Derrière chaque dossier, une vraie histoire.</p>
        </div>
      </div>

      <div class="mt-12 md:mt-14">
        <a class="inline-flex items-center gap-2 font-bold text-[#002626] border-b-2 border-[#002626] pb-1 hover:text-[#C04B72] hover:border-[#C04B72] transition-colors" href="/apropos#valeurs">
          En savoir plus sur notre approche <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Wave: Partners → Don -->
  <div aria-hidden="true" style="background:#EFE7DA;line-height:0;display:block;margin-top:-1px;margin-bottom:-2px;position:relative;z-index:2;overflow:hidden;"><svg viewBox="0 0 1440 50" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block;width:100%;height:50px;overflow:visible;"><path d="M0 16 Q360 48 720 24 Q1080 4 1440 40 L1440 60 L0 60 Z" fill="#002626"/></svg></div>

  <!-- ── CTA: Soutien (V3 unified) ── -->
  <section id="don" class="bg-[#002626] py-16 md:py-24 px-6 md:px-8 overflow-hidden relative">
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full pointer-events-none" style="background:radial-gradient(circle, rgba(192,75,114,0.12) 0%, transparent 70%);"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <span class="text-[#C04B72] font-black tracking-widest text-sm uppercase block mb-5">Merci pour votre soutien</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-6 leading-tight">
        Ensemble, on continue.
      </h2>
      <p class="text-white/70 text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10">
        Chaque contribution, petite ou grande, ponctuelle ou régulière, nous permet d'aller un peu plus loin avec les jeunes qu'on accompagne. Merci, vraiment.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/don" class="btn btn-accent btn-lg">
          <span class="material-symbols-outlined icon-heart" style="font-size:20px;">favorite</span>
          Faire un don
        </a>
      </div>
    </div>
  </section>

</main>

<Fragment slot="scripts">
<script>
(function() {
  'use strict';

  /* ══════════════════════════════════════
     0-A. MOBILE DRAWER
     ══════════════════════════════════════ */

  (function() {
    var btn = document.getElementById('hamburgerBtn');
    var closeBtn = document.getElementById('drawerCloseBtn');
    var drawer = document.getElementById('mobileDrawer');
    var backdrop = document.getElementById('drawerBackdrop');
    if (!btn || !drawer || !backdrop) return;

    function open() {
      drawer.classList.add('is-open');
      backdrop.classList.add('is-open');
      btn.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.classList.add('drawer-open');
    }
    function close() {
      drawer.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      btn.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('drawer-open');
    }

    btn.addEventListener('click', function() {
      if (drawer.classList.contains('is-open')) close(); else open();
    });
    if (closeBtn) closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    // Close on plain nav link click (not accordion triggers)
    drawer.querySelectorAll('a.m-link, a.m-sublink, a.m-link-main, .m-drawer-footer .btn').forEach(function(el) {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) close();
    });
    window.addEventListener('resize', function() {
      if (window.innerWidth >= 1024 && drawer.classList.contains('is-open')) close();
    });

    /* ── Accordion ── */
    drawer.querySelectorAll('.m-accordion-trigger').forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        var accordion = trigger.closest('.m-accordion');
        var isOpen = accordion.classList.contains('is-open');
        // Close all accordions first
        drawer.querySelectorAll('.m-accordion.is-open').forEach(function(a) {
          a.classList.remove('is-open');
          a.querySelector('.m-accordion-trigger').setAttribute('aria-expanded', 'false');
        });
        // Toggle clicked one
        if (!isOpen) {
          accordion.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Prevent Services/À propos desktop link from closing drawer on click
    // (handled by a.m-link-main close already attached above)
  })();

  /* ══════════════════════════════════════
     0. NAV SHRINK ON SCROLL
     ══════════════════════════════════════ */

  var nav = document.querySelector('nav');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 40) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }, { passive: true });

  /* ══════════════════════════════════════
     0a. IMAGE BLUR-UP LOADING
     ══════════════════════════════════════ */

  (function() {
    var imgs = document.querySelectorAll('img.blur-up');
    imgs.forEach(function(img) {
      if (img.complete && img.naturalWidth > 0) {
        img.classList.add('is-loaded');
      } else {
        img.addEventListener('load', function() {
          img.classList.add('is-loaded');
        }, { once: true });
        img.addEventListener('error', function() {
          img.classList.add('is-loaded');
        }, { once: true });
      }
    });
  })();

  /* ══════════════════════════════════════
     0b. HERO ENTRANCE ANIMATION
     ══════════════════════════════════════ */

  var heroImg = document.querySelector('.hero-img-reveal');
  var heroEls = document.querySelectorAll('.hero-reveal');
  if (heroImg) {
    setTimeout(function() { heroImg.classList.add('revealed'); }, 100);
  }
  heroEls.forEach(function(el, i) {
    setTimeout(function() { el.classList.add('revealed'); }, 250 + i * 120);
  });

  /* ══════════════════════════════════════
     0c. HERO SLIDER (no dot navigation · auto-rotate · fade + Ken Burns)
     ══════════════════════════════════════ */

  (function() {
    var slider = document.querySelector('.hero-slider');
    if (!slider) return;
    var slides = slider.querySelectorAll('.hero-slide');
    if (slides.length < 2) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var current = 0;
    var interval = 6000;
    var timer;

    function go(idx) {
      var leaving = slides[current];
      // Freeze Ken Burns scale so leaving slide doesn't snap back during fade-out
      leaving.style.transform = window.getComputedStyle(leaving).transform;
      leaving.classList.remove('active');
      current = idx;
      slides[current].classList.add('active');
      // Clean frozen transform after fade completes
      (function(el) { setTimeout(function() { el.style.transform = ''; }, 1300); })(leaving);
    }

    function next() { go((current + 1) % slides.length); }

    function start() { if (!timer) timer = setInterval(next, interval); }
    function pause() { clearInterval(timer); timer = null; }

    // Pause on hover/focus (UX nicety + a11y)
    slider.addEventListener('mouseenter', pause);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', pause);
    slider.addEventListener('focusout', start);
    // Pause when tab not visible (battery-friendly)
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) pause(); else start();
    });

    start();
  })();

  /* ══════════════════════════════════════
     1. SCROLL-TRIGGERED ENTRANCE ANIMATIONS
     ══════════════════════════════════════ */

  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    var revealGroups = [];

    // Section titles (overline + h2 pairs inside sections)
    document.querySelectorAll('main section').forEach(function(section) {
      // Find title blocks: overline spans + h2 siblings
      var overlines = section.querySelectorAll(':scope > div > div > span[class*="tracking-widest"], :scope > div > span[class*="tracking-widest"]');
      overlines.forEach(function(overline) {
        var parent = overline.parentElement;
        var h2 = parent.querySelector('h2');
        if (h2) {
          revealGroups.push({ el: parent, delay: 0 });
        }
      });
    });

    // Service cards, stagger 0, 120, 240
    document.querySelectorAll('.service-card').forEach(function(card, i) {
      revealGroups.push({ el: card, delay: i * 120 });
    });

    // Stats cards, stagger 0, 80, 160, 240
    document.querySelectorAll('.stat-card').forEach(function(card, i) {
      revealGroups.push({ el: card, delay: i * 80 });
    });

    // About section text block
    var aboutSection = document.getElementById('about');
    if (aboutSection) {
      var aboutText = aboutSection.querySelector(':scope > div > div:first-child');
      if (aboutText) revealGroups.push({ el: aboutText, delay: 0 });
    }

    // Actualités cards, stagger 0, 100, 200, 300
    document.querySelectorAll('.actu-card').forEach(function(card, i) {
      revealGroups.push({ el: card, delay: i * 100 });
    });

    // Faire un don, text block + decorative cards
    var donSection = document.getElementById('don');
    if (donSection) {
      var donText = donSection.querySelector(':scope > div > div:first-child');
      var donCards = donSection.querySelector(':scope > div > div:last-child');
      if (donText) revealGroups.push({ el: donText, delay: 0 });
      if (donCards) revealGroups.push({ el: donCards, delay: 150 });
    }

    // Apply initial hidden state
    revealGroups.forEach(function(item) {
      item.el.classList.add('scroll-reveal');
    });

    // Intersection Observer
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var item = revealGroups.find(function(g) { return g.el === el; });
          var delay = item ? item.delay : 0;
          setTimeout(function() {
            el.classList.add('revealed');
          }, delay);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    revealGroups.forEach(function(item) {
      observer.observe(item.el);
    });

    // Safeguard: any reveal element still hidden after 1.5s gets revealed
    // (catches edge cases on tall viewports where observer doesn't fire)
    setTimeout(function() {
      revealGroups.forEach(function(item) {
        if (!item.el.classList.contains('revealed')) {
          item.el.classList.add('revealed');
          observer.unobserve(item.el);
        }
      });
    }, 1500);
  }

  /* ══════════════════════════════════════
     1b. STATS COUNT-UP
     ══════════════════════════════════════ */

  (function() {
    var nums = document.querySelectorAll('.stat-number[data-count]');
    if (!nums.length) return;

    function animate(el) {
      var target = parseInt(el.getAttribute('data-count'), 10);
      var start = parseInt(el.getAttribute('data-start') || '0', 10);
      var duration = 1400;
      var startTime = null;

      function ease(t) { return 1 - Math.pow(1 - t, 3); }

      function step(ts) {
        if (!startTime) startTime = ts;
        var p = Math.min((ts - startTime) / duration, 1);
        var val = Math.round(start + (target - start) * ease(p));
        el.textContent = val;
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = target;
      }
      requestAnimationFrame(step);
    }

    if (prefersReducedMotion) {
      nums.forEach(function(el) { el.textContent = el.getAttribute('data-count'); });
      return;
    }

    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          animate(entry.target);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    nums.forEach(function(el) { io.observe(el); });
  })();

  /* ══════════════════════════════════════
     2. NAVIGATION DROPDOWNS
     ══════════════════════════════════════ */

  document.querySelectorAll('.nav-item').forEach(function(item) {
    var closeTimer = null;

    // Dropdown item hover colors
    var dropdownLinks = item.querySelectorAll('.nav-dropdown a');
    dropdownLinks.forEach(function(link) {
      var color = link.getAttribute('data-hover-color');
      if (color) {
        link.addEventListener('mouseenter', function() {
          link.style.borderLeftColor = color;
        });
        link.addEventListener('mouseleave', function() {
          link.style.borderLeftColor = 'transparent';
        });
      }
    });

    item.addEventListener('mouseenter', function() {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      // Close other open dropdowns
      document.querySelectorAll('.nav-item.dropdown-open').forEach(function(other) {
        if (other !== item) other.classList.remove('dropdown-open');
      });
      item.classList.add('dropdown-open');
    });

    item.addEventListener('mouseleave', function() {
      closeTimer = setTimeout(function() {
        item.classList.remove('dropdown-open');
      }, 120);
    });

    // The dropdown trigger link now navigates on click, don't preventDefault
  });

  // ── Mobile: auto-activate hover state when element enters viewport center ──
  if (window.matchMedia('(hover: none)').matches && 'IntersectionObserver' in window) {
    var touchTargets = document.querySelectorAll('.service-card, .don-card, .stat-card, .actu-card, .partner-logo');
    var touchObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        entry.target.classList.toggle('is-active', entry.isIntersecting);
      });
    }, { threshold: [0.5], rootMargin: '-20% 0px -20% 0px' });
    touchTargets.forEach(function(el) { touchObs.observe(el); });
  }

})();
</script>


</Fragment>

