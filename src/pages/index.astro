---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import WaveDivider from '../components/WaveDivider.astro';
import DOMPurify from 'isomorphic-dompurify';
import { getHome, sectionData, str, asImage, asGallery, imageUrl, imageSrcSet, focusPosition, extractVisitorHeaders } from '../lib/cms';

const vis = extractVisitorHeaders(Astro.request);
const page = await getHome(vis);
const d = sectionData(page, 'startseite');
const heroSlides = asGallery(d.galerie);

const title = "L'Espoir asbl · Aide à la jeunesse à Huy depuis 1985";
const description = "Depuis 1985, L'Espoir asbl accompagne enfants et jeunes en difficulté dans la région de Huy et Amay via trois services agréés par la Fédération Wallonie-Bruxelles : SRG, SASE, SAPA.";
const keywords = "aide à la jeunesse Huy, asbl Amay, L'Espoir asbl, service résidentiel Wallonie, SRG SASE SAPA, éducateur spécialisé Liège, protection de l'enfance Belgique, parrainage familial, famille d'accueil Huy, accompagnement socio-éducatif";
const canonicalPath = "/";
const ogImage = "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?fm=webp&w=1200&q=80&auto=format&fit=crop";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const preloadTags = "<link rel=\"preload\" as=\"image\" type=\"image/webp\" fetchpriority=\"high\" imagesrcset=\"1-xs.webp 480w, 1-sm.webp 768w, 1-md.webp 1024w, 1.webp 1080w\" imagesizes=\"(max-width: 1023px) 100vw, 50vw\"/>";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"foundingLocation\":{\"@type\":\"Place\",\"name\":\"Antheit, Belgique\"},\"award\":\"Agrément Fédération Wallonie-Bruxelles, secteur Aide à la Jeunesse\",\"slogan\":\"Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[\"https://www.aidealajeunesse.cfwb.be/ajss-pro/contacts-coordonneesnbspde-ladministration-etdes-services/services-agreesnbspde-laide-a-la-jeunesse/\"],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/#webpage\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl · Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Depuis 1985, L'Espoir asbl accompagne enfants et jeunes en difficulté dans la région de Huy et Amay via trois services agréés par la Fédération Wallonie-Bruxelles : SRG, SASE, SAPA.\",\"inLanguage\":\"fr-BE\",\"dateModified\":\"2026-05-12\",\"datePublished\":\"2024-01-15\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
];
const activeNav = "home";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
  trackEntryId={page?.id ?? page?.entry_id ?? null}
>

<style is:global>

  /* Actualités card arrows */
  .actu-arrow { transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1); }
  .actu-card:hover .actu-arrow { transform: translateX(4px); }

  /* ── Don cards hover ── */
  .don-card {
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
  }
  .don-card:hover {
    transform: rotate(0deg) translateY(-6px) scale(1.04);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }
  .btn-link::after {
    content: ''; position: absolute;
    left: 0; right: 1.5rem; bottom: 0;
    height: 2px; background: currentColor;
    transform: scaleX(1); transform-origin: left;
    transition: transform 0.3s ease;
  }
  .btn-link:hover::after {
    transform: scaleX(0.9);
  }
  .btn-link .arrow {
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .btn-link:hover .arrow {
    transform: translateX(6px);
  }

  /* ── Image blur-up loading ── */
  .blur-up {
    filter: blur(14px);
    transform: scale(1.03);
    transition: filter 0.6s ease, transform 0.6s ease, opacity 0.6s ease;
    will-change: filter;
  }
  .blur-up.is-loaded {
    filter: blur(0);
    transform: scale(1);
  }

  /* ── Actualités mobile heights ── */
  @media (max-width: 767px) {
    .actu-card {
      min-height: 380px;
    }
    /* Text-only offre d'emploi card sizes to its own content */
    .actu-card.bg-\[\#002626\] {
      min-height: auto;
    }
  }

  /* ── Partners section ── */
  .partner-logo {
    display: flex; align-items: center; justify-content: center;
    height: 80px;
    padding: 12px 24px;
    border-radius: 12px;
    background: #fff;
    border: 1px solid rgba(0, 38, 38, 0.08);
    color: #002626;
    font-weight: 600; font-size: 14px;
    text-align: center;
    opacity: 0.55;
    filter: grayscale(100%);
    transition: opacity 0.3s ease, filter 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .partner-logo:hover {
    opacity: 1;
    filter: grayscale(0%);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 38, 38, 0.08);
  }

  /* ── Quote section polish ── */
  .quote-section { position: relative; overflow: hidden; }
  .quote-mark {
    font-family: Georgia, serif;
    font-size: 9rem;
    color: #E58346;
    line-height: 0.8;
    opacity: 0.85;
    display: inline-block;
    animation: quoteFloat 6s ease-in-out infinite;
  }
  @media (max-width: 640px) {
    .quote-mark { font-size: 5.5rem; }
  }
  @keyframes quoteFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .quote-mark { animation: none; }
  }
  .quote-deco-line {
    display: inline-block; vertical-align: middle;
    width: 40px; height: 1px;
    background: #002626; opacity: 0.25;
  }
  @media (max-width: 480px) {
    .quote-deco-line { width: 20px; }
  }
  .quote-deco-dot {
    display: inline-block; vertical-align: middle;
    width: 4px; height: 4px; border-radius: 50%;
    background: #E58346; margin: 0 10px;
  }

  /* ── Stats cards hover ── */
  .stat-card {
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
    cursor: default;
  }
  .stat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(0, 38, 38, 0.10);
  }
  .stat-card .stat-number {
    display: inline-block;
    font-variant-numeric: tabular-nums;
  }

  /* ── Service cards hover polish ── */
  .service-card {
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
    cursor: pointer; text-decoration: none; display: flex;
  }
  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 38, 38, 0.18);
  }
  .service-card .service-icon {
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1), background-color 0.3s ease;
  }
  .service-card:hover .service-icon {
    transform: rotate(-6deg) scale(1.08);
    background-color: rgba(255,255,255,0.28);
  }
  .service-card .service-cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    position: relative;
  }
  .service-card .service-cta .arrow {
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .service-card:hover .service-cta .arrow {
    transform: translateX(6px);
  }
  .service-card .service-cta::after {
    content: ''; position: absolute; left: 0; right: 1.5rem; bottom: -2px;
    height: 2px; background: currentColor; opacity: 0;
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.35s ease, opacity 0.3s ease;
  }
  .service-card:hover .service-cta::after {
    opacity: 0.9; transform: scaleX(1);
  }

  /* ── Hero entrance animation ── */
  .hero-reveal {
    opacity: 0;
    transform: translateY(24px);
    will-change: transform, opacity;
  }
  .hero-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .hero-img-reveal {
    opacity: 0;
    will-change: opacity;
  }
  .hero-img-reveal.revealed {
    opacity: 1;
    transition: opacity 0.9s ease-out;
  }

  /* ── Hero image panel: organic rounded edges ── */
  /* Desktop: round the right side so the image blends into the cream content panel */
  @media (min-width: 1024px) {
    .hero-img-reveal {
      border-radius: 0 2.5rem 2.5rem 0;
    }
  }
  /* Mobile/tablet: round the bottom so the image blends into the content below */
  @media (max-width: 1023px) {
    .hero-img-reveal {
      border-radius: 0 0 2.5rem 2.5rem;
    }
  }

  /* ── Hero sizing ── */
  #hero {
    min-height: 0;
  }
  /* Desktop (≥1024px): image stretches to match content height */
  @media (min-width: 1024px) {
    #hero {
      height: auto;
      flex-direction: row;
    }
    #hero > .hero-img-reveal {
      flex: 0 0 42%;
      padding: 2rem 0 2rem 2rem;
      display: flex;
      align-items: stretch;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .hero-img-frame {
      position: relative;
      width: 100%;
    }
    .hero-img-card {
      width: 100%; height: 100%;
      border-radius: 1.75rem;
      overflow: hidden;
      position: relative;
      z-index: 2;
    }
    .hero-img-deco {
      position: absolute;
      width: 14rem; height: 14rem;
      bottom: -1.5rem; right: -1.5rem;
      background: rgba(192,75,114,0.22);
      border-radius: 60% 40% 70% 30% / 55% 60% 40% 45%;
      z-index: 1;
      pointer-events: none;
    }
    .hero-img-deco-2 {
      position: absolute;
      width: 7rem; height: 7rem;
      top: -1rem; left: -1rem;
      background: rgba(229,131,70,0.20);
      border-radius: 50% 50% 60% 40% / 60% 40% 60% 40%;
      z-index: 1;
      pointer-events: none;
    }
  }
  @media (max-height: 760px) and (min-width: 1024px) {
    #hero { height: auto; }
  }
  /* Mobile + Tablet (<1024px): stacked, landscape rounded image */
  @media (max-width: 1023px) {
    #hero { min-height: 0; height: auto; flex-direction: column; }
    #hero > .hero-img-reveal {
      width: 100%;
      padding: 1rem 1rem 0 1rem;
      position: relative;
    }
    .hero-img-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 10;
    }
    .hero-img-card {
      width: 100%; height: 100%;
      border-radius: 1.25rem;
      overflow: hidden;
      box-shadow: 0 16px 40px -16px rgba(0,38,38,0.25);
    }
    .hero-img-deco, .hero-img-deco-2 { display: none; }
  }

  /* ── Hero slider ── */
  .hero-slider {
    position: relative; width: 100%; height: 100%; overflow: hidden;
  }
  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
    pointer-events: none;
  }
  .hero-slide.active {
    opacity: 1;
    animation: heroKenBurns 8s ease-out forwards;
  }
  .hero-slide picture {
    display: block; width: 100%; height: 100%;
  }
  .hero-img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  @keyframes heroKenBurns {
    from { transform: scale(1); }
    to   { transform: scale(1.08); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-slide { transition: none; }
    .hero-slide.active { animation: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal, .hero-reveal, .hero-img-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      will-change: auto;
    }
  }
  /* ── Organic blob decorations ── */
  .blob {
    position: absolute;
    border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%;
    pointer-events: none;
    z-index: 0;
  }
  /* Ensure content inside blob-parent sections stays above blobs */
  .blob-parent > :not(.blob) { position: relative; z-index: 1; }

  /* ── Stat card rotations (subtle handmade feel) ── */
  /* Base rotations: each card slightly off-axis */
  #about .grid .stat-card:nth-child(1) { transform: rotate(-1.2deg); }
  #about .grid .stat-card:nth-child(2) { transform: rotate(0.7deg); }
  #about .grid .stat-card:nth-child(3) { transform: rotate(-0.5deg); }
  #about .grid .stat-card:nth-child(4) { transform: rotate(1deg); }

  /* Hover: lift + preserve rotation (specificity beats .scroll-reveal.revealed) */
  #about .grid .stat-card:nth-child(1):hover,
  #about .grid .stat-card:nth-child(1).revealed:hover { transform: rotate(-1.2deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }
  #about .grid .stat-card:nth-child(2):hover,
  #about .grid .stat-card:nth-child(2).revealed:hover { transform: rotate(0.7deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }
  #about .grid .stat-card:nth-child(3):hover,
  #about .grid .stat-card:nth-child(3).revealed:hover { transform: rotate(-0.5deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }
  #about .grid .stat-card:nth-child(4):hover,
  #about .grid .stat-card:nth-child(4).revealed:hover { transform: rotate(1deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }

  /* ── Scroll-reveal hover fix: specificity (0,3,0) beats .scroll-reveal.revealed (0,2,0) ── */
  .stat-card.revealed:hover { transform: translateY(-6px); }
  .service-card.revealed:hover { transform: translateY(-10px); }
  .don-card.revealed:hover { transform: rotate(0deg) translateY(-6px) scale(1.04); }

  /* ── Mobile: auto-activate hover state when element is centered in viewport ── */
  @media (hover: none) {
    .don-card.is-active {
      transform: rotate(0deg) translateY(-6px) scale(1.04);
      box-shadow: 0 12px 32px rgba(0,0,0,0.18);
    }
    .don-card.revealed.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); }
    .actu-card.is-active .actu-arrow { transform: translateX(4px); }
    .partner-logo.is-active {
      opacity: 1;
      filter: grayscale(0%);
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(0, 38, 38, 0.08);
    }
    .stat-card.is-active {
      transform: translateY(-6px);
      box-shadow: 0 14px 30px rgba(0, 38, 38, 0.10);
    }
    .stat-card.revealed.is-active { transform: translateY(-6px); }
    #about .grid .stat-card:nth-child(1).is-active,
    #about .grid .stat-card:nth-child(1).revealed.is-active { transform: rotate(-1.2deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }
    #about .grid .stat-card:nth-child(2).is-active,
    #about .grid .stat-card:nth-child(2).revealed.is-active { transform: rotate(0.7deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }
    #about .grid .stat-card:nth-child(3).is-active,
    #about .grid .stat-card:nth-child(3).revealed.is-active { transform: rotate(-0.5deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }
    #about .grid .stat-card:nth-child(4).is-active,
    #about .grid .stat-card:nth-child(4).revealed.is-active { transform: rotate(1deg) translateY(-6px); box-shadow: 0 14px 30px rgba(0,38,38,0.10); }
    .service-card.is-active {
      transform: translateY(-10px);
      box-shadow: 0 20px 40px rgba(0, 38, 38, 0.18);
    }
    .service-card.revealed.is-active { transform: translateY(-10px); }
    .service-card.is-active .service-icon {
      transform: rotate(-6deg) scale(1.08);
      background-color: rgba(255,255,255,0.28);
    }
    .service-card.is-active .service-cta .arrow { transform: translateX(6px); }
    .service-card.is-active .service-cta::after { opacity: 0.9; transform: scaleX(1); }
  }

  /* ── Tilt image wrapper (rotated photo with hover straighten) ── */
  .tilt-img { transform: rotate(-1.5deg); transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), box-shadow 0.5s ease; }
  .tilt-img:hover { transform: rotate(0deg) translateY(-4px); }
  .tilt-img.tilt-right { transform: rotate(1.5deg); }
  .tilt-img.tilt-right:hover { transform: rotate(0deg) translateY(-4px); }

</style>

<main id="main" class="flex-grow">

  <!-- ── HERO (V2 Split) ── -->
  <section id="hero" class="relative bg-[#EFE7DA] flex flex-col lg:flex-row">
    <!-- Floating square image card with decorative blobs (desktop), landscape on mobile -->
    <div class="hero-img-reveal relative">
      <div class="hero-img-frame">
        <div class="hero-img-deco" aria-hidden="true"></div>
        <div class="hero-img-deco-2" aria-hidden="true"></div>
        <div class="hero-img-card">
          <div class="hero-slider" role="region" aria-roledescription="carousel" aria-label="Galerie L'Espoir asbl">
            {heroSlides.length > 0 ? heroSlides.map((img, i) => (
              <div class={i === 0 ? 'hero-slide active' : 'hero-slide'}>
                <img class="hero-img" src={imageUrl(img, 'lg')} srcset={imageSrcSet(img)} sizes="(max-width:1024px) 100vw, 42vw" alt={img.alt ?? ''} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" style={`width:100%;height:100%;object-fit:cover;object-position:${focusPosition(img.focus_x, img.focus_y)};`} />
              </div>
            )) : (<Fragment>
            <div class="hero-slide active">
              <Placeholder alt="L'Espoir asbl, aide à la jeunesse à Huy et Amay depuis 1985" aspectRatio='16/9' />
            </div>
            <div class="hero-slide">
              <Placeholder alt="SRG L'Espoir asbl, hébergement résidentiel pour enfants à Amay et Couthuin" aspectRatio='16/9' />
            </div>
            <div class="hero-slide">
              <Placeholder alt="SASE L'Espoir asbl, accompagnement socio-éducatif à domicile dans la région de Huy" aspectRatio='16/9' />
            </div>
            <div class="hero-slide">
              <Placeholder alt="SAPA L'Espoir asbl, parrainage familial à Huy, Waremme et Hannut" aspectRatio='16/9' />
            </div>
            </Fragment>)}
          </div>
        </div>
      </div>
    </div>
    <!-- Text: 2/3 on desktop -->
    <div class="blob-parent bg-[#EFE7DA] flex flex-col justify-center flex-1 px-6 sm:px-10 md:px-10 lg:px-14 py-12 md:py-20">
      <div class="blob" data-parallax="-0.12" aria-hidden="true" style="width:320px;height:320px;background:rgba(192,75,114,0.09);top:20px;right:-80px;border-radius:60% 40% 70% 30% / 50% 60% 40% 50%;"></div>
      <div class="blob" data-parallax="0.18" aria-hidden="true" style="width:200px;height:200px;background:rgba(229,131,70,0.07);bottom:30px;left:-40px;border-radius:30% 70% 40% 60% / 60% 30% 70% 40%;"></div>
      <span class="hero-reveal text-[#C04B72] font-bold tracking-widest text-sm uppercase mb-6">Bienvenue à L'Espoir</span>
      <h1 class="hero-reveal text-4xl sm:text-5xl md:text-5xl lg:text-6xl font-extrabold text-[#002626] leading-[1.1] tracking-tight mb-6 md:mb-8">
        {str(d.titre_page_accueil)
          ? <Fragment set:html={DOMPurify.sanitize(String(d.titre_page_accueil))} />
          : (<Fragment>Parce que chaque enfant mérite un endroit pour grandir en <span style="position:relative;display:inline-block;">sécurité<svg class="curly-svg" viewBox="0 0 100 10" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg" style="position:absolute;bottom:-3px;left:0;width:100%;height:10px;" aria-hidden="true"><path d="M1 7 Q25 2 50 7 Q75 12 99 5" stroke="#C04B72" stroke-width="2.5" stroke-linecap="round"/></svg></span></Fragment>)}
      </h1>
      <p class="hero-reveal text-base md:text-lg lg:text-xl text-[#002626] opacity-80 leading-relaxed mb-8 md:mb-12 max-w-lg">
        {str(d.description_page_accueil) ?? `L'Espoir asbl accompagne des enfants et des jeunes en difficulté dans la région de Huy, à travers trois services agréés depuis 1985.`}
      </p>
      <div class="hero-reveal flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4">
        <a href="#services" class="btn btn-primary btn-lg w-full sm:w-auto">Nos Services</a>
