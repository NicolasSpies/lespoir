---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "L'Espoir asbl · Aide à la jeunesse à Huy depuis 1985";
const description = "Depuis 1985, L'Espoir asbl accompagne enfants et jeunes en difficulté dans la région de Huy et Amay via trois services agréés par la Fédération Wallonie-Bruxelles : SRG, SASE, SAPA.";
const keywords = "aide à la jeunesse Huy, asbl Amay, L'Espoir asbl, service résidentiel Wallonie, SRG SASE SAPA, éducateur spécialisé Liège, protection de l'enfance Belgique, parrainage familial, famille d'accueil Huy, accompagnement socio-éducatif";
const canonicalPath = "/";
const ogImage = "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?fm=webp&w=1200&q=80&auto=format&fit=crop";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const preloadTags = "<link rel=\"preload\" as=\"image\" type=\"image/webp\" fetchpriority=\"high\" imagesrcset=\"1-xs.webp 480w, 1-sm.webp 768w, 1-md.webp 1024w, 1.webp 1080w\" imagesizes=\"(max-width: 1023px) 100vw, 50vw\"/>";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"foundingLocation\":{\"@type\":\"Place\",\"name\":\"Antheit, Belgique\"},\"award\":\"Agrément Fédération Wallonie-Bruxelles, secteur Aide à la Jeunesse\",\"slogan\":\"Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[\"https://www.aidealajeunesse.cfwb.be/ajss-pro/contacts-coordonneesnbspde-ladministration-etdes-services/services-agreesnbspde-laide-a-la-jeunesse/\"],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/#webpage\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl · Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Depuis 1985, L'Espoir asbl accompagne enfants et jeunes en difficulté dans la région de Huy et Amay via trois services agréés par la Fédération Wallonie-Bruxelles : SRG, SASE, SAPA.\",\"inLanguage\":\"fr-BE\",\"dateModified\":\"2026-05-12\",\"datePublished\":\"2024-01-15\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
];
const activeNav = "home";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  preloadTags={preloadTags}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
>

<style is:global>
/* ── Base ── */
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
  body { font-family: 'Inter', sans-serif; background-color: #fbf9f8; }

  /* ── Material Symbols ── */
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    display: inline-block; line-height: 1;
    transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Focus states ── */
  *:focus { outline: none; }
  *:focus-visible { outline: 2px solid #C04B72; outline-offset: 3px; border-radius: 4px; }
  button:focus-visible, a:focus-visible { outline: 2px solid #C04B72; outline-offset: 3px; }

  /* ── Design Tokens ── */
  :root {
    --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Arrow animations ── */
  /* Horizontal arrows, slide right on parent hover */
  a:hover > .material-symbols-outlined,
  a:hover > span > .material-symbols-outlined {
    transform: translateX(4px);
  }

  /* Actualités card arrows */
  .actu-arrow { transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1); }
  .actu-card:hover .actu-arrow { transform: translateX(4px); }

  /* ── Text links ── */
  nav a, footer a { transition: var(--transition); }
  nav a:hover, footer a:hover { opacity: 1 !important; }

  /* ── Don cards hover ── */
  .don-card {
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
  }
  .don-card:hover {
    transform: rotate(0deg) translateY(-6px) scale(1.04);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }

  /* ── Navbar link animated underline ── */
  .nav-link {
    position: relative;
    padding-bottom: 6px;
    color: #002626;
    transition: color 0.2s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 2px;
    background: #002626;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .nav-link:hover::after,
  .nav-link.is-active::after {
    transform: scaleX(1);
  }
  .nav-link.is-active { font-weight: 700; }

  /* ── Button system ── */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 999px;
    font-weight: 700; font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    border: 0;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, color 0.25s ease, filter 0.25s ease;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }
  .btn-lg { padding: 1.1rem 2.2rem; font-size: 1.05rem; }
  .btn-sm { padding: 0.75rem 1.3rem; font-size: 0.85rem; min-height: 44px; }

  .btn-primary {
    background: #002626;
    color: #EFE7DA;
  }
  .btn-primary:hover {
    box-shadow: 0 10px 24px rgba(0, 38, 38, 0.25);
    filter: brightness(1.08);
  }

  .btn-accent {
    background: #C04B72;
    color: #fff;
  }
  .btn-accent:hover {
    box-shadow: 0 10px 24px rgba(192, 75, 114, 0.35);
    filter: brightness(1.05);
  }
  /* Heart fills up smoothly on hover (position stable) */
  .btn-accent .material-symbols-outlined {
    font-variation-settings: 'FILL' 0;
    transition: font-variation-settings 0.35s ease, transform 0.35s ease;
  }
  .btn-accent:hover .material-symbols-outlined {
    font-variation-settings: 'FILL' 1;
    transform: scale(1.08);
  }

  .btn-outline {
    background: transparent;
    color: #002626;
    box-shadow: inset 0 0 0 2px #002626;
  }
  .btn-outline:hover {
    background: #002626;
    color: #EFE7DA;
  }

  .btn-outline-light {
    background: transparent;
    color: #fff;
    box-shadow: inset 0 0 0 2px rgba(255,255,255,0.5);
  }
  .btn-outline-light:hover {
    background: #fff;
    color: #002626;
    box-shadow: inset 0 0 0 2px #fff;
  }

  .btn-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    position: relative; padding-bottom: 4px;
    font-weight: 700;
    color: inherit;
    text-decoration: none;
  }
  .btn-link::after {
    content: ''; position: absolute;
    left: 0; right: 1.5rem; bottom: 0;
    height: 2px; background: currentColor;
    transform: scaleX(1); transform-origin: left;
    transition: transform 0.3s ease;
  }
  .btn-link:hover::after {
    transform: scaleX(0.9);
  }
  .btn-link .arrow {
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .btn-link:hover .arrow {
    transform: translateX(6px);
  }

  /* ── Image blur-up loading ── */
  .blur-up {
    filter: blur(14px);
    transform: scale(1.03);
    transition: filter 0.6s ease, transform 0.6s ease, opacity 0.6s ease;
    will-change: filter;
  }
  .blur-up.is-loaded {
    filter: blur(0);
    transform: scale(1);
  }

  /* ── Actualités mobile heights ── */
  @media (max-width: 767px) {
    .actu-card {
      min-height: 380px;
    }
    /* Text-only offre d'emploi card sizes to its own content */
    .actu-card.bg-\[\#002626\] {
      min-height: auto;
    }
  }

  /* ── Partners section ── */
  .partner-logo {
    display: flex; align-items: center; justify-content: center;
    height: 80px;
    padding: 12px 24px;
    border-radius: 12px;
    background: #fff;
    border: 1px solid rgba(0, 38, 38, 0.08);
    color: #002626;
    font-weight: 600; font-size: 14px;
    text-align: center;
    opacity: 0.55;
    filter: grayscale(100%);
    transition: opacity 0.3s ease, filter 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .partner-logo:hover {
    opacity: 1;
    filter: grayscale(0%);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 38, 38, 0.08);
  }

  /* ── Quote section polish ── */
  .quote-section { position: relative; overflow: hidden; }
  .quote-mark {
    font-family: Georgia, serif;
    font-size: 9rem;
    color: #E58346;
    line-height: 0.8;
    opacity: 0.85;
    display: inline-block;
    animation: quoteFloat 6s ease-in-out infinite;
  }
  @media (max-width: 640px) {
    .quote-mark { font-size: 5.5rem; }
  }
  @keyframes quoteFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .quote-mark { animation: none; }
  }
  .quote-deco-line {
    display: inline-block; vertical-align: middle;
    width: 40px; height: 1px;
    background: #002626; opacity: 0.25;
  }
  @media (max-width: 480px) {
    .quote-deco-line { width: 20px; }
  }
  .quote-deco-dot {
    display: inline-block; vertical-align: middle;
    width: 4px; height: 4px; border-radius: 50%;
    background: #E58346; margin: 0 10px;
  }

  /* ── Stats cards hover ── */
  .stat-card {
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
    cursor: default;
  }
  .stat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(0, 38, 38, 0.10);
  }
  .stat-card .stat-number {
    display: inline-block;
    font-variant-numeric: tabular-nums;
  }

  /* ── Service cards hover polish ── */
  .service-card {
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
    cursor: pointer; text-decoration: none; display: flex;
  }
  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 38, 38, 0.18);
  }
  .service-card .service-icon {
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1), background-color 0.3s ease;
  }
  .service-card:hover .service-icon {
    transform: rotate(-6deg) scale(1.08);
    background-color: rgba(255,255,255,0.28);
  }
  .service-card .service-cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    position: relative;
  }
  .service-card .service-cta .arrow {
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .service-card:hover .service-cta .arrow {
    transform: translateX(6px);
  }
  .service-card .service-cta::after {
    content: ''; position: absolute; left: 0; right: 1.5rem; bottom: -2px;
    height: 2px; background: currentColor; opacity: 0;
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.35s ease, opacity 0.3s ease;
  }
  .service-card:hover .service-cta::after {
    opacity: 0.9; transform: scaleX(1);
  }

  /* ── Hero entrance animation ── */
  .hero-reveal {
    opacity: 0;
    transform: translateY(24px);
    will-change: transform, opacity;
  }
  .hero-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .hero-img-reveal {
    opacity: 0;
    will-change: opacity;
  }
  .hero-img-reveal.revealed {
    opacity: 1;
    transition: opacity 0.9s ease-out;
  }

  /* ── Hero image panel: organic rounded edges ── */
  /* Desktop: round the right side so the image blends into the cream content panel */
  @media (min-width: 1024px) {
    .hero-img-reveal {
      border-radius: 0 2.5rem 2.5rem 0;
    }
  }
  /* Mobile/tablet: round the bottom so the image blends into the content below */
  @media (max-width: 1023px) {
    .hero-img-reveal {
      border-radius: 0 0 2.5rem 2.5rem;
    }
  }

  /* ── Hero sizing ── */
  #hero {
    min-height: 0;
  }
  /* Desktop (≥1024px): image stretches to match content height */
  @media (min-width: 1024px) {
    #hero {
      height: auto;
      flex-direction: row;
    }
    #hero > .hero-img-reveal {
      flex: 0 0 42%;
      padding: 2rem 0 2rem 2rem;
      display: flex;
      align-items: stretch;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .hero-img-frame {
      position: relative;
      width: 100%;
    }
    .hero-img-card {
      width: 100%; height: 100%;
      border-radius: 1.75rem;
      overflow: hidden;
      position: relative;
      z-index: 2;
    }
    .hero-img-deco {
      position: absolute;
      width: 14rem; height: 14rem;
      bottom: -1.5rem; right: -1.5rem;
      background: rgba(192,75,114,0.22);
      border-radius: 60% 40% 70% 30% / 55% 60% 40% 45%;
      z-index: 1;
      pointer-events: none;
    }
    .hero-img-deco-2 {
      position: absolute;
      width: 7rem; height: 7rem;
      top: -1rem; left: -1rem;
      background: rgba(229,131,70,0.20);
      border-radius: 50% 50% 60% 40% / 60% 40% 60% 40%;
      z-index: 1;
      pointer-events: none;
    }
  }
  @media (max-height: 760px) and (min-width: 1024px) {
    #hero { height: auto; }
  }
  /* Mobile + Tablet (<1024px): stacked, landscape rounded image */
  @media (max-width: 1023px) {
    #hero { min-height: 0; height: auto; flex-direction: column; }
    #hero > .hero-img-reveal {
      width: 100%;
      padding: 1rem 1rem 0 1rem;
      position: relative;
    }
    .hero-img-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 10;
    }
    .hero-img-card {
      width: 100%; height: 100%;
      border-radius: 1.25rem;
      overflow: hidden;
      box-shadow: 0 16px 40px -16px rgba(0,38,38,0.25);
    }
    .hero-img-deco, .hero-img-deco-2 { display: none; }
  }

  /* ── Hero slider ── */
  .hero-slider {
    position: relative; width: 100%; height: 100%; overflow: hidden;
  }
  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
    pointer-events: none;
  }
  .hero-slide.active {
    opacity: 1;
    animation: heroKenBurns 8s ease-out forwards;
  }
  .hero-slide picture {
    display: block; width: 100%; height: 100%;
  }
  .hero-img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  @keyframes heroKenBurns {
    from { transform: scale(1); }
    to   { transform: scale(1.08); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-slide { transition: none; }
    .hero-slide.active { animation: none; }
  }

  /* ── Scroll animations ── */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(28px);
    will-change: transform, opacity;
  }
  .scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.55s ease-out, transform 0.4s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal, .hero-reveal, .hero-img-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      will-change: auto;
    }
  }

  /* ── Nav shrink on scroll ── */
  nav > div { transition: padding 0.3s ease; }
  .nav-logo { width: auto; transition: height 0.3s ease; }
  nav.scrolled > div { padding-top: 0.75rem; padding-bottom: 0.75rem; }
  nav.scrolled .nav-logo { height: 2.25rem; }

  /* ── Mobile hamburger & drawer ── */
  .hamburger {
    width: 44px; height: 44px;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    gap: 5px; padding: 0; margin: 0;
    background: transparent; border: 0; cursor: pointer;
    color: #002626; flex-shrink: 0;
  }
  .hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.28s ease, opacity 0.22s ease;
    transform-origin: center;
  }
  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-drawer {
    position: fixed;
    top: 0; right: 0;
    width: min(88vw, 360px);
    height: 100vh; height: 100dvh;
    background: #EFE7DA;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 60;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .mobile-drawer.is-open { transform: translateX(0); }

  .mobile-drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 38, 38, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    z-index: 55;
    backdrop-filter: blur(2px);
  }
  .mobile-drawer-backdrop.is-open { opacity: 1; pointer-events: auto; }

  /* Drawer header */
  .m-drawer-header {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(0, 38, 38, 0.08);
    flex-shrink: 0;
  }
  .m-close-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0, 38, 38, 0.07);
    border: 0; cursor: pointer; color: #002626;
    transition: background 0.2s ease;
  }
  .m-close-btn:hover { background: rgba(0, 38, 38, 0.14); }

  /* Drawer nav area */
  .m-nav {
    flex: 1;
    padding: 0 0 0.5rem;
    overflow-y: auto;
  }

  /* All main links, equal weight */
  .m-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.9rem 1.25rem;
    color: #002626;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    cursor: pointer;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(0, 38, 38, 0.07);
    width: 100%; text-align: left;
    font-family: inherit;
    transition: background 0.18s ease;
  }
  .m-link:hover { background: rgba(0, 38, 38, 0.04); }
  .m-link.is-active { font-weight: 700; color: #002626; }

  /* Accordion trigger chevron */
  .m-chevron {
    font-size: 20px;
    opacity: 0.45;
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }
  .m-accordion.is-open .m-chevron { transform: rotate(180deg); opacity: 0.7; }

  /* Accordion body */
  .m-accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(0, 38, 38, 0.025);
  }
  .m-accordion.is-open .m-accordion-body { max-height: 480px; }

  /* Sub-links inside accordions */
  .m-sublink {
    display: flex; flex-direction: column;
    padding: 0.65rem 1.25rem 0.65rem 1.75rem;
    border-bottom: 1px solid rgba(0, 38, 38, 0.05);
    text-decoration: none;
    transition: background 0.18s ease;
  }
  .m-sublink:hover { background: rgba(0, 38, 38, 0.04); }
  .m-sublink .abbr { font-weight: 700; font-size: 0.9rem; color: #002626; }
  .m-sublink .name { font-size: 0.73rem; color: rgba(0, 38, 38, 0.55); margin-top: 1px; }

  /* Drawer footer */
  .m-drawer-footer {
    padding: 1.25rem;
    border-top: 1px solid rgba(0, 38, 38, 0.08);
    flex-shrink: 0;
  }
