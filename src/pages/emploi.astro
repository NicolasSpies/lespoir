  <!-- ── CANDIDATURE SPONTANÉE ── -->
  <section id="candidature" class="py-16 md:py-24 px-6 md:px-8 bg-[#EFE7DA] blob-parent">
    <div class="blob" aria-hidden="true" style="width:260px;height:260px;background:rgba(192,75,114,0.08);bottom:40px;right:-80px;border-radius:65% 35% 55% 45% / 50% 50% 50% 50%;"></div>
    <div class="max-w-6xl mx-auto">

      <div class="flex items-center gap-3 mb-6 candid-header">
        <div class="w-1 h-6 bg-[#C04B72] rounded-full"></div>
        <span class="text-[#002626]/50 font-black tracking-widest text-xs uppercase">Votre candidature</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-black text-[#002626] leading-tight mb-3 candid-header">
        Rejoignez <span style="position:relative;display:inline-block;">L'Espoir<svg class="curly-svg" viewBox="0 0 100 10" preserveAspectRatio="none" fill="none" style="position:absolute;bottom:-3px;left:0;width:100%;height:10px;" aria-hidden="true"><path d="M1 7 Q25 2 50 7 Q75 12 99 5" stroke="#C04B72" stroke-width="2.5" stroke-linecap="round"/></svg></span> asbl
      </h2>
      <p class="text-[#002626]/65 leading-relaxed max-w-2xl mb-12 candid-header" id="candidatureLead">
        Remplissez le formulaire ci-dessous pour déposer votre candidature, spontanée ou pour une offre précise. La direction vous recontacte sous 10 à 15 jours ouvrables.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-14 items-start">

        <!-- FORM (3/5) -->
        <div class="lg:col-span-3 candid-form" id="formWrapper">

          {jobForm ? (
          <form id="postulerForm" class="space-y-5" novalidate>

            <p class="text-[#002626]/55 text-sm leading-relaxed">
              Les champs marqués d'un <span class="text-[#E58346] font-bold">*</span> sont obligatoires.
            </p>

            {/* Poste visé — a CC `text` field, but rendered as a dropdown that
               adapts to the live job offers; the picked title is submitted as text.
               Prefilled by the Postuler buttons / ?poste=. */}
            {posteField && (
              <div>
                <label class="block text-xs font-bold text-[#002626]/80 uppercase tracking-widest mb-2" for="poste_vise">Poste visé{posteField.required && <span class="text-[#E58346]"> *</span>}</label>
                <select id="poste_vise" name="poste_vise" required={posteField.required} class="form-field">
                  <option value="" disabled selected>Sélectionnez un poste</option>
                  {offres.map((o) => (<option value={o.title}>{o.title}</option>))}
                  <option value="Candidature spontanée">Candidature spontanée</option>
                </select>
              </div>
            )}

            {/* Prénom + Nom, Email + Téléphone — 2-col grid */}
            {pairFields.length > 0 && (
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {pairFields.map((f) => (
                  <div>
                    <label class="block text-xs font-bold text-[#002626]/80 uppercase tracking-widest mb-2" for={f.name}>{f.label}{f.required && <span class="text-[#E58346]"> *</span>}</label>
                    <input id={f.name} name={f.name} type={f.type === 'phone' || f.type === 'tel' ? 'tel' : f.type === 'email' ? 'email' : 'text'} placeholder={f.placeholder ?? ''} required={f.required} class="form-field" />
                  </div>
                ))}
              </div>
            )}

            {/* Disponibilité — select */}
            {dispoField && (
              <div>
                <label class="block text-xs font-bold text-[#002626]/80 uppercase tracking-widest mb-2" for="disponibilite">{dispoField.label}{dispoField.required && <span class="text-[#E58346]"> *</span>}</label>
                <select id="disponibilite" name="disponibilite" required={dispoField.required} class="form-field">
                  <option value="" disabled selected>{dispoField.placeholder ?? 'Choisissez…'}</option>
                  {(dispoField.options ?? []).map((o) => <option value={o.value}>{o.label}</option>)}
                </select>
              </div>
            )}

            {/* Lettre de motivation — textarea (maxlength) */}
            {lettreField && (
              <div>
                <label class="block text-xs font-bold text-[#002626]/80 uppercase tracking-widest mb-2" for="lettre_de_motivation">{lettreField.label}{lettreField.required && <span class="text-[#E58346]"> *</span>}</label>
                <textarea id="lettre_de_motivation" name="lettre_de_motivation" placeholder={lettreField.placeholder ?? ''} required={lettreField.required} maxlength={lettreMax} class="form-field"></textarea>
                <p class="form-hint">Maximum {lettreMax} caractères.</p>
              </div>
            )}

            {/* CV — file input with styled drop zone */}
            {cvField && (
              <div>
                <label class="block text-xs font-bold text-[#002626]/80 uppercase tracking-widest mb-2" for="cv_au_format_pdf_ou_doc">{cvField.label}{cvField.required && <span class="text-[#E58346]"> *</span>}</label>
                <div id="fileDrop" class="file-drop">
                  <input type="file" id="cv_au_format_pdf_ou_doc" name="cv_au_format_pdf_ou_doc" accept=".pdf,.doc,.docx" required={cvField.required} aria-describedby="cvHint" />
                  <div class="file-drop-content">
                    <span class="material-symbols-outlined file-drop-icon">upload_file</span>
                    <div class="file-drop-label"><strong>Cliquez</strong> ou glissez votre CV ici</div>
                    <div class="file-drop-sub">PDF, DOC ou DOCX · max. {cvField.max_size_mb ?? 5} MB</div>
                  </div>
                  <div class="file-selected">
                    <span class="material-symbols-outlined f-icon">description</span>
                    <div class="flex-1 min-w-0">
                      <div class="f-name" id="fileName">-</div>
                      <div class="f-size" id="fileSize">-</div>
                    </div>
                    <button type="button" class="f-remove" id="fileRemove" aria-label="Retirer le fichier">
                      <span class="material-symbols-outlined" style="font-size:18px;">close</span>
                    </button>
                  </div>
                </div>
                <p class="form-hint" id="cvHint">Formats acceptés : <strong>PDF, DOC, DOCX</strong> · Taille maximale : <strong>{cvField.max_size_mb ?? 5} MB</strong></p>
                <p class="form-error" id="fileError"></p>
              </div>
            )}

            {/* Honeypot · CSS-hidden, submitted empty (spam guard) */}
            <div class="form-field--hidden" aria-hidden="true">
              <input type="text" name={jobForm.honeypot_field_name} tabindex="-1" autocomplete="off" value="" />
            </div>

            <p id="postuler-msg" role="status" class="text-sm font-semibold" hidden></p>

            {/* Submit */}
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-1">
              <button type="submit" id="submitBtn" class="btn btn-primary btn-lg">
                <span class="material-symbols-outlined" style="font-size:20px;">send</span>
                {jobForm.submit_button_label ?? 'Envoyer ma candidature'}
              </button>
              <a href="#offres" class="text-sm text-[#002626]/55 hover:text-[#002626] transition-colors font-semibold">← Voir les offres</a>
            </div>

            <p class="text-xs text-[#002626]/45 leading-relaxed">
              En soumettant ce formulaire, vous confirmez l'exactitude des informations fournies. Un accusé de réception vous sera envoyé par e-mail sous 48 h.
            </p>
          </form>
          ) : (
            <p class="text-[#002626]/60">Le formulaire est momentanément indisponible. Écrivez-nous à <a class="text-[#C04B72] font-semibold underline" href="mailto:direction@asbl-espoir.be">direction@asbl-espoir.be</a> en joignant votre CV.</p>
          )}

          <!-- Success card (hidden until submit) -->
          <div class="success-card" id="successCard">
            <div class="s-icon">
              <span class="material-symbols-outlined">check</span>
            </div>
            <h3 class="text-2xl font-black text-[#002626] mb-3">Candidature envoyée !</h3>
            <p class="text-[#002626]/70 mb-6 leading-relaxed">
              Merci pour votre candidature. Nous avons bien reçu votre dossier et vous recontacterons par e-mail dans les 10 à 15 jours ouvrables.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="#offres" class="btn btn-outline btn-sm">
                <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                Retour aux offres
              </a>
              <a href="/" class="btn btn-primary btn-sm">
                Accueil
                <span class="material-symbols-outlined" style="font-size:18px;">home</span>
              </a>
            </div>
          </div>

          {jobForm && (
            <script define:vars={{ api: CMS_API_BASE }}>
              (function () {
                var form = document.getElementById('postulerForm');
                if (!form) return;

                var posteInput = document.getElementById('poste_vise');
                var candidLead = document.getElementById('candidatureLead');
                var msg        = document.getElementById('postuler-msg');
                var submitBtn  = document.getElementById('submitBtn');
                var successCard = document.getElementById('successCard');

                // ── Autofill poste_vise (readable job title) ──
                function applyPoste(title) {
                  if (!title || !posteInput) return;
                  posteInput.value = title;
                  posteInput.style.boxShadow = '0 0 0 3px rgba(192,75,114,0.20)';
                  posteInput.style.borderColor = '#C04B72';
                  setTimeout(function () {
                    posteInput.style.transition = 'box-shadow 0.6s ease, border-color 0.6s ease';
                    posteInput.style.boxShadow = '';
                    posteInput.style.borderColor = '';
                  }, 1800);
                  if (candidLead && title !== 'Candidature spontanée') {
                    candidLead.textContent = '';
                    candidLead.appendChild(document.createTextNode('Vous postulez pour le poste de '));
                    var strongEl = document.createElement('strong');
                    strongEl.className = 'text-[#002626]';
                    strongEl.textContent = title;
                    candidLead.appendChild(strongEl);
                    candidLead.appendChild(document.createTextNode('. Remplissez le formulaire ci-dessous pour finaliser votre candidature.'));
                  }
                }

                // ?poste= URL param prefill
                try {
                  var poste = new URLSearchParams(window.location.search).get('poste');
                  if (poste) applyPoste(poste);
                } catch (e) { /* silent */ }

                // In-page "Postuler" / "Candidature spontanée" clicks
                document.querySelectorAll('a[data-poste][href^="#candidature"]').forEach(function (link) {
                  link.addEventListener('click', function () {
                    var title = link.getAttribute('data-poste');
                    if (!title) return;
                    applyPoste(title);
                    setTimeout(function () { if (posteInput) posteInput.focus({ preventScroll: true }); }, 600);
                  });
                });

                // ── File drop-zone UI ──
                var dropZone     = document.getElementById('fileDrop');
                var fileInput    = document.getElementById('cv_au_format_pdf_ou_doc');
                var fileNameEl   = document.getElementById('fileName');
                var fileSizeEl   = document.getElementById('fileSize');
                var fileRemoveBtn = document.getElementById('fileRemove');
                var fileError    = document.getElementById('fileError');
                var MAX_SIZE = 5 * 1024 * 1024;
                var ACCEPT_RE = /\.(pdf|doc|docx)$/i;

                function formatBytes(b) {
                  if (b < 1024) return b + ' B';
                  if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
                  return (b / (1024 * 1024)).toFixed(2) + ' MB';
                }
                function showFileError(m) {
                  if (!fileError || !dropZone) return;
                  fileError.textContent = m;
                  fileError.classList.add('is-visible');
                  dropZone.classList.add('has-error');
                  dropZone.classList.remove('has-file');
                }
                function clearFileError() {
                  if (!fileError || !dropZone) return;
                  fileError.classList.remove('is-visible');
                  fileError.textContent = '';
                  dropZone.classList.remove('has-error');
                }
                function clearFile() {
                  if (fileInput) fileInput.value = '';
                  if (dropZone) dropZone.classList.remove('has-file');
                  clearFileError();
                }
                function handleFile(file) {
                  if (!file) return;
                  clearFileError();
                  if (!ACCEPT_RE.test(file.name)) { showFileError('Format non accepté. Merci d\'envoyer un fichier PDF, DOC ou DOCX.'); clearFile(); return; }
                  if (file.size > MAX_SIZE) { showFileError('Fichier trop volumineux (' + formatBytes(file.size) + '). Taille maximale : 5 MB.'); clearFile(); return; }
                  if (fileNameEl) fileNameEl.textContent = file.name;
                  if (fileSizeEl) fileSizeEl.textContent = formatBytes(file.size);
                  if (dropZone) dropZone.classList.add('has-file');
                }

                if (fileInput) fileInput.addEventListener('change', function (e) { handleFile(e.target.files && e.target.files[0]); });
                if (fileRemoveBtn) fileRemoveBtn.addEventListener('click', function (e) { e.stopPropagation(); e.preventDefault(); clearFile(); });
                if (dropZone) {
                  ['dragenter', 'dragover'].forEach(function (evt) {
                    dropZone.addEventListener(evt, function (e) { e.preventDefault(); e.stopPropagation(); dropZone.classList.add('is-dragover'); });
                  });
                  ['dragleave', 'drop'].forEach(function (evt) {
                    dropZone.addEventListener(evt, function (e) { e.preventDefault(); e.stopPropagation(); dropZone.classList.remove('is-dragover'); });
                  });
                  dropZone.addEventListener('drop', function (e) {
                    var files = e.dataTransfer && e.dataTransfer.files;
                    if (files && files[0]) {
                      try { var dt = new DataTransfer(); dt.items.add(files[0]); if (fileInput) fileInput.files = dt.files; } catch (err) { /* Safari */ }
                      handleFile(files[0]);
                    }
                  });
                }

                // ── Submit: two-step (upload file → submit JSON) ──
                form.addEventListener('submit', async function (e) {
                  e.preventDefault();
                  if (msg) { msg.hidden = true; }

                  if (!form.checkValidity()) { form.reportValidity(); return; }

                  var file = fileInput && fileInput.files && fileInput.files[0];
                  if (file) {
                    if (!ACCEPT_RE.test(file.name)) { showFileError('Format non accepté. Merci d\'envoyer un fichier PDF, DOC ou DOCX.'); return; }
                    if (file.size > MAX_SIZE) { showFileError('Votre CV dépasse 5 MB.'); return; }
                  }

                  if (submitBtn) submitBtn.disabled = true;

                  function fail(text) {
                    if (msg) { msg.textContent = text; msg.style.color = '#C04B72'; msg.hidden = false; }
                    if (submitBtn) submitBtn.disabled = false;
                  }

                  try {
                    // Step 1 — upload the CV if present
                    var cvValue = null;
                    if (file) {
                      var fd = new FormData();
                      fd.append('file', file);
                      var upRes = await fetch(api + '/forms/offre_demploi/fields/cv_au_format_pdf_ou_doc/upload', { method: 'POST', cache: 'no-store', body: fd });
                      if (!upRes.ok) {
                        if (upRes.status === 415) return fail('Format de CV non accepté. Merci d\'envoyer un PDF, DOC ou DOCX.');
                        if (upRes.status === 413) return fail('Votre CV est trop volumineux (max. 5 MB).');
                        if (upRes.status === 429) return fail('Trop de tentatives, patientez un instant puis réessayez.');
                        var upErr = await upRes.json().catch(function () { return {}; });
                        return fail(upErr.error || 'Échec de l\'envoi du CV, réessayez.');
                      }
                      var up = await upRes.json();
                      cvValue = { upload_token: up.upload_token, original_filename: up.original_filename };
                    }

                    // Step 2 — submit the text fields + file reference as JSON
                    var body = {};
                    var fdAll = new FormData(form);
                    fdAll.forEach(function (v, k) {
                      if (k === 'cv_au_format_pdf_ou_doc') return; // file handled separately
                      body[k] = v;
                    });
                    if (cvValue) body.cv_au_format_pdf_ou_doc = cvValue;

                    var res = await fetch(api + '/forms/offre_demploi/submit', { method: 'POST', cache: 'no-store', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                    var data = await res.json().catch(function () { return {}; });

                    if (res.status === 201 || res.status === 200) {
                      if (data.redirect_url) { window.location.href = data.redirect_url; return; }
                      form.style.display = 'none';
                      if (successCard) {
                        successCard.classList.add('is-visible');
                        successCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
                      } else if (msg) {
                        msg.textContent = data.success_message || 'Merci, votre candidature a bien été envoyée.';
                        msg.style.color = '#119DA4'; msg.hidden = false; form.reset();
                      }
                    } else if (res.status === 400) {
                      fail((data.errors || []).map(function (x) { return x.message; }).join(' · ') || data.error || 'Merci de vérifier les champs du formulaire.');
                    } else {
                      fail(data.error || 'Une erreur est survenue, réessayez.');
                    }
                  } catch (err) {
                    fail('Erreur réseau, réessayez.');
                  }
                });
              })();
            </script>
          )}

