                <span class="material-symbols-outlined is-filled" style="font-size:18px">phone</span>
                085 23 58 14
              </a>
              <a href="mailto:direction@asbl-espoir.be" class="flex items-center gap-2 text-white font-semibold text-sm hover:text-[#C04B72] transition-colors">
                <span class="material-symbols-outlined is-filled" style="font-size:18px">mail</span>
                direction@asbl-espoir.be
              </a>
            </div>
          </div>

        </aside>

      </div>
    </div>
  </section>


  <WaveDivider from="#EFE7DA" to="#002626" path="M0 20 Q240 48 720 24 Q1080 4 1440 36 L1440 60 L0 60 Z" />

  <!-- ── CTA: Soutien (V3 unified) ── -->
