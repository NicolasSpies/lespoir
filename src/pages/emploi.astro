              <label class="block text-xs font-bold text-[#002626]/80 uppercase tracking-widest mb-2" for="poste">Poste visé <span class="text-[#E58346]">*</span></label>
              <select id="poste" name="poste" class="form-field" required>
                <option value="">Sélectionnez un poste -</option>
                <option value="srg-educateur">Éducateur·trice spécialisé·e, SRG (CDI)</option>
                <option value="sase-educateur">Éducateur·trice à domicile, SASE (CDD 6 mois)</option>
                <option value="sapa-benevole">Famille bénévole, SAPA (Bénévolat)</option>
