<Fragment slot="scripts">
<script>
(function() {
  'use strict';
  /* ── NAV SHRINK ── */
  var nav = document.querySelector('nav');
  window.addEventListener('scroll', function() {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  /* ── SCROLL REVEAL ── */
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    var revealItems = [];

    document.querySelectorAll('.why-header, .why-item').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 60 });
    });
    document.querySelectorAll('.offres-header, .offre-item').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 80 });
    });
    var pt = document.querySelector('.profiles-text');
    var pi = document.querySelector('.profiles-img');
    if (pt) revealItems.push({ el: pt, delay: 0 });
    if (pi) revealItems.push({ el: pi, delay: 150 });
    document.querySelectorAll('.candid-header, .candid-text, .candid-form').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 100 });
    });
    var donText = document.querySelector('.don-text');
    var donCards = document.querySelector('.don-cards');
    if (donText) revealItems.push({ el: donText, delay: 0 });
    if (donCards) revealItems.push({ el: donCards, delay: 150 });

    revealItems.forEach(function(item) { item.el.classList.add('scroll-reveal'); });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var item = revealItems.find(function(g) { return g.el === el; });
        setTimeout(function() { el.classList.add('revealed'); }, item ? item.delay : 0);
        observer.unobserve(el);
      });
    }, { threshold: 0.07 });

    revealItems.forEach(function(item) { observer.observe(item.el); });

    // Safeguard: reveal anything still hidden after 1.5s
    setTimeout(function() { revealItems.forEach(function(item) { if (!item.el.classList.contains("revealed")) { item.el.classList.add("revealed"); observer.unobserve(item.el); } }); }, 1500);
  }

  /* ── BLUR-UP IMAGES ── */
  document.querySelectorAll('img.blur-up').forEach(function(img) {
    if (img.complete) { img.classList.add('loaded'); return; }
    img.addEventListener('load', function() { img.classList.add('loaded'); });
  });

  /* ── NAV DROPDOWNS ── */
  document.querySelectorAll('.nav-item').forEach(function(item) {
    var closeTimer = null;
    item.querySelectorAll('.nav-dropdown a').forEach(function(link) {
      var color = link.getAttribute('data-hover-color');
      if (color) {
        link.addEventListener('mouseenter', function() { link.style.borderLeftColor = color; });
        link.addEventListener('mouseleave', function() { link.style.borderLeftColor = 'transparent'; });
      }
    });
    item.addEventListener('mouseenter', function() {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      document.querySelectorAll('.nav-item.dropdown-open').forEach(function(other) {
        if (other !== item) other.classList.remove('dropdown-open');
      });
      item.classList.add('dropdown-open');
    });
    item.addEventListener('mouseleave', function() {
      closeTimer = setTimeout(function() { item.classList.remove('dropdown-open'); }, 120);
    });
  });

  /* ══════════════════════════════════════
     CANDIDATURE FORM
     ══════════════════════════════════════ */

  var POSTES_MAP = {
    'srg-educateur': 'Éducateur·trice spécialisé·e, SRG',
    'sase-educateur': 'Éducateur·trice à domicile, SASE',
    'sapa-benevole': 'Famille bénévole, SAPA',
    'coordinateur': 'Coordinateur·trice',
    'psychologue': 'Psychologue',
    'administratif': 'Administratif / Logistique',
    'spontanee': 'Candidature spontanée',
    'autre': 'Autre'
  };

  var posteSelect = document.getElementById('poste');
  var posteHint   = document.getElementById('posteHint');
  var candidLead  = document.getElementById('candidatureLead');

  function applyPoste(poste, opts) {
    opts = opts || {};
    if (!poste || !POSTES_MAP[poste] || !posteSelect) return false;
    posteSelect.value = poste;
    if (posteHint) {
      if (poste === 'spontanee') {
        posteHint.innerHTML = '✓ <strong>Candidature spontanée</strong> sélectionnée, parlez-nous de votre profil idéal ci-dessous.';
      } else {
        posteHint.innerHTML = '✓ Vous postulez pour : <strong>' + POSTES_MAP[poste] + '</strong>. Vous pouvez modifier ce choix ci-dessus.';
      }
      posteHint.style.color = '#5a7420';
    }
    if (candidLead && poste !== 'spontanee') {
      candidLead.innerHTML = 'Vous postulez pour le poste de <strong class="text-[#002626]">' + POSTES_MAP[poste] + '</strong>. Remplissez le formulaire ci-dessous pour finaliser votre candidature.';
    }
    return true;
  }

  /* 1. Prefill from URL query (?poste=…) on first load */
  (function prefillFromUrl() {
    try {
      var params = new URLSearchParams(window.location.search);
      var poste = params.get('poste');
      if (poste) applyPoste(poste);
    } catch (e) { /* silent */ }
  })();

  /* 2. Intercept in-page Postuler/spontanée clicks → prefill + smooth scroll */
  document.querySelectorAll('a[data-poste][href="#candidature"], a[data-poste][href^="#candidature"]').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var poste = link.getAttribute('data-poste');
      if (!poste) return;
      applyPoste(poste);
      // Let the hash navigation do the scroll; html { scroll-padding-top } handles the sticky nav offset.
      // Focus poste select after a beat so users see the selection land.
      setTimeout(function() {
        if (posteSelect) posteSelect.focus({ preventScroll: true });
      }, 600);
    });
  });

  /* 3. File upload validation */
  var MAX_SIZE = 5 * 1024 * 1024; // 5 MB
  var dropZone     = document.getElementById('fileDrop');
  var fileInput    = document.getElementById('cv');
  var fileNameEl   = document.getElementById('fileName');
  var fileSizeEl   = document.getElementById('fileSize');
  var fileRemoveBtn = document.getElementById('fileRemove');
  var fileError    = document.getElementById('fileError');

  function formatBytes(b) {
    if (b < 1024) return b + ' B';
    if (b < 1024 * 1024) return (b / 1024).toFixed(1) + ' KB';
    return (b / (1024 * 1024)).toFixed(2) + ' MB';
  }
  function showFileError(msg) {
    if (!fileError || !dropZone) return;
    fileError.textContent = msg;
    fileError.classList.add('is-visible');
    dropZone.classList.add('has-error');
    dropZone.classList.remove('has-file');
  }
  function clearFileError() {
    if (!fileError || !dropZone) return;
    fileError.classList.remove('is-visible');
    fileError.textContent = '';
    dropZone.classList.remove('has-error');
  }
  function clearFile() {
    if (fileInput) fileInput.value = '';
    if (dropZone) dropZone.classList.remove('has-file');
    clearFileError();
  }
  function handleFile(file) {
    if (!file) return;
    clearFileError();
    var isPdf = file.type === 'application/pdf' || /\.pdf$/i.test(file.name);
    if (!isPdf) { showFileError('Format non accepté. Merci d\'envoyer un fichier PDF.'); clearFile(); return; }
    if (file.size > MAX_SIZE) { showFileError('Fichier trop volumineux (' + formatBytes(file.size) + '). Taille maximale : 5 MB.'); clearFile(); return; }
    if (fileNameEl) fileNameEl.textContent = file.name;
    if (fileSizeEl) fileSizeEl.textContent = formatBytes(file.size);
    if (dropZone)   dropZone.classList.add('has-file');
  }

  if (fileInput) {
    fileInput.addEventListener('change', function(e) {
      handleFile(e.target.files && e.target.files[0]);
    });
  }
  if (fileRemoveBtn) {
    fileRemoveBtn.addEventListener('click', function(e) {
      e.stopPropagation(); e.preventDefault(); clearFile();
    });
  }
  if (dropZone) {
    ['dragenter','dragover'].forEach(function(evt) {
      dropZone.addEventListener(evt, function(e) {
        e.preventDefault(); e.stopPropagation();
        dropZone.classList.add('is-dragover');
      });
    });
    ['dragleave','drop'].forEach(function(evt) {
      dropZone.addEventListener(evt, function(e) {
        e.preventDefault(); e.stopPropagation();
        dropZone.classList.remove('is-dragover');
      });
    });
    dropZone.addEventListener('drop', function(e) {
      var files = e.dataTransfer && e.dataTransfer.files;
      if (files && files[0]) {
        try {
          var dt = new DataTransfer();
          dt.items.add(files[0]);
          if (fileInput) fileInput.files = dt.files;
        } catch (err) { /* Safari fallback */ }
        handleFile(files[0]);
      }
    });
  }

  /* 4. Form submit, placeholder (real integration via ContentCore API) */
  var form        = document.getElementById('postulerForm');
  var submitBtn   = document.getElementById('submitBtn');
  var successCard = document.getElementById('successCard');

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var motivation = document.getElementById('motivation');
      if (motivation && motivation.value.trim().length < 100) {
        alert('Votre lettre de motivation doit contenir au moins 100 caractères.');
        motivation.focus();
        return;
      }
      var file = fileInput && fileInput.files && fileInput.files[0];
      if (!file) { showFileError('Merci d\'ajouter votre CV au format PDF.'); return; }
      if (file.size > MAX_SIZE) { showFileError('Votre CV dépasse 5 MB.'); return; }

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:20px;">hourglass_empty</span>Envoi en cours…';

      /* ★ API HOOK ★
         Replace the setTimeout below with a real fetch() to your ContentCore endpoint.
         Example:
           var fd = new FormData(form);
           fetch('/api/postuler', { method: 'POST', body: fd })
             .then(r => r.ok ? showSuccess() : showFailure())
             .catch(showFailure);
      */
      setTimeout(function() {
        form.style.display = 'none';
        if (successCard) {
          successCard.classList.add('is-visible');
          successCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }, 900);
    });
  }

  if (window.matchMedia('(hover: none)').matches && 'IntersectionObserver' in window) {
    var touchTargets = document.querySelectorAll('.don-card, .job-card, .spontaneous-card');
    var touchObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        entry.target.classList.toggle('is-active', entry.isIntersecting);
      });
    }, { threshold: [0.5], rootMargin: '-20% 0px -20% 0px' });
    touchTargets.forEach(function(el) { touchObs.observe(el); });
  }

})();
</script>


</Fragment>

