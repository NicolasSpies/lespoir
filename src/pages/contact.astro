<Fragment slot="scripts">
<script>
(function() {
  'use strict';
    /* ── SCROLL REVEAL ── */
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    var revealItems = [];

    document.querySelectorAll('.form-col, .info-col').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 120 });
    });

    document.querySelectorAll('.service-col').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 80 });
    });

    var donText = document.querySelector('.don-text');
    var donCards = document.querySelector('.don-cards');
    if (donText) revealItems.push({ el: donText, delay: 0 });
    if (donCards) revealItems.push({ el: donCards, delay: 150 });

    revealItems.forEach(function(item) { item.el.classList.add('scroll-reveal'); });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var item = revealItems.find(function(g) { return g.el === el; });
        setTimeout(function() { el.classList.add('revealed'); }, item ? item.delay : 0);
        observer.unobserve(el);
      });
    }, { threshold: 0.08 });

    revealItems.forEach(function(item) { observer.observe(item.el); });

    // Safeguard: reveal anything still hidden after 1.5s
    setTimeout(function() { revealItems.forEach(function(item) { if (!item.el.classList.contains("revealed")) { item.el.classList.add("revealed"); observer.unobserve(item.el); } }); }, 1500);
  }

  /* ── NAV DROPDOWNS ── */
  

  if (window.matchMedia('(hover: none)').matches && 'IntersectionObserver' in window) {
    var touchTargets = document.querySelectorAll('.don-card, .info-card, .service-contact-card');
    var touchObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        entry.target.classList.toggle('is-active', entry.isIntersecting);
      });
    }, { threshold: [0.5], rootMargin: '-20% 0px -20% 0px' });
    touchTargets.forEach(function(el) { touchObs.observe(el); });
  }

  // ── Pre-select form subject from URL param: ?objet=don|srg|sase|sapa|... ──
  // Used by cross-page CTAs (e.g. "Nous contacter" on don/srg/sase/sapa pages)
  // to drop the user directly into a pre-filled form.
  (function() {
    var params = new URLSearchParams(window.location.search);
    var objet = params.get('objet');
    if (!objet) return;
    var select = document.getElementById('objet');
    if (!select) return;
    var validValues = ['general','srg','sase','sapa','don','emploi','partenariat','autre'];
    if (validValues.indexOf(objet) === -1) return;
    select.value = objet;
    // Brief highlight so the user notices the pre-fill
    select.style.boxShadow = '0 0 0 3px rgba(192,75,114,0.20)';
    select.style.borderColor = '#C04B72';
    setTimeout(function() {
      select.style.transition = 'box-shadow 0.6s ease, border-color 0.6s ease';
      select.style.boxShadow = '';
      select.style.borderColor = '';
    }, 1800);
    // Smooth-scroll to form so user sees it immediately on tall mobile screens
    var firstInput = document.getElementById('prenom');
    if (firstInput) {
      setTimeout(function() {
        var form = firstInput.closest('form');
        if (form) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 200);
    }
  })();

})();
</script>


