---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import WaveDivider from '../components/WaveDivider.astro';
import { getPage, getOrgContact, sectionData, str, strList, asImage, imageUrl, imageSrcSet, focusPosition, extractVisitorHeaders } from '../lib/cms';
import DOMPurify from 'isomorphic-dompurify';

const vis = extractVisitorHeaders(Astro.request);
const page = await getPage('sapa-service-accompagnement-du-parrainage', vis);
const d = sectionData(page, 'srg-1-1');
const faqs = page?.faqs ?? [];

// Org contact block (phone / address from site-data; SAPA uses the asmaa mail).
const org = await getOrgContact(vis);
const orgPhone = org.phone ?? '085 23 58 14';
const orgTel = org.telHref ?? 'tel:+3285235814';
const orgAddr = org.addressLine ?? 'Rue de Biber 11, 4540 Amay, Belgique';
const orgMail = org.asmaaMail ?? 'a.lakrary@asbl-espoir.be';

// description_concept_sapa is a textarea; split blank-line-separated blocks into <p> then sanitize.
const conceptDescHtml = str(d.description_concept_sapa)
  ? DOMPurify.sanitize(
      String(d.description_concept_sapa)
        .split(/\n\s*\n/)
        .map((p) => '<p>' + p.trim() + '</p>')
        .join('')
    )
  : null;

// Repeater: steps to become a parrain/marraine. Cast in frontmatter (TS generics can't sit inside JSX expressions).
const benevolePoints = Array.isArray(d.benevole_points_sase)
  ? (d.benevole_points_sase as Array<Record<string, unknown>>)
  : [];

// Concept image (cast in frontmatter — no TS generics in the template).
const conceptImg = asImage(d.foto_concept_sapa);

const title = "SAPA · Parrainage familial et famille bénévole, Huy · Waremme";
const description = "Service d'Accompagnement du Parrainage : nous relions jeunes en difficulté et familles bénévoles prêtes à s'engager dans la durée. Actif depuis 2022 sur Huy, Waremme et Hannut.";
const keywords = "SAPA parrainage, famille bénévole Wallonie, parrainage enfants Huy, famille d'accueil weekend, tiers de confiance Belgique, L'Espoir SAPA, accompagnement parrainage FWB";
const canonicalPath = "/sapa";
const ogImage = "https://images.unsplash.com/photo-1511895426328-dc8714191300?fm=webp&w=1200&q=80";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"foundingLocation\":{\"@type\":\"Place\",\"name\":\"Antheit, Belgique\"},\"award\":\"Agrément Fédération Wallonie-Bruxelles, secteur Aide à la Jeunesse\",\"slogan\":\"Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://asbl-espoir.be/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"SAPA · Service d'Accompagnement du Parrainage\",\"item\":\"https://asbl-espoir.be/sapa\"}]},{\"@type\":\"Service\",\"@id\":\"https://asbl-espoir.be/sapa#service\",\"name\":\"Service d'Accompagnement du Parrainage (SAPA)\",\"alternateName\":\"SAPA\",\"serviceType\":\"Parrainage familial bénévole\",\"category\":\"Aide à la jeunesse\",\"provider\":{\"@id\":\"https://asbl-espoir.be/#organization\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"audience\":{\"@type\":\"PeopleAudience\",\"audienceType\":\"Enfants et jeunes suivis par l'aide à la jeunesse, ainsi que familles bénévoles prêtes à accueillir un jeune ponctuellement (weekends, vacances)\"},\"description\":\"Service de parrainage familial qui met en relation des enfants et jeunes suivis par l'aide à la jeunesse avec des familles bénévoles engagées dans la durée, pour leur offrir un second lieu affectif et stabilisant. Actif depuis 2022 sur Huy, Waremme et Hannut.\",\"serviceOutput\":\"Mise en relation, formation et accompagnement des familles de parrainage, suivi éducatif de la relation parrainage-jeune\",\"termsOfService\":\"Accès pour les jeunes sur mandat du SAJ, SPJ ou Tribunal de la Jeunesse. Candidature ouverte aux familles bénévoles souhaitant s'engager dans la durée.\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"EUR\",\"availability\":\"https://schema.org/InStock\",\"description\":\"Service public gratuit agréé et subsidié par la Fédération Wallonie-Bruxelles\"},\"availableChannel\":[{\"@type\":\"ServiceChannel\",\"serviceUrl\":\"https://asbl-espoir.be/contact\",\"servicePhone\":\"+32-85-23-58-14\",\"serviceLocation\":{\"@type\":\"Place\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressCountry\":\"BE\"}}}]},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/sapa#webpage\",\"url\":\"https://asbl-espoir.be/sapa\",\"name\":\"SAPA · Parrainage familial et famille bénévole, Huy · Waremme\",\"description\":\"Service d'Accompagnement du Parrainage : nous relions jeunes en difficulté et familles bénévoles prêtes à s'engager dans la durée. Actif depuis 2022 sur Huy, Waremme et Hannut.\",\"inLanguage\":\"fr-BE\",\"dateModified\":\"2026-05-12\",\"datePublished\":\"2024-01-15\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
];
const activeNav = "sapa";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
  trackEntryId={page?.id ?? page?.entry_id ?? null}
  trackSlug={page?.slug ?? null}
>

<style is:global>
  *:focus-visible { outline: 2px solid #119DA4; outline-offset: 3px; border-radius: 4px; }
  button:focus-visible, a:focus-visible { outline: 2px solid #119DA4; outline-offset: 3px; }

  /* ── Don cards hover ── */
  .don-card { transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease; }
  .don-card:hover { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
  .btn-accent { background: #119DA4 !important; color: #fff !important; }
  .btn-accent:hover { box-shadow: 0 10px 24px rgba(17,157,164,0.35) !important; filter: brightness(1.05); }
  /* Donate buttons keep brand cassis even on themed pages */
  .btn-accent[href*="don"], .btn-accent[href="#don"] { background: #C04B72 !important; }
  .btn-accent[href*="don"]:hover, .btn-accent[href="#don"]:hover { box-shadow: 0 10px 24px rgba(192,75,114,0.35); }

  /* ── Image blur-up loading ── */
  .blur-up {
    filter: blur(14px); transform: scale(1.03);
    transition: filter 0.6s ease, transform 0.6s ease, opacity 0.6s ease;
    will-change: filter;
  }
  .blur-up.is-loaded { filter: blur(0); transform: scale(1); }

  /* ── Service image wrapper ── */
  .service-img-wrap {
    border-radius: 1rem; overflow: hidden; height: 400px;
    box-shadow: 0 20px 60px rgba(0,38,38,0.12);
    transform: rotate(-1.5deg);
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), box-shadow 0.5s ease;
  }
  .service-img-wrap.revealed { transform: rotate(-1.5deg); }
  .service-img-wrap.tilt-right.revealed { transform: rotate(1.5deg); }
  .service-img-wrap:hover, .service-img-wrap.revealed:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 0 28px 70px rgba(0,38,38,0.18);
  }
  .service-img-wrap.tilt-right { transform: rotate(1.5deg); }
  .service-img-wrap.tilt-right:hover { transform: rotate(0deg) translateY(-4px); }
  @media (min-width: 768px) { .service-img-wrap { height: 480px; } }
  .service-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Hero blob animations ── */
  @keyframes blob-1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 55% 45% 60% 40% / 50% 60% 40% 50%; }
    33% { transform: translate(22px, -16px) rotate(3deg); border-radius: 60% 40% 55% 45% / 55% 50% 50% 45%; }
    66% { transform: translate(-14px, 18px) rotate(-2deg); border-radius: 50% 50% 65% 35% / 45% 55% 45% 55%; }
  }
  @keyframes blob-2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 60% 40% 70% 30% / 55% 60% 40% 45%; }
    50% { transform: translate(-18px, 14px) rotate(-4deg); border-radius: 55% 45% 60% 40% / 60% 50% 50% 40%; }
  }
  @keyframes blob-3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10px, -12px); }
  }
  .blob-anim-1 { animation: blob-1 16s ease-in-out infinite; }
  .blob-anim-2 { animation: blob-2 20s ease-in-out infinite; }
  .blob-anim-3 { animation: blob-3 12s ease-in-out infinite; }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(6px); opacity: 1; }
  }
  .scroll-indicator { animation: scroll-bounce 2.2s ease-in-out infinite; }
  @keyframes logo-breathe {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.025) rotate(0.6deg); }
  }
  .logo-mark { animation: logo-breathe 9s ease-in-out infinite; transform-origin: center; }
  @media (prefers-reduced-motion: reduce) {
    .blob-anim-1, .blob-anim-2, .blob-anim-3, .scroll-indicator, .logo-mark { animation: none; }
  }

  /* ── Approach cards ── */
  .approach-card {
    background: rgba(0,38,38,0.08);
    border: 1px solid rgba(0,38,38,0.12);
    border-radius: 1rem; padding: 2rem;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .approach-card:hover { background: rgba(0,38,38,0.14); transform: translateY(-3px); }
  .approach-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(0,38,38,0.12);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
  }

  /* ── Process steps ── */
  .process-step { display: flex; gap: 1.25rem; align-items: flex-start; }
  .process-num {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: #119DA4; color: #fff;
    font-weight: 900; font-size: 0.95rem;
    display: flex; align-items: center; justify-content: center;
    margin-top: 2px;
  }

  /* ── Sibling cards ── */
  .sibling-card {
    background: #fff; border-radius: 1rem; padding: 2rem;
    border: 1px solid rgba(0,38,38,0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-decoration: none; display: block;
  }
  .sibling-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,38,38,0.1); }

  /* ── Audience cards ── */
  .audience-card {
    border-radius: 1.25rem; padding: 2.5rem;
    display: flex; flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .audience-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,38,38,0.14); }

  /* ── Zone pills ── */
  .zone-pill {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(17,157,164,0.1); color: #119DA4;
    border: 1px solid rgba(17,157,164,0.25);
    border-radius: 999px; padding: 0.4rem 0.9rem;
    font-size: 0.8rem; font-weight: 700;
  }
  /* ── Scroll-reveal hover fix: specificity (0,3,0) beats .scroll-reveal.revealed (0,2,0) ── */
  .approach-card.revealed:hover { transform: translateY(-3px); }
  .sibling-card.revealed:hover { transform: translateY(-4px); }
  .audience-card.revealed:hover { transform: translateY(-4px); }

  /* ── Organic blobs ── */
  .blob { position:absolute; border-radius:60% 40% 70% 30% / 50% 60% 40% 50%; pointer-events:none; z-index:0; }
  .blob-parent > :not(.blob) { position:relative; z-index:1; }
  .blob-parent { position:relative; overflow:hidden; }

  /* ── FAQ ── */
  .faq-item { background:#fff; border-radius:0.875rem; border:1px solid rgba(0,38,38,0.08); overflow:hidden; }
  .faq-item + .faq-item { margin-top: 0.75rem; }
  .faq-item summary { padding:1.25rem 1.5rem; cursor:pointer; font-weight:700; color:#002626; list-style:none; display:flex; align-items:center; justify-content:space-between; gap:1rem; transition:background 0.2s ease; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item summary:hover { background:rgba(17,157,164,0.05); }
  .faq-item summary .material-symbols-outlined { transition:transform 0.25s ease; opacity:0.55; flex-shrink:0; }
  .faq-item[open] summary .material-symbols-outlined { transform:rotate(180deg); opacity:0.9; }
  .faq-item .faq-body { padding:0 1.5rem 1.5rem; color:#002626; opacity:0.75; line-height:1.65; font-size:0.95rem; }

  /* ── Mobile: auto-activate hover state when element is centered in viewport ── */
  @media (hover: none) {
    .don-card.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
    .don-card.revealed.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); }
    .approach-card.is-active { background: rgba(0,38,38,0.14); transform: translateY(-3px); }
    .approach-card.revealed.is-active { transform: translateY(-3px); }
    .sibling-card.is-active { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,38,38,0.1); }
    .sibling-card.revealed.is-active { transform: translateY(-4px); }
    .audience-card.is-active { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,38,38,0.14); }
    .audience-card.revealed.is-active { transform: translateY(-4px); }
  }

</style>

<main id="main" class="flex-grow" style="--curly-color:#119DA4;">

  <!-- ── HERO ── -->
  <section class="relative overflow-hidden bg-[#EFE7DA]">
    <!-- Mobile-only subtle corner accents -->
    <div aria-hidden="true" class="absolute pointer-events-none md:hidden blob-anim-2" style="width:14rem;height:14rem;top:-3rem;right:-3rem;background:rgba(17,157,164,0.30);border-radius:55% 45% 65% 35%;"></div>
    <div aria-hidden="true" class="absolute pointer-events-none md:hidden blob-anim-3" style="width:6rem;height:6rem;bottom:14rem;left:-1rem;background:rgba(17,157,164,0.18);border-radius:60% 40%;"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 pt-12 md:pt-20 pb-12 md:pb-16">
      <div class="grid md:grid-cols-12 gap-8 items-center mb-14 md:mb-20">

        <!-- Text column -->
        <div class="md:col-span-7 relative z-10">
          <!-- Badge + Subtitle -->
          <span class="inline-flex items-center bg-[#119DA4] text-white rounded-full px-3.5 py-1.5 text-xs md:text-sm font-bold shadow-sm tracking-wide uppercase mb-6 md:mb-8">
            SAPA • Service d'Accompagnement du Parrainage
          </span>

          <!-- H1 -->
          <h1 class="font-black text-[#002626] leading-[1.05] tracking-tight mb-6 md:mb-8" style="font-size:clamp(2.2rem,4.6vw,4rem);">
            {str(d.titre_h1_sapa)
              ? <Fragment set:html={DOMPurify.sanitize(String(d.titre_h1_sapa))} />
              : (<>Un <span style="position:relative;display:inline-block;white-space:nowrap;">lien<svg class="curly-svg" viewBox="0 0 100 10" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg" style="position:absolute;bottom:-4px;left:0;width:100%;height:12px;" aria-hidden="true"><path d="M1 7 Q25 1 50 7 Q75 13 99 4" stroke="#119DA4" stroke-width="2.5" stroke-linecap="round"/></svg></span> privilégié,<br/>une présence bénévole.</>)}
          </h1>

          <!-- Description -->
          <p class="text-base md:text-lg text-[#002626]/75 leading-relaxed mb-8 md:mb-10 max-w-xl">
            {str(d.description_hero_sapa)}
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <a href="#benevole" class="btn btn-accent btn-lg"><span class="material-symbols-outlined" style="font-size:18px;">volunteer_activism</span> Devenir bénévole</a>
            <a href="#orientation" class="btn btn-outline btn-lg"><span class="material-symbols-outlined" style="font-size:18px;">child_care</span> Demander un parrain</a>
          </div>
        </div>

        <!-- Decoration column: desktop only, service logo as focal -->
        <div class="hidden md:flex md:col-span-5 relative h-[480px] items-center justify-center">
          <div aria-hidden="true" class="absolute blob-anim-1" style="width:24rem;height:24rem;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(17,157,164,0.18);border-radius:55% 45% 60% 40% / 50% 60% 40% 50%;"></div>
          <div aria-hidden="true" class="absolute blob-anim-2" style="width:5rem;height:5rem;top:2rem;right:2rem;background:rgba(17,157,164,0.4);border-radius:55% 45% 65% 35%;"></div>
          <div aria-hidden="true" class="absolute blob-anim-3" style="width:3rem;height:3rem;bottom:3rem;left:1rem;background:rgba(13,118,123,0.42);border-radius:60% 40%;animation-delay:-4s;"></div>
          <div aria-hidden="true" class="absolute blob-anim-2" style="width:2rem;height:2rem;top:5rem;left:3rem;background:rgba(17,157,164,0.5);border-radius:50%;animation-delay:-7s;"></div>
          <img src="/logo-sapa.svg" alt="L'Espoir asbl · SAPA" class="logo-mark relative z-10" style="width:18rem;height:auto;" loading="eager"/>
        </div>
      </div>


      <!-- Scroll indicator -->
      <div aria-hidden="true" class="flex flex-col items-center text-[#002626]/40 scroll-indicator mt-10 md:mt-12">
        <span class="material-symbols-outlined" style="font-size:24px;">keyboard_arrow_down</span>
      </div>
    </div>
  </section>


  <WaveDivider from="#EFE7DA" to="#fbf9f8" path="M0 32 Q360 8 720 44 Q1080 48 1440 16 L1440 60 L0 60 Z" />

  <!-- ── LE PARRAINAGE, C'EST QUOI ? ── -->
  <section id="concept" class="blob-parent py-16 md:py-24 px-6 md:px-8 bg-surface">
    <div class="blob" aria-hidden="true" style="width:240px;height:240px;background:rgba(17,157,164,0.09);top:20px;right:-60px;border-radius:50% 50% 70% 30% / 40% 60% 40% 60%;"></div>
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div class="section-text">
        <span class="text-[#119DA4] font-black tracking-widest text-sm uppercase block mb-4">Le concept</span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#002626] mb-6 leading-tight">
          {str(d.titre_concept_sapa)
            ? <Fragment set:html={DOMPurify.sanitize(String(d.titre_concept_sapa))} />
            : (<>Le parrainage familial, <span style="font-weight:500;">un engagement simple et</span> <span style="position:relative;display:inline-block;">profond<svg class="curly-svg" viewBox="0 0 100 10" preserveAspectRatio="none" fill="none" style="position:absolute;bottom:-3px;left:0;width:100%;height:10px;" aria-hidden="true"><path d="M1 7 Q25 2 50 7 Q75 12 99 5" stroke="#119DA4" stroke-width="2.5" stroke-linecap="round"/></svg></span></>)}
        </h2>
        {conceptDescHtml && <div class="text-base md:text-lg text-[#002626]/75 leading-relaxed mb-8 [&>p]:mb-5 [&>p:last-child]:mb-0" set:html={conceptDescHtml} />}
        <div class="checklist flex flex-col gap-3">
          {strList(d.liste_concept_sapa).map(x => (
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#119DA4] mt-0.5 is-filled" style="font-size:20px">check_circle</span>
              <span class="text-[#002626]/80 text-base">{x}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Image -->
      <div class="section-img service-img-wrap">
        {conceptImg
          ? <img
              src={imageUrl(conceptImg, 'lg')}
              srcset={imageSrcSet(conceptImg)}
              sizes="(min-width: 1024px) 50vw, 100vw"
              alt={conceptImg.alt ?? 'Parrainage familial, lien entre un jeune et une famille bénévole'}
              width={conceptImg.width ?? undefined}
              height={conceptImg.height ?? undefined}
              loading="lazy"
              decoding="async"
              class="blur-up"
              style={`object-position:${focusPosition(conceptImg.focus_x, conceptImg.focus_y)};`}
            />
          : <Placeholder alt='Parrainage familial, lien entre un jeune et une famille bénévole' aspectRatio='4/3' />}
      </div>

    </div>

    <!-- ── ESCAPADE · marque du service (discret) ── -->
    <div class="max-w-3xl mx-auto mt-14 md:mt-20">
      <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8 bg-white rounded-2xl p-6 md:p-7 border border-[#002626]/08" style="box-shadow:0 8px 24px rgba(0,38,38,0.05);">
