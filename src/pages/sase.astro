---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import WaveDivider from '../components/WaveDivider.astro';
import { getPage, sectionData, str, strList, asImage, imageUrl, imageSrcSet, focusPosition, extractVisitorHeaders } from '../lib/cms';
import DOMPurify from 'isomorphic-dompurify';

const vis = extractVisitorHeaders(Astro.request);
const page = await getPage('sase', vis);
const d = sectionData(page, 'srg-1');
const equipeRepeater = Array.isArray(d.notre_equipe_repeater_sase) ? d.notre_equipe_repeater_sase as Array<Record<string, unknown>> : [];
const deroulementPoints = Array.isArray(d.deroulement_points_sase) ? d.deroulement_points_sase as Array<Record<string, unknown>> : [];
const fotoPourQui = asImage(d.foto_pour_qui_sase);
const fotoEquipe = asImage(d.foto_equipe_sase);
const faqs = page?.faqs ?? [];

const title = "SASE · Accompagnement socio-éducatif à domicile, Huy · Liège";
const description = "Service d'Accompagnement Socio-Éducatif de L'Espoir asbl : nos éducateurs visitent les familles en difficulté de l'arrondissement de Huy pour soutenir la parentalité et prévenir le placement.";
const keywords = "SASE Huy, accompagnement à domicile enfants, soutien parentalité Wallonie, éducateur famille Liège, prévention placement, aide à la jeunesse domicile Belgique, L'Espoir SASE";
const canonicalPath = "/sase";
const ogImage = "https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?fm=webp&w=1200&q=80";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"foundingLocation\":{\"@type\":\"Place\",\"name\":\"Antheit, Belgique\"},\"award\":\"Agrément Fédération Wallonie-Bruxelles, secteur Aide à la Jeunesse\",\"slogan\":\"Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://asbl-espoir.be/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"SASE · Service d'Accompagnement Socio-Éducatif\",\"item\":\"https://asbl-espoir.be/sase\"}]},{\"@type\":\"Service\",\"@id\":\"https://asbl-espoir.be/sase#service\",\"name\":\"Service d'Accompagnement Socio-Éducatif (SASE)\",\"alternateName\":\"SASE\",\"serviceType\":\"Accompagnement éducatif à domicile\",\"category\":\"Aide à la jeunesse\",\"provider\":{\"@id\":\"https://asbl-espoir.be/#organization\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Arrondissement de Huy\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"audience\":{\"@type\":\"PeopleAudience\",\"audienceType\":\"Familles avec enfants mineurs en difficulté éducative, sociale ou relationnelle\"},\"description\":\"Visites éducatives à domicile pour soutenir la parentalité, dénouer les conflits familiaux, et prévenir si possible une séparation enfant-parents. Accompagnement sur mandat du SPJ ou SAJ, en partenariat avec les familles.\",\"serviceOutput\":\"Accompagnement éducatif à domicile, soutien à la parentalité, médiation familiale, prévention du placement\",\"termsOfService\":\"Accès sur mandat du Service de l'Aide à la Jeunesse (SAJ) ou du Service de Protection de la Jeunesse (SPJ).\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"EUR\",\"availability\":\"https://schema.org/InStock\",\"description\":\"Service public gratuit agréé et subsidié par la Fédération Wallonie-Bruxelles\"},\"availableChannel\":[{\"@type\":\"ServiceChannel\",\"serviceUrl\":\"https://asbl-espoir.be/contact\",\"servicePhone\":\"+32-85-23-58-14\",\"serviceLocation\":{\"@type\":\"Place\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressCountry\":\"BE\"}}}]},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/sase#webpage\",\"url\":\"https://asbl-espoir.be/sase\",\"name\":\"SASE · Accompagnement socio-éducatif à domicile, Huy · Liège\",\"description\":\"Service d'Accompagnement Socio-Éducatif de L'Espoir asbl : nos éducateurs visitent les familles en difficulté de l'arrondissement de Huy pour soutenir la parentalité et prévenir le placement.\",\"inLanguage\":\"fr-BE\",\"dateModified\":\"2026-05-12\",\"datePublished\":\"2024-01-15\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
];
const activeNav = "sase";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
  trackEntryId={page?.id ?? page?.entry_id ?? null}
  trackSlug={page?.slug ?? null}
>

<style is:global>

  /* ── Don cards hover ── */
  .don-card { transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease; }
  .don-card:hover { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
  .btn-accent:hover { box-shadow: 0 10px 24px rgba(192,75,114,0.35); filter: brightness(1.05); }

  /* ── Image blur-up loading ── */
  .blur-up {
    filter: blur(14px); transform: scale(1.03);
    transition: filter 0.6s ease, transform 0.6s ease, opacity 0.6s ease;
    will-change: filter;
  }
  .blur-up.is-loaded { filter: blur(0); transform: scale(1); }

  /* ── Service image wrapper ── */
  .service-img-wrap {
    border-radius: 1rem; overflow: hidden; height: 400px;
    box-shadow: 0 20px 60px rgba(0,38,38,0.12);
    transform: rotate(-1.5deg);
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), box-shadow 0.5s ease;
  }
  .service-img-wrap.revealed { transform: rotate(-1.5deg); }
  .service-img-wrap.tilt-right.revealed { transform: rotate(1.5deg); }
  .service-img-wrap:hover, .service-img-wrap.revealed:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 0 28px 70px rgba(0,38,38,0.18);
  }
  .service-img-wrap.tilt-right { transform: rotate(1.5deg); }
  .service-img-wrap.tilt-right:hover { transform: rotate(0deg) translateY(-4px); }
  @media (min-width: 768px) { .service-img-wrap { height: 480px; } }
  .service-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Hero blob animations ── */
  @keyframes blob-1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 55% 45% 60% 40% / 50% 60% 40% 50%; }
    33% { transform: translate(22px, -16px) rotate(3deg); border-radius: 60% 40% 55% 45% / 55% 50% 50% 45%; }
    66% { transform: translate(-14px, 18px) rotate(-2deg); border-radius: 50% 50% 65% 35% / 45% 55% 45% 55%; }
  }
  @keyframes blob-2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 60% 40% 70% 30% / 55% 60% 40% 45%; }
    50% { transform: translate(-18px, 14px) rotate(-4deg); border-radius: 55% 45% 60% 40% / 60% 50% 50% 40%; }
  }
  @keyframes blob-3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10px, -12px); }
  }
  .blob-anim-1 { animation: blob-1 16s ease-in-out infinite; }
  .blob-anim-2 { animation: blob-2 20s ease-in-out infinite; }
  .blob-anim-3 { animation: blob-3 12s ease-in-out infinite; }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(6px); opacity: 1; }
  }
  .scroll-indicator { animation: scroll-bounce 2.2s ease-in-out infinite; }
  @keyframes logo-breathe {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.025) rotate(0.6deg); }
  }
  .logo-mark { animation: logo-breathe 9s ease-in-out infinite; transform-origin: center; }
  @media (prefers-reduced-motion: reduce) {
    .blob-anim-1, .blob-anim-2, .blob-anim-3, .scroll-indicator, .logo-mark { animation: none; }
  }

  .approach-card {
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 1rem; padding: 2rem;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .approach-card:hover { background: rgba(255,255,255,0.22); transform: translateY(-3px); }
  .approach-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(255,255,255,0.18);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
  }

  .process-step { display: flex; gap: 1.25rem; align-items: flex-start; }
  .process-num {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: #C04B72; color: #fff;
    font-weight: 900; font-size: 0.95rem;
    display: flex; align-items: center; justify-content: center;
    margin-top: 2px;
  }

  .sibling-card {
    background: #fff; border-radius: 1rem; padding: 2rem;
    border: 1px solid rgba(0,38,38,0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-decoration: none; display: block;
  }
  .sibling-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,38,38,0.1); }
  /* ── Scroll-reveal hover fix: specificity (0,3,0) beats .scroll-reveal.revealed (0,2,0) ── */
  .approach-card.revealed:hover { transform: translateY(-3px); }
  .sibling-card.revealed:hover { transform: translateY(-4px); }

  /* ── Organic blobs ── */
  .blob { position:absolute; border-radius:60% 40% 70% 30% / 50% 60% 40% 50%; pointer-events:none; z-index:0; }
  .blob-parent > :not(.blob) { position:relative; z-index:1; }
  .blob-parent { position:relative; overflow:hidden; }

  /* ── FAQ ── */
  .faq-item { background:#fff; border-radius:0.875rem; border:1px solid rgba(0,38,38,0.08); overflow:hidden; }
  .faq-item + .faq-item { margin-top: 0.75rem; }
  .faq-item summary { padding:1.25rem 1.5rem; cursor:pointer; font-weight:700; color:#002626; list-style:none; display:flex; align-items:center; justify-content:space-between; gap:1rem; transition:background 0.2s ease; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item summary:hover { background:rgba(192,75,114,0.05); }
  .faq-item summary .material-symbols-outlined { transition:transform 0.25s ease; opacity:0.55; flex-shrink:0; }
  .faq-item[open] summary .material-symbols-outlined { transform:rotate(180deg); opacity:0.9; }
  .faq-item .faq-body { padding:0 1.5rem 1.5rem; color:#002626; opacity:0.75; line-height:1.65; font-size:0.95rem; }

  /* ── Mobile: auto-activate hover state when element is centered in viewport ── */
  @media (hover: none) {
    .don-card.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
    .don-card.revealed.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); }
    .approach-card.is-active { background: rgba(255,255,255,0.22); transform: translateY(-3px); }
    .approach-card.revealed.is-active { transform: translateY(-3px); }
    .sibling-card.is-active { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,38,38,0.1); }
    .sibling-card.revealed.is-active { transform: translateY(-4px); }
  }

</style>

<main id="main" class="flex-grow">

  <!-- ── HERO ── -->
  <section class="relative overflow-hidden bg-[#EFE7DA]">
    <!-- Mobile-only subtle corner accents -->
    <div aria-hidden="true" class="absolute pointer-events-none md:hidden blob-anim-2" style="width:14rem;height:14rem;top:-3rem;right:-3rem;background:rgba(192,75,114,0.30);border-radius:55% 45% 65% 35%;"></div>
    <div aria-hidden="true" class="absolute pointer-events-none md:hidden blob-anim-3" style="width:6rem;height:6rem;bottom:14rem;left:-1rem;background:rgba(192,75,114,0.18);border-radius:60% 40%;"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 pt-12 md:pt-20 pb-12 md:pb-16">
      <div class="grid md:grid-cols-12 gap-8 items-center mb-14 md:mb-20">

        <!-- Text column -->
        <div class="md:col-span-7 relative z-10">
          <!-- Badge + Subtitle -->
          <span class="inline-flex items-center bg-[#C04B72] text-white rounded-full px-3.5 py-1.5 text-xs md:text-sm font-bold shadow-sm tracking-wide uppercase mb-6 md:mb-8">
            SASE • Service d'Accompagnement Socio-Éducatif
          </span>

          <!-- H1 -->
          <h1 class="font-black text-[#002626] leading-[1.05] tracking-tight mb-6 md:mb-8" style="font-size:clamp(2.2rem,4.6vw,4rem);">
            <Fragment set:html={DOMPurify.sanitize(String(d.titre_h1_sase))} />
          </h1>

          <!-- Description -->
          <p class="text-base md:text-lg text-[#002626]/75 leading-relaxed mb-8 md:mb-10 max-w-xl">
            {str(d.description_hero_sase)}
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <a href="#orientation" class="btn btn-accent btn-lg"><span class="material-symbols-outlined" style="font-size:18px;">phone</span> Nous contacter</a>
            <a href="/homepage#services" class="btn btn-outline btn-lg"><span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span> Retour aux services</a>
          </div>
        </div>

        <!-- Decoration column: desktop only, service logo as focal -->
        <div class="hidden md:flex md:col-span-5 relative h-[480px] items-center justify-center">
          <div aria-hidden="true" class="absolute blob-anim-1" style="width:24rem;height:24rem;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(192,75,114,0.18);border-radius:55% 45% 60% 40% / 50% 60% 40% 50%;"></div>
          <div aria-hidden="true" class="absolute blob-anim-2" style="width:5rem;height:5rem;top:2rem;right:2rem;background:rgba(192,75,114,0.4);border-radius:55% 45% 65% 35%;"></div>
          <div aria-hidden="true" class="absolute blob-anim-3" style="width:3rem;height:3rem;bottom:3rem;left:1rem;background:rgba(139,42,78,0.42);border-radius:60% 40%;animation-delay:-4s;"></div>
          <div aria-hidden="true" class="absolute blob-anim-2" style="width:2rem;height:2rem;top:5rem;left:3rem;background:rgba(192,75,114,0.5);border-radius:50%;animation-delay:-7s;"></div>
          <img src="/logo-sase.svg" alt="L'Espoir asbl · SASE" class="logo-mark relative z-10" style="width:18rem;height:auto;" loading="eager"/>
        </div>
      </div>


      <!-- Scroll indicator -->
      <div aria-hidden="true" class="flex flex-col items-center text-[#002626]/40 scroll-indicator mt-10 md:mt-12">
        <span class="material-symbols-outlined" style="font-size:24px;">keyboard_arrow_down</span>
      </div>
    </div>
  </section>


  <WaveDivider from="#EFE7DA" to="#fbf9f8" path="M0 32 Q360 8 720 44 Q1080 48 1440 16 L1440 60 L0 60 Z" />

  <!-- ── POUR QUI ── -->
  <section id="pour-qui" class="py-16 md:py-24 px-6 md:px-8 bg-surface">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Image (LEFT on desktop) -->
      <div class="section-img service-img-wrap">
        {fotoPourQui
          ? <img src={imageUrl(fotoPourQui, 'lg')} srcset={imageSrcSet(fotoPourQui)} sizes="(max-width:1024px) 100vw, 50vw" alt={fotoPourQui.alt ?? "Famille accompagnée par le SASE de L'Espoir asbl"} loading="lazy" decoding="async" style={`object-position:${focusPosition(fotoPourQui.focus_x, fotoPourQui.focus_y)};`} />
          : <Placeholder alt="Famille accompagnée par le SASE de L'Espoir asbl" aspectRatio='4/3' />}
      </div>

      <!-- Text (RIGHT on desktop) -->
      <div class="section-text">
        <span class="text-[#C04B72] font-black tracking-widest text-sm uppercase block mb-4">Pour qui ?</span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#002626] mb-6 leading-tight">
          <Fragment set:html={DOMPurify.sanitize(String(d.titre_pour_qui_sase))} />
        </h2>
        <div class="text-base md:text-lg text-[#002626]/75 leading-relaxed mb-8 sase-rich" set:html={DOMPurify.sanitize(String(d.description_pour_qui_sase))} />
        <div class="checklist flex flex-col gap-3">
          {strList(d.liste_pour_qui_sase).map((x) => (
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-[#C04B72] mt-0.5 is-filled" style="font-size:20px">check_circle</span>
            <span class="text-[#002626]/80 text-base">{x}</span>
          </div>
          ))}
        </div>
      </div>

    </div>
  </section>


  <WaveDivider from="#fbf9f8" to="#C04B72" path="M0 16 Q360 48 720 12 Q1080 0 1440 44 L1440 60 L0 60 Z" />

  <!-- ── NOTRE APPROCHE ── -->
  <section id="approche" class="py-16 md:py-24 px-6 md:px-8 bg-[#C04B72] blob-parent">
    <div class="blob" aria-hidden="true" style="width:240px;height:240px;background:rgba(17,157,164,0.09);top:20px;right:-60px;border-radius:50% 50% 70% 30% / 40% 60% 40% 60%;"></div>
    <div class="max-w-7xl mx-auto">

      <!-- Header -->
      <div class="flex items-center gap-3 mb-4">
        <div style="width:4px;height:20px;background:rgba(255,255,255,0.5);border-radius:4px;flex-shrink:0;"></div>
        <span class="text-white/60 font-black tracking-widest text-xs uppercase">Notre approche</span>
      </div>
      <h2 class="font-black text-white leading-tight mb-16 max-w-xl" style="font-size:clamp(1.9rem,3.5vw,2.8rem);">
        {str(d.titre_notre_approche_sase)}
      </h2>

      <!-- Steps -->
      <div class="grid grid-cols-1 md:grid-cols-3 relative" style="gap:0;">

        <!-- Step 01 -->
        <div class="pb-12 md:pb-0 md:pr-12 approach-col">
          <div style="width:52px;height:52px;border-radius:50%;background:#002626;display:flex;align-items:center;justify-content:center;margin-bottom:24px;position:relative;z-index:1;">
            <span class="material-symbols-outlined is-filled" style="color:#fff;font-size:24px">home_work</span>
          </div>
          <h3 class="font-black text-white text-xl mb-3 leading-tight">{str(d.titre_approche_1_sase)}</h3>
          <p class="text-white/80 leading-relaxed text-sm">
            {str(d.description_approche_1_sase)}
          </p>
        </div>

        <!-- Step 02 -->
        <div class="pb-12 md:pb-0 md:px-6 approach-col">
          <div style="width:52px;height:52px;border-radius:50%;background:#002626;display:flex;align-items:center;justify-content:center;margin-bottom:24px;position:relative;z-index:1;">
            <span class="material-symbols-outlined is-filled" style="color:#fff;font-size:24px">handshake</span>
          </div>
          <h3 class="font-black text-white text-xl mb-3 leading-tight">{str(d.titre_approche_2_sase)}</h3>
          <p class="text-white/80 leading-relaxed text-sm">
            {str(d.description_approche_2_sase)}
          </p>
        </div>

        <!-- Step 03 -->
        <div class="pb-0 md:pl-12 approach-col">
          <div style="width:52px;height:52px;border-radius:50%;background:#002626;display:flex;align-items:center;justify-content:center;margin-bottom:24px;position:relative;z-index:1;">
            <span class="material-symbols-outlined is-filled" style="color:#fff;font-size:24px">diversity_3</span>
          </div>
          <h3 class="font-black text-white text-xl mb-3 leading-tight">{str(d.titre_approche_3_sase)}</h3>
          <p class="text-white/80 leading-relaxed text-sm">
            {str(d.description_approche_3_sase)}
          </p>
        </div>

      </div>
    </div>
  </section>


  <WaveDivider from="#C04B72" to="#fbf9f8" path="M0 44 Q480 0 720 36 Q1200 48 1440 24 L1440 60 L0 60 Z" />

  <!-- ── L'ÉQUIPE SASE ── -->
  <section id="equipe" class="py-16 md:py-24 px-6 md:px-8 bg-surface">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text (LEFT on desktop) -->
      <div class="section-text">
        <span class="text-[#C04B72] font-black tracking-widest text-sm uppercase block mb-4">L'équipe</span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#002626] mb-6 leading-tight">
          {str(d.titre_notre_equipe_sase)}
        </h2>
        <p class="text-base md:text-lg text-[#002626]/75 leading-relaxed mb-8">
          {str(d.description_notre_equipe_sase)}
