---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Politique de confidentialité · RGPD · L'Espoir asbl";
const description = "Politique de confidentialité conforme RGPD : finalités de traitement, bases légales, durées de conservation, droits des personnes et cookies sur le site de L'Espoir asbl.";
const keywords = "politique confidentialité RGPD, protection données L'Espoir asbl, droits RGPD Belgique, cookies asbl, APD autorité protection données";
const canonicalPath = "/politique-confidentialite";
const ogImage = "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?fm=webp&w=1200&q=80";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://asbl-espoir.be/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Politique de confidentialité\",\"item\":\"https://asbl-espoir.be/politique-confidentialite\"}]},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/politique-confidentialite#webpage\",\"url\":\"https://asbl-espoir.be/politique-confidentialite\",\"name\":\"Politique de confidentialité · RGPD · L'Espoir asbl\",\"description\":\"Politique de confidentialité conforme RGPD : finalités de traitement, bases légales, durées de conservation, droits des personnes et cookies sur le site de L'Espoir asbl.\",\"inLanguage\":\"fr-BE\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
];
const activeNav = null;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
>

<style is:global>
  .btn-accent:hover { box-shadow: 0 10px 24px rgba(192,75,114,0.35); filter: brightness(1.05); }

  /* Legal page content */
  .legal-content h2 {
    font-size: 1.5rem; font-weight: 800; color: #002626;
    margin-top: 2.5rem; margin-bottom: 1rem; letter-spacing: -0.01em;
    scroll-margin-top: 7rem;
  }
  .legal-content h2:first-child { margin-top: 0; }
  .legal-content h3 { font-size: 1.1rem; font-weight: 700; color: #002626; margin-top: 1.75rem; margin-bottom: 0.6rem; }
  .legal-content p { color: #002626; opacity: 0.82; line-height: 1.75; margin-bottom: 1rem; }
  .legal-content a:not(.btn) { color: #C04B72; font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
  .legal-content a:not(.btn):hover { color: #002626; }
  .legal-content ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 1.25rem; color: #002626; opacity: 0.82; }
  .legal-content li { margin-bottom: 0.4rem; line-height: 1.7; }
  .legal-content strong { color: #002626; opacity: 1; font-weight: 700; }

  .legal-card { background: #fff; border: 1px solid rgba(0,38,38,0.08); border-radius: 0.875rem; padding: 1.5rem 1.5rem; }

  .toc-link {
    display: block; padding: 0.55rem 0.9rem; border-radius: 0.5rem;
    color: #002626; font-size: 0.875rem; font-weight: 500;
    text-decoration: none; transition: background 0.18s ease, color 0.18s ease;
    border-left: 2px solid transparent;
  }
  .toc-link:hover { background: #EFE7DA; color: #002626; border-left-color: #C04B72; }
  .toc-link.is-active { background: #EFE7DA; color: #002626; border-left-color: #C04B72; font-weight: 700; }

  /* Rights pill cards */
  .right-card {
    display: flex; gap: 0.85rem; padding: 1rem 1.1rem;
    background: #fff; border: 1px solid rgba(0,38,38,0.08);
    border-radius: 0.75rem;
  }
  .right-card .icon {
    flex-shrink: 0; width: 2.25rem; height: 2.25rem;
    border-radius: 50%; background: rgba(192,75,114,0.15);
    display: flex; align-items: center; justify-content: center;
  }
  .right-card .icon .material-symbols-outlined { color: #C04B72; font-size: 20px; font-variation-settings: 'FILL' 1; }
  .right-card h4 { font-weight: 700; color: #002626; font-size: 0.95rem; margin-bottom: 0.2rem; }
  .right-card p { font-size: 0.85rem; color: #002626; opacity: 0.68; line-height: 1.55; margin: 0; }

  /* Data table */
  .data-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 0.75rem; overflow: hidden; border: 1px solid rgba(0,38,38,0.08); }
  .data-table th, .data-table td { padding: 0.85rem 1rem; text-align: left; font-size: 0.88rem; border-bottom: 1px solid rgba(0,38,38,0.07); vertical-align: top; }
  .data-table th { background: #EFE7DA; color: #002626; font-weight: 700; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table td { color: #002626; opacity: 0.85; line-height: 1.55; }

</style>

<main id="main" class="flex-grow">

  <!-- ── HERO ── -->
  <section class="relative bg-[#002626] pt-16 pb-14 md:pt-24 md:pb-20 px-6 md:px-8 overflow-hidden">
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full pointer-events-none" style="background:radial-gradient(circle, rgba(192,75,114,0.10) 0%, transparent 70%);"></div>
    <div class="relative max-w-4xl mx-auto">
      <span class="text-[#C04B72] font-black tracking-widest text-xs uppercase block mb-4">Protection des données</span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.08] tracking-tight mb-5">
        Vos données,<br class="hidden sm:block"/> notre responsabilité
      </h1>
      <p class="text-lg text-white/65 leading-relaxed max-w-2xl">
        L'Espoir asbl s'engage à protéger la vie privée de toutes les personnes qui nous confient leurs données, enfants, familles, partenaires, donateurs et visiteurs de notre site. Voici comment, pourquoi et combien de temps nous les conservons.
      </p>
      <p class="text-sm text-white/40 mt-6">Dernière mise à jour : 11 mai 2026 · Conforme RGPD (UE 2016/679)</p>
    </div>
  </section>

  <!-- ── CONTENT ── -->
  <section class="py-16 md:py-24 px-6 md:px-8 bg-[#EFE7DA]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-4 gap-10 lg:gap-14">

      <!-- TOC sidebar -->
      <aside class="lg:col-span-1 order-2 lg:order-1">
        <div class="lg:sticky lg:top-28">
          <span class="text-[#C04B72] font-black tracking-widest text-xs uppercase block mb-4">Sommaire</span>
          <nav class="flex flex-col gap-1">
            <a href="#intro" class="toc-link">1. Introduction</a>
            <a href="#responsable" class="toc-link">2. Responsable du traitement</a>
            <a href="#donnees" class="toc-link">3. Données collectées</a>
            <a href="#finalites" class="toc-link">4. Finalités &amp; bases légales</a>
            <a href="#destinataires" class="toc-link">5. Destinataires</a>
            <a href="#conservation" class="toc-link">6. Durée de conservation</a>
            <a href="#securite" class="toc-link">7. Sécurité</a>
            <a href="#droits" class="toc-link">8. Vos droits</a>
            <a href="#cookies" class="toc-link">9. Cookies</a>
            <a href="#mineurs" class="toc-link">10. Mineurs</a>
            <a href="#modifs" class="toc-link">11. Modifications</a>
            <a href="#contact" class="toc-link">12. Contact</a>
          </nav>
        </div>
      </aside>

      <!-- Content -->
      <article class="lg:col-span-3 order-1 lg:order-2 legal-content">

        <div class="legal-card mb-10">
          <h2 id="intro" class="!mt-0">1. Introduction</h2>
          <p>La présente politique de confidentialité décrit la manière dont <strong>L'Espoir asbl</strong> collecte, utilise et protège vos données à caractère personnel lorsque vous interagissez avec notre site <a href="/">asbl-espoir.be</a>, remplissez un formulaire de contact, effectuez un don ou entrez en relation avec l'un de nos services.</p>
          <p>Nous traitons vos données conformément au <strong>Règlement Général sur la Protection des Données</strong> (RGPD, Règlement UE 2016/679) et à la loi belge du 30 juillet 2018 relative à la protection des personnes physiques à l'égard des traitements de données à caractère personnel.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="responsable">2. Responsable du traitement</h2>
          <p>Le responsable du traitement de vos données est :</p>
          <ul>
            <li><strong>L'Espoir ASBL</strong></li>
            <li>Rue de Biber 11, 4540 Amay, Belgique</li>
            <li>N° d'entreprise : 0431 081 064</li>
            <li>Téléphone : <a href="tel:+3285235814">085 23 58 14</a></li>
            <li>E-mail : <a href="mailto:direction@asbl-espoir.be">direction@asbl-espoir.be</a></li>
          </ul>
          <p>Pour toute question relative à la protection de vos données, vous pouvez nous contacter à l'adresse e-mail ci-dessus avec la mention <em>« RGPD »</em> en objet.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="donnees">3. Données collectées</h2>
          <p>Selon le contexte de votre interaction avec nous, nous pouvons être amenés à collecter :</p>
          <h3>Via le formulaire de contact</h3>
          <ul>
            <li>Prénom et nom</li>
            <li>Adresse e-mail</li>
            <li>Numéro de téléphone (facultatif)</li>
            <li>Contenu du message</li>
            <li>Objet de la demande</li>
          </ul>
          <h3>Via les candidatures (offres d'emploi)</h3>
          <ul>
            <li>CV, lettre de motivation, parcours professionnel</li>
            <li>Coordonnées de contact</li>
          </ul>
          <h3>Via les dons</h3>
          <ul>
            <li>Identité et coordonnées (gérées par <strong>Service Arc-en-Ciel asbl</strong>, notre partenaire pour l'attestation fiscale)</li>
            <li>Montant et date du don</li>
          </ul>
          <h3>Automatiquement</h3>
          <ul>
            <li>Adresse IP anonymisée (journalisation technique)</li>
            <li>Type de navigateur, appareil, pages consultées</li>
          </ul>
        </div>

        <div class="legal-card mb-10">
          <h2 id="finalites">4. Finalités &amp; bases légales</h2>
          <p>Nous traitons vos données uniquement dans les finalités suivantes :</p>
          <div class="overflow-x-auto my-4">
            <table class="data-table">
              <thead>
                <tr><th>Finalité</th><th>Base légale (RGPD art. 6)</th></tr>
              </thead>
              <tbody>
                <tr><td>Répondre à vos demandes de contact</td><td>Consentement &amp; intérêt légitime</td></tr>
                <tr><td>Gérer les candidatures à nos offres d'emploi</td><td>Mesures précontractuelles</td></tr>
                <tr><td>Émettre une attestation fiscale (don ≥ 40 €)</td><td>Obligation légale (SPF Finances)</td></tr>
                <tr><td>Assurer la sécurité et le bon fonctionnement du site</td><td>Intérêt légitime</td></tr>
                <tr><td>Accompagnement des bénéficiaires (SRG, SASE, SAPA)</td><td>Mission d'intérêt public &amp; mandat</td></tr>
              </tbody>
            </table>
          </div>
          <p>Nous ne procédons à <strong>aucun profilage</strong> et n'utilisons pas vos données à des fins publicitaires.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="destinataires">5. Destinataires &amp; transferts</h2>
          <p>Vos données ne sont accessibles qu'aux membres habilités de L'Espoir asbl (direction, équipes éducatives et administratives), dans la stricte mesure nécessaire à l'accomplissement de leurs missions.</p>
          <p>L'ensemble du traitement technique est opéré sur une infrastructure unique, soumise à un accord de sous-traitance conforme à l'article 28 du RGPD :</p>
          <ul>
            <li><strong>Hostinger International Ltd.</strong> (Chypre, UE) — hébergement du site web, du serveur de messagerie e-mail, et du VPS sur lequel est déployé notre logiciel interne de gestion des messages de contact (Contentcore). Tous les serveurs concernés sont localisés au sein de l'Espace économique européen.</li>
          </ul>
          <p>Vos données peuvent par ailleurs être communiquées à :</p>
          <ul>
            <li><strong>Service Arc-en-Ciel asbl</strong> — émission des attestations fiscales pour les dons.</li>
            <li>Les <strong>autorités publiques compétentes</strong> (Administration de l'Aide à la Jeunesse, SPF Finances, pouvoirs judiciaires) lorsque la loi l'exige.</li>
          </ul>
          <p><strong>Aucun transfert hors de l'Union européenne</strong> n'est effectué.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="conservation">6. Durée de conservation</h2>
          <ul>
            <li><strong>Demandes de contact :</strong> 2 ans à compter de la dernière interaction.</li>
            <li><strong>Candidatures non retenues :</strong> 2 ans maximum, sauf demande de suppression anticipée.</li>
            <li><strong>Dossiers de bénéficiaires :</strong> selon les délais légaux imposés par l'Aide à la Jeunesse (généralement 30 ans).</li>
            <li><strong>Pièces comptables et fiscales (dons) :</strong> 7 ans, conformément à la législation belge.</li>
            <li><strong>Journaux techniques :</strong> 12 mois maximum.</li>
          </ul>
        </div>

        <div class="legal-card mb-10">
          <h2 id="securite">7. Sécurité</h2>
          <p>Nous mettons en œuvre des mesures techniques et organisationnelles adaptées pour protéger vos données contre l'accès non autorisé, la perte, l'altération ou la divulgation : chiffrement des communications (HTTPS/TLS), accès restreint par profil, sauvegardes régulières, formation du personnel à la confidentialité.</p>
          <p>En cas de violation de données susceptible d'engendrer un risque pour vos droits et libertés, nous nous engageons à notifier l'Autorité de Protection des Données dans les 72 heures, conformément à l'article 33 du RGPD.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="droits">8. Vos droits</h2>
          <p>Conformément au RGPD, vous disposez à tout moment des droits suivants :</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 my-5">
            <div class="right-card">
              <div class="icon"><span class="material-symbols-outlined">visibility</span></div>
              <div><h4>Droit d'accès</h4><p>Obtenir la confirmation que vos données sont traitées et en recevoir une copie.</p></div>
            </div>
            <div class="right-card">
              <div class="icon"><span class="material-symbols-outlined">edit</span></div>
              <div><h4>Droit de rectification</h4><p>Faire corriger les données inexactes ou incomplètes.</p></div>
            </div>
            <div class="right-card">
              <div class="icon"><span class="material-symbols-outlined">delete</span></div>
              <div><h4>Droit à l'effacement</h4><p>Demander la suppression de vos données (sous réserve des obligations légales).</p></div>
            </div>
            <div class="right-card">
              <div class="icon"><span class="material-symbols-outlined">block</span></div>
              <div><h4>Droit à la limitation</h4><p>Limiter le traitement dans certaines circonstances.</p></div>
            </div>
            <div class="right-card">
              <div class="icon"><span class="material-symbols-outlined">ios_share</span></div>
              <div><h4>Droit à la portabilité</h4><p>Recevoir vos données dans un format structuré et réutilisable.</p></div>
            </div>
            <div class="right-card">
              <div class="icon"><span class="material-symbols-outlined">do_not_disturb_on</span></div>
              <div><h4>Droit d'opposition</h4><p>Vous opposer au traitement pour des motifs légitimes.</p></div>
            </div>
          </div>
          <p><strong>Pour exercer ces droits :</strong> envoyez-nous un e-mail à <a href="mailto:direction@asbl-espoir.be">direction@asbl-espoir.be</a> avec une copie d'une pièce d'identité. Nous vous répondrons dans un délai d'un mois maximum.</p>
          <p>Si vous estimez que vos droits ne sont pas respectés, vous pouvez introduire une réclamation auprès de <strong>l'Autorité de Protection des Données</strong>, Rue de la Presse 35, 1000 Bruxelles, <a href="https://www.autoriteprotectiondonnees.be" target="_blank" rel="noopener noreferrer">www.autoriteprotectiondonnees.be</a>.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="cookies">9. Cookies &amp; ressources externes</h2>
          <p>Notre site <strong>ne dépose aucun cookie</strong>, ni traceur, ni outil d'analyse tiers. Aucune information n'est conservée dans votre navigateur entre deux visites.</p>
          <p>De même, <strong>aucune ressource externe</strong> n'est chargée depuis un serveur tiers : les polices d'écriture (Inter, Pally, Material Symbols), les feuilles de style et les scripts sont tous hébergés directement sur notre site. Votre navigateur ne communique donc qu'avec <em>asbl-espoir.be</em>.</p>
          <p>C'est un choix volontaire pour respecter votre vie privée sans avoir besoin d'un bandeau de consentement.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="mineurs">10. Protection des mineurs</h2>
          <p>L'Espoir asbl accompagnant des enfants et des adolescents, la protection de leurs données est une priorité absolue. Les données des mineurs bénéficiaires de nos services sont traitées exclusivement dans le cadre des missions éducatives qui nous sont confiées, dans le respect du <strong>décret du 18 janvier 2018 portant le Code de la prévention, de l'Aide à la jeunesse et de la protection de la jeunesse</strong>.</p>
          <p>Aucune image, aucun prénom ni aucune information permettant d'identifier un mineur ne sont publiés sur le site ou les supports de communication sans l'autorisation écrite préalable du représentant légal.</p>
          <p>Les visuels illustratifs présents sur ce site sont soit des photographies réalisées par l'asbl avec accord écrit, soit des images <strong>générées par intelligence artificielle ne représentant aucune personne réelle</strong>. Aucun visuel n'est extrait d'une banque d'images en ligne. Pour plus de détails, voir les <a href="/mentions-legales#photos">mentions légales</a>.</p>
        </div>

        <div class="legal-card mb-10">
          <h2 id="modifs">11. Modifications de cette politique</h2>
          <p>Nous pouvons être amenés à mettre à jour la présente politique pour refléter des évolutions légales, techniques ou organisationnelles. La date de dernière mise à jour est toujours indiquée en haut de cette page.</p>
          <p>En cas de modification substantielle, nous vous en informerons via les canaux appropriés (publication sur le site, e-mail le cas échéant).</p>
        </div>

        <div class="legal-card">
          <h2 id="contact">12. Nous contacter</h2>
          <p>Pour toute question relative à cette politique ou à l'exercice de vos droits :</p>
          <ul>
            <li>Par courrier : L'Espoir asbl, Rue de Biber 11, 4540 Amay</li>
            <li>Par téléphone : <a href="tel:+3285235814">085 23 58 14</a></li>
            <li>Par e-mail : <a href="mailto:direction@asbl-espoir.be">direction@asbl-espoir.be</a> (objet : <em>RGPD</em>)</li>
          </ul>
          <p class="mt-4 flex flex-wrap gap-3">
            <a href="/contact" class="btn btn-primary btn-sm" style="text-decoration:none;">
              <span class="material-symbols-outlined" style="font-size:18px;">mail</span>
              Formulaire de contact
            </a>
            <a href="/mentions-legales" class="btn btn-outline btn-sm" style="text-decoration:none;">
              <span class="material-symbols-outlined" style="font-size:18px;">gavel</span>
              Mentions légales
            </a>
          </p>
        </div>

      </article>
    </div>
  </section>

</main>

<Fragment slot="scripts">
<script>
(function() {
  'use strict';
  
  // ── ToC scrollspy: highlight current section as user scrolls ──
  if ('IntersectionObserver' in window) {
    var sections = document.querySelectorAll('.legal-content h2[id]');
    var tocLinks = document.querySelectorAll('.toc-link');
    if (sections.length && tocLinks.length) {
      var tocMap = {};
      tocLinks.forEach(function(link) {
        var href = link.getAttribute('href');
        if (href && href.startsWith('#')) tocMap[href.slice(1)] = link;
      });
      var spyObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            tocLinks.forEach(function(l) { l.classList.remove('is-active'); });
            var link = tocMap[entry.target.id];
            if (link) link.classList.add('is-active');
          }
        });
      }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });
      sections.forEach(function(sec) { spyObs.observe(sec); });
    }
  }

})();
</script>


</Fragment>

</BaseLayout>
