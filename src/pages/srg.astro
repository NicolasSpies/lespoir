  <!-- ── CTA: Soutien (V3 unified) ── -->
  <section id="don" class="bg-[#002626] py-16 md:py-24 px-6 md:px-8 overflow-hidden relative">
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full pointer-events-none" style="background:radial-gradient(circle, rgba(192,75,114,0.12) 0%, transparent 70%);"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <span class="text-[#C04B72] font-black tracking-widest text-sm uppercase block mb-5">Merci pour votre soutien</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-6 leading-tight">
        Ensemble, on continue.
      </h2>
      <p class="text-white/70 text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10">
        Chaque contribution, petite ou grande, ponctuelle ou régulière, nous permet d'aller un peu plus loin avec les jeunes qu'on accompagne. Merci, vraiment.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/don" class="btn btn-accent btn-lg">
          <span class="material-symbols-outlined icon-heart" style="font-size:20px;">favorite</span>
          Faire un don
        </a>
      </div>
    </div>
  </section>

</main>

<Fragment slot="scripts">
<script>
(function() {
  'use strict';

  /* ── MOBILE DRAWER ── */
  (function() {
    var btn = document.getElementById('hamburgerBtn');
    var closeBtn = document.getElementById('drawerCloseBtn');
    var drawer = document.getElementById('mobileDrawer');
    var backdrop = document.getElementById('drawerBackdrop');
    if (!btn || !drawer || !backdrop) return;

    function open() {
      drawer.classList.add('is-open'); backdrop.classList.add('is-open');
      btn.classList.add('is-open'); btn.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false'); document.body.classList.add('drawer-open');
    }
    function close() {
      drawer.classList.remove('is-open'); backdrop.classList.remove('is-open');
      btn.classList.remove('is-open'); btn.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true'); document.body.classList.remove('drawer-open');
    }

    btn.addEventListener('click', function() { if (drawer.classList.contains('is-open')) close(); else open(); });
    if (closeBtn) closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    drawer.querySelectorAll('a.m-link, a.m-sublink, a.m-link-main, .m-drawer-footer .btn').forEach(function(el) {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && drawer.classList.contains('is-open')) close(); });
    window.addEventListener('resize', function() { if (window.innerWidth >= 1024 && drawer.classList.contains('is-open')) close(); });

    drawer.querySelectorAll('.m-accordion-trigger').forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        var accordion = trigger.closest('.m-accordion');
        var isOpen = accordion.classList.contains('is-open');
        drawer.querySelectorAll('.m-accordion.is-open').forEach(function(a) {
          a.classList.remove('is-open');
          a.querySelector('.m-accordion-trigger').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) { accordion.classList.add('is-open'); trigger.setAttribute('aria-expanded', 'true'); }
      });
    });
  })();

  /* ── NAV SHRINK ── */
  var nav = document.querySelector('nav');
  window.addEventListener('scroll', function() {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  /* ── IMAGE BLUR-UP ── */
  document.querySelectorAll('img.blur-up').forEach(function(img) {
    if (img.complete && img.naturalWidth > 0) { img.classList.add('is-loaded'); return; }
    img.addEventListener('load', function() { img.classList.add('is-loaded'); }, { once: true });
    img.addEventListener('error', function() { img.classList.add('is-loaded'); }, { once: true });
  });

  /* ── SCROLL REVEAL ── */
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    var revealItems = [];

    // Section text + image pairs
    document.querySelectorAll('.section-text, .section-img').forEach(function(el, i) {
      revealItems.push({ el: el, delay: (i % 2) * 120 });
    });

    // Approach cards (staggered)
    document.querySelectorAll('.approach-col').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 100 });
    });

    // Maison cards
    document.querySelectorAll('.maison-card').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 80 });
    });

    // Orientation sections
    document.querySelectorAll('.orientation-text, .orientation-card').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 120 });
    });

    // Sibling service cards
    document.querySelectorAll('.sibling-card').forEach(function(el, i) {
      revealItems.push({ el: el, delay: i * 80 });
    });

    // Don section
    var donText = document.querySelector('.don-text');
    var donCards = document.querySelector('.don-cards');
    if (donText) revealItems.push({ el: donText, delay: 0 });
    if (donCards) revealItems.push({ el: donCards, delay: 150 });

    revealItems.forEach(function(item) { item.el.classList.add('scroll-reveal'); });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var item = revealItems.find(function(g) { return g.el === el; });
        setTimeout(function() { el.classList.add('revealed'); }, item ? item.delay : 0);
        observer.unobserve(el);
      });
    }, { threshold: 0.1 });

    revealItems.forEach(function(item) { observer.observe(item.el); });

    // Safeguard: reveal anything still hidden after 1.5s
    setTimeout(function() { revealItems.forEach(function(item) { if (!item.el.classList.contains("revealed")) { item.el.classList.add("revealed"); observer.unobserve(item.el); } }); }, 1500);
  }

  /* ── NAV DROPDOWNS ── */
  document.querySelectorAll('.nav-item').forEach(function(item) {
    var closeTimer = null;
    item.querySelectorAll('.nav-dropdown a').forEach(function(link) {
      var color = link.getAttribute('data-hover-color');
      if (color) {
        link.addEventListener('mouseenter', function() { link.style.borderLeftColor = color; });
        link.addEventListener('mouseleave', function() { link.style.borderLeftColor = 'transparent'; });
      }
    });
    item.addEventListener('mouseenter', function() {
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      document.querySelectorAll('.nav-item.dropdown-open').forEach(function(other) {
        if (other !== item) other.classList.remove('dropdown-open');
      });
      item.classList.add('dropdown-open');
    });
    item.addEventListener('mouseleave', function() {
      closeTimer = setTimeout(function() { item.classList.remove('dropdown-open'); }, 120);
    });
  });

  if (window.matchMedia('(hover: none)').matches && 'IntersectionObserver' in window) {
    var touchTargets = document.querySelectorAll('.don-card, .approach-card, .maison-card, .sibling-card');
    var touchObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        entry.target.classList.toggle('is-active', entry.isIntersecting);
      });
    }, { threshold: [0.5], rootMargin: '-20% 0px -20% 0px' });
    touchTargets.forEach(function(el) { touchObs.observe(el); });
  }

  // ── Maison galleries: auto-fade slider + lightbox ──
  (function() {
    var sliders = document.querySelectorAll('.maison-slider');
    if (!sliders.length) return;
    var lightbox = document.getElementById('lightbox');
    var lbImg = lightbox && lightbox.querySelector('.lightbox-img');
    var lbCap = lightbox && lightbox.querySelector('.lightbox-caption');

    // Per-slider state for autoplay
    var sliderStates = [];
    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    sliders.forEach(function(slider, sIdx) {
      var slides = slider.querySelectorAll('.ms-slide');
      var dots = slider.querySelectorAll('.ms-dot');
      var idx = 0;
      var paused = false;

      function show(n) {
        slides.forEach(function(s, i) { s.classList.toggle('active', i === n); });
        dots.forEach(function(d, i) { d.classList.toggle('active', i === n); });
        idx = n;
      }
      function next() { if (!paused) show((idx + 1) % slides.length); }

      sliderStates.push({ getIdx: function() { return idx; } });

      // Autoplay (offset start by sIdx so cards are out of sync)
      if (!reduceMotion) {
        setTimeout(function() {
          setInterval(next, 5500);
        }, sIdx * 1800);
      }

      // Pause on hover
      slider.addEventListener('mouseenter', function() { paused = true; });
      slider.addEventListener('mouseleave', function() { paused = false; });

      // Click / keyboard → open lightbox
      function openLightbox() {
        if (!lightbox) return;
        var images = Array.prototype.map.call(slides, function(img) {
          return {
            src: (img.src || '').replace(/w=\d+/, 'w=1600'),
            alt: img.alt || '',
            caption: img.alt || ''
          };
        });
        var startIdx = idx;
        lbImg.src = images[startIdx].src;
        lbImg.alt = images[startIdx].alt;
        lbCap.textContent = images[startIdx].caption;
        lbCap.style.display = images[startIdx].caption ? '' : 'none';
        lightbox.classList.add('is-open');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        // store nav state on lightbox
        lightbox._gallery = images;
        lightbox._idx = startIdx;
      }
      slider.addEventListener('click', openLightbox);
      slider.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(); }
      });
    });

    // Lightbox controls
    if (lightbox && lbImg && lbCap) {
      function lbShow(i) {
        var imgs = lightbox._gallery; if (!imgs) return;
        var n = (i + imgs.length) % imgs.length;
        lbImg.src = imgs[n].src;
        lbImg.alt = imgs[n].alt;
        lbCap.textContent = imgs[n].caption;
        lbCap.style.display = imgs[n].caption ? '' : 'none';
        lightbox._idx = n;
      }
      function lbClose() {
        lightbox.classList.remove('is-open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      lightbox.querySelector('.lightbox-close').addEventListener('click', lbClose);
      lightbox.querySelector('.lightbox-next').addEventListener('click', function(e) { e.stopPropagation(); lbShow((lightbox._idx || 0) + 1); });
      lightbox.querySelector('.lightbox-prev').addEventListener('click', function(e) { e.stopPropagation(); lbShow((lightbox._idx || 0) - 1); });
      lightbox.addEventListener('click', function(e) { if (e.target === lightbox) lbClose(); });
      document.addEventListener('keydown', function(e) {
        if (!lightbox.classList.contains('is-open')) return;
        if (e.key === 'Escape') lbClose();
        if (e.key === 'ArrowRight') lbShow((lightbox._idx || 0) + 1);
        if (e.key === 'ArrowLeft') lbShow((lightbox._idx || 0) - 1);
      });
    }
  })();

})();
</script>


</Fragment>

</BaseLayout>
