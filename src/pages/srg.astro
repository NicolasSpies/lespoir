---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import WaveDivider from '../components/WaveDivider.astro';
import { getPage, getOrgContact, sectionData, str, strList, asImage, asGallery, imageUrl, imageSrcSet, focusPosition, extractVisitorHeaders } from '../lib/cms';
import DOMPurify from 'isomorphic-dompurify';

const vis = extractVisitorHeaders(Astro.request);
const page = await getPage('srg-service-residentiel-general', vis);
const d = sectionData(page, 'srg');

// Org contact block (phone / address / direction mail) from site-data.
const org = await getOrgContact(vis);
const orgPhone = org.phone ?? '085 23 58 14';
const orgTel = org.telHref ?? 'tel:+3285235814';
const orgAddr = org.addressLine ?? 'Rue de Biber 11, 4540 Amay, Belgique';
const orgMailDir = org.directionMail ?? 'direction@asbl-espoir.be';
const faqs = page?.faqs ?? [];

// notre_equipe_repeater_srg → équipe roles. Wire when non-empty (maps to the 4 role rows).
type EquipeItem = { titre_notre_equipe_srg?: string; description_notre_equipe_srg?: string };
const equipe = Array.isArray((d as Record<string, unknown>).notre_equipe_repeater_srg)
  ? ((d as Record<string, unknown>).notre_equipe_repeater_srg as EquipeItem[])
  : [];
const equipeIcons = ['groups', 'psychology', 'handshake', 'medical_services'];

// orientation_points_srg → numbered process steps. Wire when non-empty (maps to the 5 steps).
type OrientationItem = { titre_points_orientation_srg?: string; description_points_orientation_srg?: string };
const orientation = Array.isArray((d as Record<string, unknown>).orientation_points_srg)
  ? ((d as Record<string, unknown>).orientation_points_srg as OrientationItem[])
  : [];

const title = "SRG · Hébergement résidentiel jeunes 3-18 ans, Huy · Amay";
const description = "Service Résidentiel Général de L'Espoir asbl : trois maisons à Amay et Couthuin qui accueillent des enfants et adolescents de 3 à 18 ans ne pouvant pas rester dans leur famille. Agréé FWB.";
const keywords = "SRG Amay, hébergement résidentiel jeunes, foyer enfants Huy, service résidentiel général Wallonie, aide à la jeunesse SPJ, maison d'accueil adolescents Liège, L'Espoir SRG";
const canonicalPath = "/srg";
const ogImage = "https://images.unsplash.com/photo-1542037104857-ffbb0b9155fb?fm=webp&w=1200&q=80";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"foundingLocation\":{\"@type\":\"Place\",\"name\":\"Antheit, Belgique\"},\"award\":\"Agrément Fédération Wallonie-Bruxelles, secteur Aide à la Jeunesse\",\"slogan\":\"Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://asbl-espoir.be/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"SRG · Service Résidentiel Général\",\"item\":\"https://asbl-espoir.be/srg\"}]},{\"@type\":\"Service\",\"@id\":\"https://asbl-espoir.be/srg#service\",\"name\":\"Service Résidentiel Général (SRG)\",\"alternateName\":\"SRG\",\"serviceType\":\"Hébergement résidentiel pour enfants et adolescents\",\"category\":\"Aide à la jeunesse\",\"provider\":{\"@id\":\"https://asbl-espoir.be/#organization\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Arrondissement de Huy\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"audience\":{\"@type\":\"PeopleAudience\",\"audienceType\":\"Enfants et adolescents de 3 à 18 ans ne pouvant temporairement pas vivre en famille\",\"suggestedMinAge\":3,\"suggestedMaxAge\":18},\"description\":\"Trois maisons d'accueil à Amay et Couthuin hébergeant des jeunes qui, sur mandat du SAJ, SPJ ou Tribunal de la Jeunesse, ne peuvent temporairement pas rester dans leur famille. Encadrement éducatif 24h/24, scolarité, maintien du lien familial.\",\"serviceOutput\":\"Hébergement, accompagnement éducatif, soutien scolaire, accompagnement psychosocial, travail du lien familial\",\"hoursAvailable\":{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\",\"Sunday\"],\"opens\":\"00:00\",\"closes\":\"23:59\"},\"termsOfService\":\"Accès uniquement sur mandat du Service de l'Aide à la Jeunesse (SAJ), du Service de Protection de la Jeunesse (SPJ) ou du Tribunal de la Jeunesse.\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"EUR\",\"availability\":\"https://schema.org/InStock\",\"description\":\"Service public gratuit agréé et subsidié par la Fédération Wallonie-Bruxelles\"},\"availableChannel\":[{\"@type\":\"ServiceChannel\",\"serviceUrl\":\"https://asbl-espoir.be/contact\",\"servicePhone\":\"+32-85-23-58-14\",\"serviceLocation\":{\"@type\":\"Place\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressCountry\":\"BE\"}}}]},{\"@type\":\"Place\",\"@id\":\"https://asbl-espoir.be/srg#maison-couthuin\",\"name\":\"La Maison de Couthuin\",\"description\":\"Maison d'accueil SRG de L'Espoir asbl, une demeure historique avec grand jardin accueillant jusqu'à 15 enfants et adolescents. Rénovation prévue en 2027.\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Couthuin\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"}},{\"@type\":\"Place\",\"@id\":\"https://asbl-espoir.be/srg#maison-amay\",\"name\":\"La Maison d'Amay\",\"description\":\"Maison d'accueil SRG de L'Espoir asbl installée dans un ancien hôtel réaménagé au cœur d'Amay, accueillant jusqu'à 9 jeunes. Mitoyenne du service de mise en autonomie L'Escale.\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"}},{\"@type\":\"Place\",\"@id\":\"https://asbl-espoir.be/srg#escale\",\"name\":\"L'Escale\",\"description\":\"Service de mise en autonomie de L'Espoir asbl à Amay, accueillant jusqu'à 6 jeunes dès 16 ans pour les préparer à la vie autonome. Cuisine gérée collectivement.\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"}},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/srg#webpage\",\"url\":\"https://asbl-espoir.be/srg\",\"name\":\"SRG · Hébergement résidentiel jeunes 3-18 ans, Huy · Amay\",\"description\":\"Service Résidentiel Général de L'Espoir asbl : trois maisons à Amay et Couthuin qui accueillent des enfants et adolescents de 3 à 18 ans ne pouvant pas rester dans leur famille. Agréé FWB.\",\"inLanguage\":\"fr-BE\",\"dateModified\":\"2026-05-12\",\"datePublished\":\"2024-01-15\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
];
const activeNav = "srg";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
  trackEntryId={page?.id ?? page?.entry_id ?? null}
  trackSlug={page?.slug ?? null}
>

<style is:global>
  *:focus-visible { outline: 2px solid #E58346; outline-offset: 3px; border-radius: 4px; }
  button:focus-visible, a:focus-visible { outline: 2px solid #E58346; outline-offset: 3px; }

  /* ── Don cards hover ── */
  .don-card { transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease; }
  .don-card:hover { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
  .btn-accent { background: #E58346 !important; color: #fff !important; }
  .btn-accent:hover { box-shadow: 0 10px 24px rgba(229,131,70,0.35) !important; filter: brightness(1.05); }
  /* Donate buttons keep brand cassis even on themed pages */
  .btn-accent[href*="don"], .btn-accent[href="#don"] { background: #C04B72 !important; }
  .btn-accent[href*="don"]:hover, .btn-accent[href="#don"]:hover { box-shadow: 0 10px 24px rgba(192,75,114,0.35); }

  /* ── Image blur-up loading ── */
  .blur-up {
    filter: blur(14px); transform: scale(1.03);
    transition: filter 0.6s ease, transform 0.6s ease, opacity 0.6s ease;
    will-change: filter;
  }
  .blur-up.is-loaded { filter: blur(0); transform: scale(1); }

  /* ── Service image wrapper ── */
  .service-img-wrap {
    border-radius: 1rem; overflow: hidden; height: 400px;
    box-shadow: 0 20px 60px rgba(0,38,38,0.12);
    transform: rotate(-1.5deg);
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), box-shadow 0.5s ease;
  }
  .service-img-wrap.revealed { transform: rotate(-1.5deg); }
  .service-img-wrap.tilt-right.revealed { transform: rotate(1.5deg); }
  .service-img-wrap:hover, .service-img-wrap.revealed:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 0 28px 70px rgba(0,38,38,0.18);
  }
  .service-img-wrap.tilt-right { transform: rotate(1.5deg); }
  .service-img-wrap.tilt-right:hover { transform: rotate(0deg) translateY(-4px); }
  @media (min-width: 768px) { .service-img-wrap { height: 480px; } }
  .service-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Hero blob animations ── */
  @keyframes blob-1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 55% 45% 60% 40% / 50% 60% 40% 50%; }
    33% { transform: translate(22px, -16px) rotate(3deg); border-radius: 60% 40% 55% 45% / 55% 50% 50% 45%; }
    66% { transform: translate(-14px, 18px) rotate(-2deg); border-radius: 50% 50% 65% 35% / 45% 55% 45% 55%; }
  }
  @keyframes blob-2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 60% 40% 70% 30% / 55% 60% 40% 45%; }
    50% { transform: translate(-18px, 14px) rotate(-4deg); border-radius: 55% 45% 60% 40% / 60% 50% 50% 40%; }
  }
  @keyframes blob-3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10px, -12px); }
  }
  .blob-anim-1 { animation: blob-1 16s ease-in-out infinite; }
  .blob-anim-2 { animation: blob-2 20s ease-in-out infinite; }
  .blob-anim-3 { animation: blob-3 12s ease-in-out infinite; }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(6px); opacity: 1; }
  }
  .scroll-indicator { animation: scroll-bounce 2.2s ease-in-out infinite; }
  @keyframes logo-breathe {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.025) rotate(0.6deg); }
  }
  .logo-mark { animation: logo-breathe 9s ease-in-out infinite; transform-origin: center; }
  @media (prefers-reduced-motion: reduce) {
    .blob-anim-1, .blob-anim-2, .blob-anim-3, .scroll-indicator, .logo-mark { animation: none; }
  }

  .approach-card {
    background: rgba(0,38,38,0.08);
    border: 1px solid rgba(0,38,38,0.12);
    border-radius: 1rem; padding: 2rem;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .approach-card:hover { background: rgba(0,38,38,0.14); transform: translateY(-3px); }
  .approach-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(0,38,38,0.12);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
  }

  /* ── Lightbox (shared with maison galleries) ── */
  .lightbox {
    position: fixed; inset: 0; background: rgba(0,38,38,0.94);
    z-index: 200; display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
  }
  .lightbox.is-open { opacity: 1; pointer-events: auto; }
  .lightbox-img { max-width: 92vw; max-height: 84vh; border-radius: 0.75rem; object-fit: contain; }
  .lightbox-close, .lightbox-prev, .lightbox-next {
    position: absolute; background: rgba(255,255,255,0.14); color: #fff;
    border: 0; width: 48px; height: 48px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background 0.2s ease;
  }
  .lightbox-close { top: 1.5rem; right: 1.5rem; }
  .lightbox-prev { left: 1.5rem; top: 50%; transform: translateY(-50%); }
  .lightbox-next { right: 1.5rem; top: 50%; transform: translateY(-50%); }
  .lightbox-close:hover, .lightbox-prev:hover, .lightbox-next:hover { background: rgba(255,255,255,0.28); }
  .lightbox-caption {
    position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
    color: #fff; background: rgba(0,0,0,0.5); padding: 0.5rem 1rem;
    border-radius: 999px; font-size: 0.85rem; max-width: 80vw; text-align: center;
  }

  /* ── Maison gallery slider + zoom ── */
  .maison-slider { position: relative; overflow: hidden; cursor: zoom-in; }
  .maison-slider .ms-slide {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; display: block;
    opacity: 0; transition: opacity 1s ease-in-out, transform 0.4s ease;
  }
  .maison-slider .ms-slide.active { opacity: 1; }
  .maison-card:hover .maison-slider .ms-slide.active { transform: scale(1.04); }
  .maison-slider .ms-zoom {
    position: absolute; top: 10px; right: 10px;
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(0,38,38,0.55); color: #fff;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.25s ease;
    pointer-events: none; z-index: 3;
  }
  .maison-slider:hover .ms-zoom { opacity: 1; }
  .maison-slider .ms-zoom .material-symbols-outlined { font-size: 18px; }
  .maison-slider .ms-dots {
    position: absolute; bottom: 10px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 6px; z-index: 3;
  }
  .maison-slider .ms-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(255,255,255,0.5);
    transition: background 0.3s ease, width 0.3s ease;
  }
  .maison-slider .ms-dot.active { background: #fff; width: 18px; border-radius: 4px; }
  @media (prefers-reduced-motion: reduce) {
    .maison-slider .ms-slide { transition: opacity 0.2s ease; }
  }

  /* ── Maison feature layout ── */
  .maison-feature {
    display: grid; grid-template-columns: 1fr 1fr;
    border-radius: 1.5rem; overflow: hidden;
    background: #fff; box-shadow: 0 4px 24px rgba(0,38,38,0.10);
    transition: box-shadow 0.3s ease;
  }
  .maison-feature:hover { box-shadow: 0 12px 40px rgba(0,38,38,0.15); }
  .maison-feature.reversed .maison-feature-img { order: 2; }
  .maison-feature.reversed .maison-feature-body { order: 1; }
  .maison-feature-img { position: relative; min-height: 380px; overflow: hidden; }
  .maison-feature-img .maison-slider { position: absolute; inset: 0; width: 100%; height: 100%; }
  .maison-feature:hover .maison-feature-img .maison-slider .ms-slide.active { transform: scale(1.04); }
  .maison-feature-body { padding: 2.5rem 2.25rem; display: flex; flex-direction: column; justify-content: center; }
  @media (min-width: 1280px) {
    .maison-feature { grid-template-columns: 55fr 45fr; }
    .maison-feature.reversed { grid-template-columns: 45fr 55fr; }
    .maison-feature-body { padding: 2.75rem 2.5rem; }
  }
  @media (max-width: 1023px) {
    .maison-feature { grid-template-columns: 1fr; }
    .maison-feature.reversed .maison-feature-img { order: 0; }
    .maison-feature.reversed .maison-feature-body { order: 1; }
    .maison-feature-img { min-height: 260px; }
    .maison-feature-body { padding: 1.75rem 1.5rem; }
  }

  .process-step { display: flex; gap: 1.25rem; align-items: flex-start; }
  .process-num {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: #E58346; color: #fff;
    font-weight: 900; font-size: 0.95rem;
    display: flex; align-items: center; justify-content: center;
    margin-top: 2px;
  }

  .sibling-card {
    background: #fff; border-radius: 1rem; padding: 2rem;
    border: 1px solid rgba(0,38,38,0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-decoration: none; display: block;
  }
  .sibling-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,38,38,0.1); }
  /* ── Scroll-reveal hover fix: specificity (0,3,0) beats .scroll-reveal.revealed (0,2,0) ── */
  .approach-card.revealed:hover { transform: translateY(-3px); }
  .maison-card.revealed:hover { transform: translateY(-4px); }
  .sibling-card.revealed:hover { transform: translateY(-4px); }

  /* ── Organic blobs ── */
  .blob { position:absolute; border-radius:60% 40% 70% 30% / 50% 60% 40% 50%; pointer-events:none; z-index:0; }
  .blob-parent > :not(.blob) { position:relative; z-index:1; }
  .blob-parent { position:relative; overflow:hidden; }

  /* ── FAQ ── */
  .faq-item { background:#fff; border-radius:0.875rem; border:1px solid rgba(0,38,38,0.08); overflow:hidden; }
  .faq-item + .faq-item { margin-top: 0.75rem; }
  .faq-item summary { padding:1.25rem 1.5rem; cursor:pointer; font-weight:700; color:#002626; list-style:none; display:flex; align-items:center; justify-content:space-between; gap:1rem; transition:background 0.2s ease; }
  .faq-item summary::-webkit-details-marker { display:none; }
  .faq-item summary:hover { background:rgba(229,131,70,0.05); }
  .faq-item summary .material-symbols-outlined { transition:transform 0.25s ease; opacity:0.55; flex-shrink:0; }
  .faq-item[open] summary .material-symbols-outlined { transform:rotate(180deg); opacity:0.9; }
  .faq-item .faq-body { padding:0 1.5rem 1.5rem; color:#002626; opacity:0.75; line-height:1.65; font-size:0.95rem; }

  /* ── Mobile: auto-activate hover state when element is centered in viewport ── */
  @media (hover: none) {
    .don-card.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }
    .don-card.revealed.is-active { transform: rotate(0deg) translateY(-6px) scale(1.04); }
    .approach-card.is-active { background: rgba(0,38,38,0.14); transform: translateY(-3px); }
    .approach-card.revealed.is-active { transform: translateY(-3px); }
    .maison-card.is-active { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,38,38,0.14); }
    .maison-card.revealed.is-active { transform: translateY(-4px); }
    .maison-card.is-active .maison-card-img img { transform: scale(1.04); }
    .sibling-card.is-active { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,38,38,0.1); }
    .sibling-card.revealed.is-active { transform: translateY(-4px); }
  }

</style>

<main id="main" class="flex-grow" style="--curly-color:#E58346;">

  <!-- ── HERO ── -->
  <section class="relative overflow-hidden bg-[#EFE7DA]">
    <!-- Mobile-only subtle corner accents -->
    <div aria-hidden="true" class="absolute pointer-events-none md:hidden blob-anim-2" style="width:14rem;height:14rem;top:-3rem;right:-3rem;background:rgba(229,131,70,0.30);border-radius:55% 45% 65% 35%;"></div>
    <div aria-hidden="true" class="absolute pointer-events-none md:hidden blob-anim-3" style="width:6rem;height:6rem;bottom:14rem;left:-1rem;background:rgba(229,131,70,0.18);border-radius:60% 40%;"></div>

    <div class="max-w-7xl mx-auto px-6 md:px-12 pt-12 md:pt-20 pb-12 md:pb-16">
      <div class="grid md:grid-cols-12 gap-8 items-center mb-14 md:mb-20">

        <!-- Text column -->
        <div class="md:col-span-7 relative z-10">
          <!-- Badge + Subtitle -->
          <span class="inline-flex items-center bg-[#E58346] text-white rounded-full px-3.5 py-1.5 text-xs md:text-sm font-bold shadow-sm tracking-wide uppercase mb-6 md:mb-8">
            SRG • Service Résidentiel Général
          </span>

          <!-- H1 -->
          <h1 class="font-black text-[#002626] leading-[1.05] tracking-tight mb-6 md:mb-8" style="font-size:clamp(2.2rem,4.6vw,4rem);">
            <Fragment set:html={DOMPurify.sanitize(String(d.titre_h1_srg))} />
          </h1>

          <!-- Description -->
          <p class="text-base md:text-lg text-[#002626]/75 leading-relaxed mb-8 md:mb-10 max-w-xl">
            {str(d.description_hero_srg)}
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <a href="#orientation" class="btn btn-accent btn-lg"><span class="material-symbols-outlined" style="font-size:18px;">phone</span> Nous contacter</a>
            <a href="/homepage#services" class="btn btn-outline btn-lg"><span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span> Retour aux services</a>
