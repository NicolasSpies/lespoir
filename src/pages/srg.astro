---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaveDivider from '../components/WaveDivider.astro';

const title = "SRG · Hébergement résidentiel jeunes 3-18 ans, Huy · Amay";
const description = "Service Résidentiel Général de L'Espoir asbl : trois maisons à Amay et Couthuin qui accueillent des enfants et adolescents de 3 à 18 ans ne pouvant pas rester dans leur famille. Agréé FWB.";
const keywords = "SRG Amay, hébergement résidentiel jeunes, foyer enfants Huy, service résidentiel général Wallonie, aide à la jeunesse SPJ, maison d'accueil adolescents Liège, L'Espoir SRG";
const canonicalPath = "/srg";
const ogImage = "https://images.unsplash.com/photo-1542037104857-ffbb0b9155fb?fm=webp&w=1200&q=80";
const ogImageAlt = "L'Espoir asbl, aide à la jeunesse à Huy";
const schemaOrg = [
  "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"NGO\",\"@id\":\"https://asbl-espoir.be/#organization\",\"name\":\"L'Espoir asbl\",\"alternateName\":[\"ASBL L'Espoir\",\"L'Espoir Aide à la Jeunesse\"],\"url\":\"https://asbl-espoir.be/\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://asbl-espoir.be/lespoir-logo.svg\",\"width\":512,\"height\":512},\"foundingDate\":\"1985\",\"foundingLocation\":{\"@type\":\"Place\",\"name\":\"Antheit, Belgique\"},\"award\":\"Agrément Fédération Wallonie-Bruxelles, secteur Aide à la Jeunesse\",\"slogan\":\"Aide à la jeunesse à Huy depuis 1985\",\"description\":\"Association sans but lucratif belge agréée par la Fédération Wallonie-Bruxelles, active dans l'aide à la jeunesse à Huy et Amay depuis 1985 via trois services : SRG (résidentiel), SASE (accompagnement socio-éducatif) et SAPA (parrainage familial).\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"},\"geo\":{\"@type\":\"GeoCoordinates\",\"latitude\":50.547,\"longitude\":5.312},\"telephone\":\"+32-85-23-58-14\",\"email\":\"direction@asbl-espoir.be\",\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"City\",\"name\":\"Waremme\"},{\"@type\":\"City\",\"name\":\"Hannut\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"taxID\":\"0431.081.064\",\"sameAs\":[],\"knowsAbout\":[\"aide à la jeunesse\",\"protection de l'enfance\",\"hébergement résidentiel\",\"accompagnement socio-éducatif\",\"parrainage familial\",\"éducation spécialisée\"]},{\"@type\":\"WebSite\",\"@id\":\"https://asbl-espoir.be/#website\",\"url\":\"https://asbl-espoir.be/\",\"name\":\"L'Espoir asbl\",\"inLanguage\":\"fr-BE\",\"publisher\":{\"@id\":\"https://asbl-espoir.be/#organization\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Accueil\",\"item\":\"https://asbl-espoir.be/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"SRG · Service Résidentiel Général\",\"item\":\"https://asbl-espoir.be/srg\"}]},{\"@type\":\"Service\",\"@id\":\"https://asbl-espoir.be/srg#service\",\"name\":\"Service Résidentiel Général (SRG)\",\"alternateName\":\"SRG\",\"serviceType\":\"Hébergement résidentiel pour enfants et adolescents\",\"category\":\"Aide à la jeunesse\",\"provider\":{\"@id\":\"https://asbl-espoir.be/#organization\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Huy\"},{\"@type\":\"City\",\"name\":\"Amay\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Arrondissement de Huy\"},{\"@type\":\"AdministrativeArea\",\"name\":\"Province de Liège\"}],\"audience\":{\"@type\":\"PeopleAudience\",\"audienceType\":\"Enfants et adolescents de 3 à 18 ans ne pouvant temporairement pas vivre en famille\",\"suggestedMinAge\":3,\"suggestedMaxAge\":18},\"description\":\"Trois maisons d'accueil à Amay et Couthuin hébergeant des jeunes qui, sur mandat du SAJ, SPJ ou Tribunal de la Jeunesse, ne peuvent temporairement pas rester dans leur famille. Encadrement éducatif 24h/24, scolarité, maintien du lien familial.\",\"serviceOutput\":\"Hébergement, accompagnement éducatif, soutien scolaire, accompagnement psychosocial, travail du lien familial\",\"hoursAvailable\":{\"@type\":\"OpeningHoursSpecification\",\"dayOfWeek\":[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\",\"Sunday\"],\"opens\":\"00:00\",\"closes\":\"23:59\"},\"termsOfService\":\"Accès uniquement sur mandat du Service de l'Aide à la Jeunesse (SAJ), du Service de Protection de la Jeunesse (SPJ) ou du Tribunal de la Jeunesse.\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"EUR\",\"availability\":\"https://schema.org/InStock\",\"description\":\"Service public gratuit agréé et subsidié par la Fédération Wallonie-Bruxelles\"},\"availableChannel\":[{\"@type\":\"ServiceChannel\",\"serviceUrl\":\"https://asbl-espoir.be/contact\",\"servicePhone\":\"+32-85-23-58-14\",\"serviceLocation\":{\"@type\":\"Place\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Rue de Biber 11\",\"postalCode\":\"4540\",\"addressLocality\":\"Amay\",\"addressCountry\":\"BE\"}}}]},{\"@type\":\"Place\",\"@id\":\"https://asbl-espoir.be/srg#maison-couthuin\",\"name\":\"La Maison de Couthuin\",\"description\":\"Maison d'accueil SRG de L'Espoir asbl pour enfants de 6 à 16 ans, en cadre rural en bord de Meuse.\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Couthuin\",\"addressRegion\":\"Liège\",\"postalCode\":\"4520\",\"addressCountry\":\"BE\"},\"containedInPlace\":{\"@type\":\"City\",\"name\":\"Engis\"}},{\"@type\":\"Place\",\"@id\":\"https://asbl-espoir.be/srg#maison-erables\",\"name\":\"La Maison des Érables\",\"description\":\"Maison d'accueil SRG de L'Espoir asbl pour enfants de 3 à 12 ans, à taille humaine avec jardin et ateliers créatifs.\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"}},{\"@type\":\"Place\",\"@id\":\"https://asbl-espoir.be/srg#escale\",\"name\":\"L'Escale\",\"description\":\"Maison d'accueil SRG de L'Espoir asbl pour adolescents de 10 à 18 ans, axée sur l'autonomie et la préparation à la vie adulte.\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Amay\",\"addressRegion\":\"Liège\",\"addressCountry\":\"BE\"}},{\"@type\":\"WebPage\",\"@id\":\"https://asbl-espoir.be/srg#webpage\",\"url\":\"https://asbl-espoir.be/srg\",\"name\":\"SRG · Hébergement résidentiel jeunes 3-18 ans, Huy · Amay\",\"description\":\"Service Résidentiel Général de L'Espoir asbl : trois maisons à Amay et Couthuin qui accueillent des enfants et adolescents de 3 à 18 ans ne pouvant pas rester dans leur famille. Agréé FWB.\",\"inLanguage\":\"fr-BE\",\"dateModified\":\"2026-05-12\",\"datePublished\":\"2024-01-15\",\"isPartOf\":{\"@id\":\"https://asbl-espoir.be/#website\"},\"about\":{\"@id\":\"https://asbl-espoir.be/#organization\"}}]}",
  "{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Qui peut être accueilli au SRG ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Le SRG accueille des enfants et adolescents de 3 à 18 ans qui ne peuvent temporairement pas vivre dans leur famille. L'accueil se fait dans trois maisons à taille humaine à Amay et Couthuin, agréées par la Fédération Wallonie-Bruxelles.\"}},{\"@type\":\"Question\",\"name\":\"Comment un jeune arrive-t-il dans une de vos maisons ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"L'orientation passe toujours par un mandat officiel : le Service de l'Aide à la Jeunesse (SAJ), le Service de Protection de la Jeunesse (SPJ) ou le Tribunal de la Jeunesse. Une famille ne peut pas placer directement son enfant. Le passage par ces instances est obligatoire.\"}},{\"@type\":\"Question\",\"name\":\"Les parents gardent-ils le contact avec leur enfant ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Oui, systématiquement. Le maintien du lien familial est l'un des objectifs centraux du SRG : visites régulières, retours en famille quand la situation le permet, travail éducatif avec les parents pour préparer un retour à la maison.\"}},{\"@type\":\"Question\",\"name\":\"Combien de temps dure un séjour au SRG ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"La durée dépend de chaque situation et du mandat. Elle peut aller de quelques semaines à plusieurs années. Le projet éducatif est revu régulièrement avec le jeune, sa famille et le service mandant.\"}},{\"@type\":\"Question\",\"name\":\"Comment se passe la scolarité des jeunes accueillis ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Les jeunes restent dans leur école d'origine ou sont inscrits dans une école de la région. Les éducateurs assurent le suivi scolaire au quotidien : devoirs, rencontres avec les enseignants, soutien en cas de difficulté.\"}},{\"@type\":\"Question\",\"name\":\"Le SRG est-il payant pour les familles ?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Non. Le SRG est un service public gratuit, entièrement subsidié par la Fédération Wallonie-Bruxelles. Aucune contribution financière n'est demandée aux familles.\"}}]}",
];
const activeNav = "srg";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  schemaOrg={schemaOrg}
  activeNav={activeNav}
>

<style is:global>
/* ── Base ── */
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
  body { font-family: 'Inter', sans-serif; background-color: #fbf9f8; }

  /* ── Material Symbols ── */
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    display: inline-block; line-height: 1;
    transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Focus states ── */
  *:focus { outline: none; }
  *:focus-visible { outline: 2px solid #E58346; outline-offset: 3px; border-radius: 4px; }
  button:focus-visible, a:focus-visible { outline: 2px solid #E58346; outline-offset: 3px; }

  /* ── Design Tokens ── */
  :root { --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1); }

  /* ── Arrow animations ── */
  a:hover > .material-symbols-outlined,
  a:hover > span > .material-symbols-outlined { transform: translateX(4px); }

  /* ── Text links ── */
  nav a, footer a { transition: var(--transition); }
  nav a:hover, footer a:hover { opacity: 1 !important; }

  /* ── Don cards hover ── */
  .don-card { transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease; }
  .don-card:hover { transform: rotate(0deg) translateY(-6px) scale(1.04); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }

  /* ── Navbar link animated underline ── */
  .nav-link {
    position: relative; padding-bottom: 6px;
    color: #002626; transition: color 0.2s ease;
  }
  .nav-link::after {
    content: ''; position: absolute;
    left: 0; right: 0; bottom: 0; height: 2px;
    background: #002626; transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .nav-link:hover::after, .nav-link.is-active::after { transform: scaleX(1); }
  .nav-link.is-active { font-weight: 700; }

  /* ── Button system ── */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.5rem; padding: 1rem 2rem; border-radius: 999px;
    font-weight: 700; font-size: 1rem; font-family: inherit;
    cursor: pointer; border: 0;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, color 0.25s ease, filter 0.25s ease;
    line-height: 1; text-decoration: none; white-space: nowrap;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }
  .btn-lg { padding: 1.1rem 2.2rem; font-size: 1.05rem; }
  .btn-sm { padding: 0.75rem 1.3rem; font-size: 0.85rem; min-height: 44px; }
  .btn-primary { background: #002626; color: #EFE7DA; }
  .btn-primary:hover { box-shadow: 0 10px 24px rgba(0,38,38,0.25); filter: brightness(1.08); }
  .btn-accent { background: #E58346 !important; color: #fff !important; }
  .btn-accent:hover { box-shadow: 0 10px 24px rgba(229,131,70,0.35) !important; filter: brightness(1.05); }
  .btn-accent .material-symbols-outlined { font-variation-settings: 'FILL' 0; transition: font-variation-settings 0.35s ease, transform 0.35s ease; }
  .btn-accent:hover .material-symbols-outlined { font-variation-settings: 'FILL' 1; transform: scale(1.08); }
  /* Donate buttons keep brand cassis even on themed pages */
  .btn-accent[href*="don"], .btn-accent[href="#don"] { background: #C04B72 !important; }
  .btn-accent[href*="don"]:hover, .btn-accent[href="#don"]:hover { box-shadow: 0 10px 24px rgba(192,75,114,0.35); }
  .btn-outline { background: transparent; color: #002626; box-shadow: inset 0 0 0 2px #002626; }
  .btn-outline:hover { background: #002626; color: #EFE7DA; }
  .btn-outline-light { background: transparent; color: #fff; box-shadow: inset 0 0 0 2px rgba(255,255,255,0.5); }
  .btn-outline-light:hover { background: #fff; color: #002626; box-shadow: inset 0 0 0 2px #fff; }

  /* ── Image blur-up loading ── */
  .blur-up {
    filter: blur(14px); transform: scale(1.03);
    transition: filter 0.6s ease, transform 0.6s ease, opacity 0.6s ease;
    will-change: filter;
  }
  .blur-up.is-loaded { filter: blur(0); transform: scale(1); }

  /* ── Scroll animations ── */
  .scroll-reveal { opacity: 0; transform: translateY(28px); will-change: transform, opacity; }
  .scroll-reveal.revealed {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.55s ease-out, transform 0.4s cubic-bezier(0.4,0,0.2,1), box-shadow 0.3s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal { opacity: 1 !important; transform: none !important; transition: none !important; will-change: auto; }
  }

  /* ── Nav shrink on scroll ── */
  nav > div { transition: padding 0.3s ease; }
  .nav-logo { width: auto; transition: height 0.3s ease; }
  nav.scrolled > div { padding-top: 0.75rem; padding-bottom: 0.75rem; }
  nav.scrolled .nav-logo { height: 2.25rem; }

  /* ── Mobile hamburger & drawer ── */
  .hamburger {
    width: 44px; height: 44px;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    gap: 5px; padding: 0; margin: 0;
    background: transparent; border: 0; cursor: pointer;
    color: #002626; flex-shrink: 0;
  }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    background: currentColor; border-radius: 2px;
    transition: transform 0.28s ease, opacity 0.22s ease;
    transform-origin: center;
  }
  .hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-drawer {
    position: fixed; top: 0; right: 0;
    width: min(88vw, 360px); height: 100vh; height: 100dvh;
    background: #EFE7DA; transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 60; overflow-y: auto;
    display: flex; flex-direction: column;
  }
  .mobile-drawer.is-open { transform: translateX(0); }

  .mobile-drawer-backdrop {
    position: fixed; inset: 0;
    background: rgba(0, 38, 38, 0.5); opacity: 0;
    pointer-events: none; transition: opacity 0.3s ease;
    z-index: 55; backdrop-filter: blur(2px);
  }
  .mobile-drawer-backdrop.is-open { opacity: 1; pointer-events: auto; }

  .m-drawer-header {
    display: flex; align-items: center; justify-content: flex-end;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(0, 38, 38, 0.08); flex-shrink: 0;
  }
  .m-close-btn {
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0, 38, 38, 0.07);
    border: 0; cursor: pointer; color: #002626; transition: background 0.2s ease;
  }
  .m-close-btn:hover { background: rgba(0, 38, 38, 0.14); }

  .m-nav { flex: 1; padding: 0 0 0.5rem; overflow-y: auto; }

  .m-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.9rem 1.25rem; color: #002626; font-weight: 600;
    font-size: 1rem; text-decoration: none; cursor: pointer;
    background: transparent; border: none;
    border-bottom: 1px solid rgba(0, 38, 38, 0.07);
    width: 100%; text-align: left; font-family: inherit;
    transition: background 0.18s ease;
  }
  .m-link:hover { background: rgba(0, 38, 38, 0.04); }
  .m-link.is-active { font-weight: 700; color: #002626; }

  .m-chevron {
    font-size: 20px; opacity: 0.45;
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1); flex-shrink: 0;
  }
  .m-accordion.is-open .m-chevron { transform: rotate(180deg); opacity: 0.7; }

  .m-accordion-body {
    max-height: 0; overflow: hidden;
    transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(0, 38, 38, 0.025);
  }
  .m-accordion.is-open .m-accordion-body { max-height: 480px; }

  .m-sublink {
    display: flex; flex-direction: column;
    padding: 0.65rem 1.25rem 0.65rem 1.75rem;
    border-bottom: 1px solid rgba(0, 38, 38, 0.05);
    text-decoration: none; transition: background 0.18s ease;
  }
  .m-sublink:hover { background: rgba(0, 38, 38, 0.04); }
  .m-sublink .abbr { font-weight: 700; font-size: 0.9rem; color: #002626; }
  .m-sublink .name { font-size: 0.73rem; color: rgba(0, 38, 38, 0.55); margin-top: 1px; }

  .m-drawer-footer { padding: 1.25rem; border-top: 1px solid rgba(0, 38, 38, 0.08); flex-shrink: 0; }
  .m-drawer-footer .btn { width: 100%; }

  body.drawer-open { overflow: hidden; }

  .m-link-row { display: flex; align-items: stretch; border-bottom: 1px solid rgba(0,38,38,0.07); }
  .m-link-row .m-link-main { flex: 1; border-bottom: none; justify-content: flex-start; }
  .m-chevron-btn {
    padding: 0 1rem; background: transparent; border: none;
    border-left: 1px solid rgba(0,38,38,0.07); cursor: pointer;
    color: #002626; display: flex; align-items: center; transition: background 0.18s ease;
  }
  .m-chevron-btn:hover { background: rgba(0,38,38,0.04); }

  /* ── Nav dropdowns ── */
  .nav-item { position: relative; display: flex; align-items: center; }
  .nav-dropdown {
    position: absolute; top: calc(100% + 8px); left: 0;
    min-width: 240px; background: #fff; border-radius: 12px;
    padding: 8px; box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    opacity: 0; transform: translateY(-6px); pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease; z-index: 100;
  }
  .nav-item.dropdown-open .nav-dropdown { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .nav-dropdown a {
    display: block; padding: 8px 14px; border-radius: 8px;
    color: #002626; border-left: 3px solid transparent;
    transition: var(--transition); text-decoration: none; opacity: 1 !important;
  }
  .nav-dropdown a:hover { background: #f5f5f3; }
  .nav-dropdown .dd-abbr { display: block; font-size: 15px; font-weight: 700; }
  .nav-dropdown .dd-name { display: block; font-size: 11.5px; line-height: 1.2; margin-top: 1px; opacity: 0.55; font-weight: 500; }

  /* ── Service image wrapper ── */
  .service-img-wrap {
    border-radius: 1rem; overflow: hidden; height: 400px;
    box-shadow: 0 20px 60px rgba(0,38,38,0.12);
    transform: rotate(-1.5deg);
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), box-shadow 0.5s ease;
  }
  .service-img-wrap.revealed { transform: rotate(-1.5deg); }
  .service-img-wrap.tilt-right.revealed { transform: rotate(1.5deg); }
  .service-img-wrap:hover, .service-img-wrap.revealed:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: 0 28px 70px rgba(0,38,38,0.18);
  }
  .service-img-wrap.tilt-right { transform: rotate(1.5deg); }
  .service-img-wrap.tilt-right:hover { transform: rotate(0deg) translateY(-4px); }
  @media (min-width: 768px) { .service-img-wrap { height: 480px; } }
  .service-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Hero blob animations ── */
  @keyframes blob-1 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 55% 45% 60% 40% / 50% 60% 40% 50%; }
    33% { transform: translate(22px, -16px) rotate(3deg); border-radius: 60% 40% 55% 45% / 55% 50% 50% 45%; }
    66% { transform: translate(-14px, 18px) rotate(-2deg); border-radius: 50% 50% 65% 35% / 45% 55% 45% 55%; }
  }
  @keyframes blob-2 {
    0%, 100% { transform: translate(0, 0) rotate(0deg); border-radius: 60% 40% 70% 30% / 55% 60% 40% 45%; }
    50% { transform: translate(-18px, 14px) rotate(-4deg); border-radius: 55% 45% 60% 40% / 60% 50% 50% 40%; }
  }
  @keyframes blob-3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10px, -12px); }
  }
  .blob-anim-1 { animation: blob-1 16s ease-in-out infinite; }
  .blob-anim-2 { animation: blob-2 20s ease-in-out infinite; }
  .blob-anim-3 { animation: blob-3 12s ease-in-out infinite; }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(6px); opacity: 1; }
  }
  .scroll-indicator { animation: scroll-bounce 2.2s ease-in-out infinite; }
  @keyframes logo-breathe {
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.025) rotate(0.6deg); }
  }
  .logo-mark { animation: logo-breathe 9s ease-in-out infinite; transform-origin: center; }
  @media (prefers-reduced-motion: reduce) {
    .blob-anim-1, .blob-anim-2, .blob-anim-3, .scroll-indicator, .logo-mark { animation: none; }
  }



  .approach-card {
    background: rgba(0,38,38,0.08);
    border: 1px solid rgba(0,38,38,0.12);
    border-radius: 1rem; padding: 2rem;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .approach-card:hover { background: rgba(0,38,38,0.14); transform: translateY(-3px); }
  .approach-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(0,38,38,0.12);
