---
/**
 * CurlyUnderline · animated underline that draws-in when scrolled into view.
 *
 * Wraps a word (or phrase) and adds a hand-drawn curly stroke underneath.
 * Color defaults to cassis (#C04B72) · service pages override with their own color.
 *
 * Usage:
 *   <CurlyUnderline>continuer</CurlyUnderline>
 *   <CurlyUnderline stroke="#E58346">grandir</CurlyUnderline>
 *
 * The .curly-svg + .curly-drawn classes are picked up by animations.js
 * IntersectionObserver to trigger the stroke-dashoffset draw-in.
 */
interface Props {
  stroke?: string;
}
const { stroke = '#C04B72' } = Astro.props;
---
<span style="position:relative;display:inline-block;"><slot /><svg
  class="curly-svg" viewBox="0 0 100 10" preserveAspectRatio="none" fill="none"
  xmlns="http://www.w3.org/2000/svg"
  style="position:absolute;bottom:-3px;left:0;width:100%;height:10px;"
  aria-hidden="true"
><path d="M1 7 Q25 2 50 7 Q75 12 99 5" stroke={stroke} stroke-width="2.5" stroke-linecap="round"/></svg></span>
