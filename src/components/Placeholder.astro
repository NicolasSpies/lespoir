---
/**
 * Placeholder · neutral image placeholder occupying the exact end-format space.
 *
 * Once Contentcore CMS feeds in real images via API this component gets
 * swapped out 1:1 · same dimensions, same rounded corners, just a real photo
 * instead of the logo mark.
 *
 * Design:
 *   - Neutral light-gray background (#EAE9E5) · warm-neutral, blends with brand
 *   - L'Espoir logo mark centered via CSS mask · slightly more visible
 *   - No text label · just the mark to keep it minimal
 *   - Same aspect ratio + rounded corners as the real image will have
 *
 * Aspect ratio: pass `aspectRatio` prop ("16/9", "4/3", "1/1", etc).
 *
 * Accessibility: role="img" + aria-label preserves alt text so screenreaders
 * announce what the real image will eventually show.
 */
interface Props {
  alt?: string;
  aspectRatio?: string;
  rounded?: string;       // tailwind class · default "rounded-3xl"
  class?: string;
}

const {
  alt = "Image à venir",
  aspectRatio = "16/9",
  rounded = "rounded-3xl",
  class: className = "",
} = Astro.props;
---

<div
  class:list={['placeholder', rounded, className]}
  style={`aspect-ratio: ${aspectRatio};`}
  role="img"
  aria-label={alt}
>
  <div class="placeholder-mark" aria-hidden="true"></div>
</div>

<style>
  .placeholder {
    position: relative;
    width: 100%;
    background: #EAE9E5;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .placeholder-mark {
    width: clamp(36px, 20%, 76px);
    aspect-ratio: 261/294;        /* matches logo-mark viewBox */
    background: #002626;
    opacity: 0.22;
    -webkit-mask: url('/logo-mark.svg') no-repeat center / contain;
            mask: url('/logo-mark.svg') no-repeat center / contain;
  }
</style>
