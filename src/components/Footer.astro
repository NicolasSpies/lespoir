---
// Footer · org name / address / phone / legal-number / emails from ContentCore site-data,
// with hardcoded fallback for empty fields. Nav/service/legal links stay hardcoded
// (menus empty in CC). Second email comes from the custom Contact field asmaa_mail.
import { getSiteData, str, escAttr } from '../lib/cms';
const site = await getSiteData();
const orgName = str(site?.company_name);
const addr = str(site?.address);
const addrHtml = addr ? escAttr(addr).replace(/\n/g, '<br/>') : null;
const phone = str(site?.contact_phone);
const legal = str(site?.legal_text);
const email1 = str(site?.contact_email);
const email2 = str(site?.contact_custom_field_values?.asmaa_mail);
---
<footer class="bg-[#001a1a] w-full text-[#EFE7DA]" style="background-image:radial-gradient(ellipse at 20% 30%,rgba(192,75,114,0.10),transparent 60%),radial-gradient(ellipse at 80% 70%,rgba(17,157,164,0.09),transparent 65%);">
  <div class="max-w-7xl mx-auto px-6 md:px-8 pt-12 md:pt-16 pb-8">
    <div class="flex flex-col md:flex-row justify-between gap-12 mb-12">
      <div class="max-w-xs space-y-4">
        <div class="text-xl font-bold">{orgName ?? "L'Espoir asbl"}</div>
        <p class="opacity-70 text-sm leading-relaxed">
          {addrHtml ? <Fragment set:html={addrHtml} /> : <Fragment>Rue de Biber 11<br/>4540 Amay, Belgique</Fragment>}<br/><br/>
          {phone ?? '085 23 58 14'}<br/>
          {email1 ?? 'direction@asbl-espoir.be'}<br/>
          {email2 ?? 'a.lakrary@asbl-espoir.be'}
        </p>
        <p class="opacity-50 text-xs">{legal ?? 'N° entreprise : 0431 081 064'}<br/>Agréé Fédération Wallonie-Bruxelles</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-10">
        <div class="flex flex-col gap-3">
          <span class="font-bold text-[#C04B72] uppercase tracking-widest text-xs mb-1">Navigation</span>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/">Accueil</a>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/apropos">À propos</a>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/actualites">Actualités</a>
        </div>
        <div class="flex flex-col gap-3">
          <span class="font-bold text-[#C04B72] uppercase tracking-widest text-xs mb-1">Engagement</span>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/emploi">Offres d'emploi</a>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/don">Faire un don</a>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/contact">Contact</a>
        </div>
        <div class="flex flex-col gap-3">
          <span class="font-bold text-[#C04B72] uppercase tracking-widest text-xs mb-1">Services</span>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/srg">SRG · Résidentiel</a>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/sase">SASE · Accompagnement</a>
          <a class="opacity-70 hover:opacity-100 text-sm transition-opacity" href="/sapa">SAPA · Parrainage</a>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs opacity-40">
      <p>© 2026 L'Espoir asbl. Tous droits réservés.</p>
      <div class="flex gap-6">
        <a href="/mentions-legales">Mentions légales</a>
        <a href="/politique-confidentialite">Politique de confidentialité</a>
        <span>Made with ♥ by <a href="https://laconis.be" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">lacønis</a></span>
      </div>
    </div>
  </div>
</footer>
