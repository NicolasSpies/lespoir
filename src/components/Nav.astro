---
interface Props {
  activeNav?: string | null;
}
const { activeNav = null } = Astro.props;
const isActive = (key: string) => activeNav === key ? ' is-active' : '';
---
<nav class="w-full top-0 sticky bg-[#EFE7DA] z-50">
  <div class="flex justify-between items-center max-w-7xl mx-auto px-6 lg:px-8 py-4 lg:py-6">
    <a href="/"><img src="/lespoir-logo.svg" alt="L'Espoir asbl" class="nav-logo h-10 lg:h-14" width="901" height="338" fetchpriority="high" /></a>

    <!-- Desktop nav -->
    <div class="hidden lg:flex gap-7 text-sm tracking-tight items-center">
      <a class={`nav-link${isActive('home')}`} href="/">Accueil</a>
      <div class="nav-item">
        <a class={`nav-link cursor-default${activeNav && ['srg','sase','sapa'].includes(activeNav) ? ' is-active' : ''}`} href="#" onclick="event.preventDefault()">Services ▾</a>
        <div class="nav-dropdown">
          <a href="/srg" data-hover-color="#E58346"><span class="dd-abbr" style="color:#E58346">SRG</span><span class="dd-name">Service Résidentiel Général</span></a>
          <a href="/sase" data-hover-color="#C04B72"><span class="dd-abbr" style="color:#C04B72">SASE</span><span class="dd-name">Service d'Accompagnement Socio-Éducatif</span></a>
          <a href="/sapa" data-hover-color="#119DA4"><span class="dd-abbr" style="color:#119DA4">SAPA</span><span class="dd-name">Service d'Accompagnement du Parrainage</span></a>
        </div>
      </div>
      <a class={`nav-link${isActive('apropos')}`} href="/apropos">À propos</a>
      <a class={`nav-link${isActive('actualites')}`} href="/actualites">Actualités</a>
      <a class={`nav-link${isActive('emploi')}`} href="/emploi">Offres d'emploi</a>
      <a class={`nav-link${isActive('contact')}`} href="/contact">Contact</a>
    </div>

    <!-- Right side actions -->
    <div class="flex items-center gap-2 sm:gap-3">
      <a href="/don" class="btn btn-accent btn-sm">
        <span class="material-symbols-outlined icon-heart" style="font-size:18px;">favorite</span>
        <span class="hidden min-[420px]:inline">Faire un don</span>
      </a>
      <button id="hamburgerBtn" class="hamburger lg:hidden" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobileDrawer">
        <svg class="hamburger-icon" viewBox="0 0 32 32" aria-hidden="true">
          <path class="bun" d="M27 10 13 10C10.8 10 9 8.2 9 6 9 3.5 10.8 2 13 2 15.2 2 17 3.8 17 6L17 26C17 28.2 18.8 30 21 30 23.2 30 25 28.2 25 26 25 23.8 23.2 22 21 22L7 22"/>
          <path d="M7 16 27 16"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  // Desktop nav dropdown · hover-intent with 120ms close delay,
  // service-colored left-border on dropdown links via data-hover-color.
  (function() {
    document.querySelectorAll('.nav-item').forEach(function(item) {
      var closeTimer = null;
      item.querySelectorAll('.nav-dropdown a').forEach(function(link) {
        var color = link.getAttribute('data-hover-color');
        if (color) {
          link.addEventListener('mouseenter', function() { link.style.borderLeftColor = color; });
          link.addEventListener('mouseleave', function() { link.style.borderLeftColor = 'transparent'; });
        }
      });
      item.addEventListener('mouseenter', function() {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        document.querySelectorAll('.nav-item.dropdown-open').forEach(function(other) {
          if (other !== item) other.classList.remove('dropdown-open');
        });
        item.classList.add('dropdown-open');
      });
      item.addEventListener('mouseleave', function() {
        closeTimer = setTimeout(function() { item.classList.remove('dropdown-open'); }, 120);
      });
    });
  })();
</script>
