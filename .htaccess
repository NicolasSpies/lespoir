# ═══════════════════════════════════════════════════════════════
# .htaccess · L'Espoir asbl
# Static site optimization for Hostinger (Apache)
# ═══════════════════════════════════════════════════════════════

RewriteEngine On
RewriteBase /

# ─────── HTTPS redirect ───────
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ─────── www → non-www (canonical) ───────
RewriteCond %{HTTP_HOST} ^www\.asbl-espoir\.be [NC]
RewriteRule ^(.*)$ https://asbl-espoir.be/$1 [R=301,L]

# ─────── Default homepage ───────
DirectoryIndex homepage.html

# ─────── Hide .html extension ───────
# 1) If user requests /foo.html → redirect to clean /foo (SEO canonical)
RewriteCond %{THE_REQUEST} \s/([^.\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2) Internally serve .html when user requests clean URL
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ─────── Custom 404 ───────
ErrorDocument 404 /404.html

# ═══════════════════════════════════════════════════════════════
# Performance · Compression + Caching
# ═══════════════════════════════════════════════════════════════

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/otf font/ttf font/woff font/woff2
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType image/jpeg                "access plus 6 months"
  ExpiresByType image/png                 "access plus 6 months"
  ExpiresByType image/webp                "access plus 6 months"
  ExpiresByType image/svg+xml             "access plus 6 months"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/otf                  "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/xml           "access plus 1 day"
  ExpiresByType application/json          "access plus 0 seconds"
</IfModule>

# ═══════════════════════════════════════════════════════════════
# Security headers
# ═══════════════════════════════════════════════════════════════

<IfModule mod_headers.c>
  Header set X-Content-Type-Options          "nosniff"
  Header set X-Frame-Options                 "SAMEORIGIN"
  Header set Referrer-Policy                 "strict-origin-when-cross-origin"
  Header set Permissions-Policy              "geolocation=(), microphone=(), camera=(), interest-cohort=()"
  Header set Strict-Transport-Security       "max-age=31536000; includeSubDomains; preload"
  Header set X-XSS-Protection                "1; mode=block"

  # Allow self-hosted fonts & assets
  <FilesMatch "\.(woff|woff2|otf|ttf)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# ═══════════════════════════════════════════════════════════════
# Block sensitive files
# ═══════════════════════════════════════════════════════════════

<FilesMatch "(^\.|\.bak$|\.sql$|\.log$|\.git|README\.md|CHANGELOG\.md)">
  Require all denied
</FilesMatch>

# Disable directory listing
Options -Indexes

# Block hidden internal pages from being indexed via direct access
<Files "briefing.html">
  Header set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "palettes.html">
  Header set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "index.html">
  Header set X-Robots-Tag "noindex, nofollow"
</Files>
